{
  "buildCommand": "next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "functions": {
    "pages/**/*.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "pages/api/**/*.js": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "github": {
    "silent": true,
    "autoJobCancel": true
  }
}