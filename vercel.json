{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/ads/**/*.js": {
      "maxDuration": 10,
      "regions": ["iad1", "cdg1", "hnd1", "syd1"]
    },
    "app/api/content/**/*.js": {
      "maxDuration": 10,
      "regions": ["iad1", "cdg1", "hnd1", "syd1"]
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=1, stale-while-revalidate=59"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "public, max-age=300"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}