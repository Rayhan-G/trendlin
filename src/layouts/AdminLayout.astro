---
// ============================================
// ADMIN LAYOUT - Trendlin
// ============================================

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Trendlin Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet" />
    <style>
      /* ==========================================
      RESET & BASE
      ========================================== */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #f8fafc;
        color: #0f172a;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      
      a {
        text-decoration: none;
        color: inherit;
      }
      
      /* ==========================================
      ADMIN CONTAINER
      ========================================== */
      .admin-container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      
      @media (min-width: 640px) {
        .admin-container {
          padding: 0 2rem;
        }
      }
      
      @media (min-width: 1024px) {
        .admin-container {
          padding: 0 4rem;
        }
      }
      
      /* ==========================================
      FIX: Padding for fixed navbar
      ========================================== */
      .admin-main {
        padding-top: 80px; /* Desktop navbar height */
        min-height: 100vh;
      }
      
      /* Mobile navbar height */
      @media (max-width: 767px) {
        .admin-main {
          padding-top: 64px;
        }
      }
      
      /* ==========================================
      NAVBAR
      ========================================== */
      .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(229, 231, 235, 0.5);
        height: 64px;
      }
      
      @media (min-width: 768px) {
        .navbar {
          height: 80px;
        }
      }
      
      .navbar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 100%;
      }
      
      .navbar-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      
      .navbar-logo-icon {
        width: 2rem;
        height: 2rem;
        background: linear-gradient(to bottom right, #2563eb, #7c3aed);
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-weight: 700;
        font-size: 0.875rem;
        box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.25);
      }
      
      @media (min-width: 768px) {
        .navbar-logo-icon {
          width: 2.25rem;
          height: 2.25rem;
          font-size: 1rem;
        }
      }
      
      .navbar-logo-text {
        font-size: 1.125rem;
        font-weight: 700;
        color: #0f172a;
      }
      
      @media (min-width: 768px) {
        .navbar-logo-text {
          font-size: 1.25rem;
        }
      }
      
      .navbar-nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      
      .navbar-nav a {
        font-size: 0.875rem;
        color: #64748b;
        transition: color 0.2s ease;
      }
      
      .navbar-nav a:hover {
        color: #2563eb;
      }
      
      .navbar-nav a.logout {
        color: #ef4444;
      }
      
      .navbar-nav a.logout:hover {
        color: #dc2626;
      }
    </style>
  </head>
  
  <body>
    <!-- ==========================================
    NAVBAR
    ========================================== -->
    <header class="navbar">
      <div class="admin-container">
        <div class="navbar-inner">
          <!-- Logo -->
          <a href="/admin/dashboard" class="navbar-logo">
            <div class="navbar-logo-icon">T</div>
            <span class="navbar-logo-text">Admin Panel</span>
          </a>
          
          <!-- Navigation -->
          <nav class="navbar-nav">
            <a href="/admin/dashboard">Dashboard</a>
            <a href="/admin/new">New Post</a>
            <a href="/">View Site</a>
            <a href="/admin" class="logout">Logout</a>
          </nav>
        </div>
      </div>
    </header>

    <!-- ==========================================
    MAIN CONTENT with navbar padding
    ========================================== -->
    <main class="admin-main">
      <div class="admin-container py-6">
        <slot />
      </div>
    </main>
  </body>
</html>