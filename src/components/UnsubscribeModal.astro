---
// src/components/UnsubscribeModal.astro
import type { UNSUBSCRIBE_REASONS } from '@/types/newsletter';

export interface Props {
  email: string;
  isOpen: boolean;
  isLoading: boolean;
  reason?: string;
  feedback?: string;
  error?: string;
}

const { email, isOpen, isLoading, reason, feedback, error } = Astro.props;
---

{isOpen && (
  <div id="unsubscribe-modal" class="fixed inset-0 z-50 flex items-center justify-center px-4">
    <!-- Backdrop -->
    <div 
      id="modal-backdrop"
      class="fixed inset-0 bg-black/50 backdrop-blur-sm transition-opacity"
    ></div>

    <!-- Modal -->
    <div class="relative bg-white dark:bg-gray-800 rounded-2xl shadow-2xl max-w-md w-full p-6 animate-scale-in">
      <!-- Close button -->
      <button
        id="modal-close"
        class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
        aria-label="Close modal"
        type="button"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Header -->
      <div class="text-center mb-6">
        <div class="w-14 h-14 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-7 h-7 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">
          Unsubscribe from Trendlin?
        </h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
          We're sorry to see you go, {email}
        </p>
      </div>

      <!-- Error -->
      {error && (
        <div class="mb-4 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg text-red-600 dark:text-red-400 text-sm">
          {error}
        </div>
      )}

      <!-- Form -->
      <form id="unsubscribe-form" class="space-y-4">
        <!-- Reason -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Why are you unsubscribing?
          </label>
          <div class="space-y-2" id="reason-options">
            <!-- Reasons will be rendered by JavaScript -->
          </div>
        </div>

        <!-- Other reason input -->
        <div id="other-reason-container" class="hidden animate-slide-down">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            Please specify
          </label>
          <input
            id="other-reason"
            type="text"
            placeholder="Tell us why you're leaving..."
            class="w-full px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 focus:border-transparent outline-none transition-all"
          />
        </div>

        <!-- Feedback -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            Any additional feedback? <span class="text-gray-400 text-xs">(optional)</span>
          </label>
          <textarea
            id="feedback"
            rows="3"
            placeholder="We'd love to hear how we can improve..."
            class="w-full px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 focus:border-transparent outline-none transition-all resize-none"
          >{feedback}</textarea>
        </div>

        <!-- Actions -->
        <div class="flex gap-3 pt-2">
          <button
            id="modal-cancel"
            type="button"
            class="flex-1 px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors font-medium"
          >
            Cancel
          </button>
          <button
            id="modal-confirm"
            type="submit"
            disabled={isLoading}
            class="flex-1 px-4 py-2.5 bg-gradient-to-r from-red-600 to-red-700 text-white rounded-lg font-medium hover:shadow-lg hover:scale-[1.02] transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
          >
            {isLoading ? (
              <span class="flex items-center justify-center gap-2">
                <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" />
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
                </svg>
                Processing...
              </span>
            ) : (
              'Yes, Unsubscribe'
            )}
          </button>
        </div>
      </form>
    </div>
  </div>
)}

<!-- Styles -->
<style is:global>
  @keyframes scale-in {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  @keyframes slide-down {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-scale-in {
    animation: scale-in 0.2s ease-out;
  }
  .animate-slide-down {
    animation: slide-down 0.2s ease-out;
  }
</style>

<!-- JavaScript -->
<script>
  import { UNSUBSCRIBE_REASONS } from '@/types/newsletter';

  const reasons = UNSUBSCRIBE_REASONS;
  const reasonContainer = document.getElementById('reason-options');
  const otherReasonContainer = document.getElementById('other-reason-container');
  const otherReasonInput = document.getElementById('other-reason');
  const feedbackInput = document.getElementById('feedback');
  const form = document.getElementById('unsubscribe-form');
  const confirmBtn = document.getElementById('modal-confirm');
  const cancelBtn = document.getElementById('modal-cancel');
  const closeBtn = document.getElementById('modal-close');
  const backdrop = document.getElementById('modal-backdrop');

  let selectedReason = '';

  // Render reason options
  if (reasonContainer) {
    reasons.forEach((reason) => {
      const label = document.createElement('label');
      label.className = `flex items-center gap-3 p-3 rounded-lg border-2 cursor-pointer transition-all duration-200 ${
        reason.value === 'Other' ? '' : ''
      }`;
      label.dataset.value = reason.value;
      
      label.innerHTML = `
        <input
          type="radio"
          name="unsubscribeReason"
          value="${reason.value}"
          class="w-4 h-4 text-red-600 border-gray-300 focus:ring-red-500"
        />
        <span class="text-sm text-gray-700 dark:text-gray-300">${reason.label}</span>
      `;
      
      const radio = label.querySelector('input');
      radio?.addEventListener('change', (e) => {
        selectedReason = (e.target as HTMLInputElement).value;
        if (selectedReason === 'Other') {
          otherReasonContainer?.classList.remove('hidden');
        } else {
          otherReasonContainer?.classList.add('hidden');
        }
      });
      
      reasonContainer.appendChild(label);
    });
  }

  // Handle form submit
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (!selectedReason) {
      alert('Please select a reason for unsubscribing.');
      return;
    }

    let finalReason = selectedReason;
    if (selectedReason === 'Other' && otherReasonInput) {
      finalReason = otherReasonInput.value.trim() || 'Other';
    }

    const feedback = feedbackInput?.value || '';

    // Dispatch custom event for parent to handle
    const event = new CustomEvent('unsubscribe-confirm', {
      detail: { reason: finalReason, feedback }
    });
    document.dispatchEvent(event);
  });

  // Close modal functions
  const closeModal = () => {
    const event = new CustomEvent('unsubscribe-close');
    document.dispatchEvent(event);
  };

  cancelBtn?.addEventListener('click', closeModal);
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);
</script>