---
// AdminSources.astro - Sources management component
---

<div id="admin-sources">
  <div class="toolbar">
    <div class="filters">
      <select id="s-filter-type">
        <option value="all">All Types</option>
        <option value="master">Universal</option>
        <option value="state">State-Specific</option>
      </select>
      <select id="s-filter-category">
        <option value="">All Categories</option>
      </select>
      <select id="s-filter-state">
        <option value="">All States</option>
      </select>
      <input type="text" id="s-search" placeholder="Search sources..." />
    </div>
    <button class="btn-primary" id="s-add-btn">+ Add Source</button>
  </div>
  
  <div id="s-loading" class="loading-text">Loading...</div>
  
  <div id="s-table-wrap" style="display:none;">
    <table class="s-table">
      <thead>
        <tr>
          <th>Source</th>
          <th>Category</th>
          <th>State</th>
          <th>Type</th>
          <th>Trust</th>
          <th>Status</th>
          <th style="width:120px;">Actions</th>
        </tr>
      </thead>
      <tbody id="s-table-body"></tbody>
    </table>
  </div>
  
  <div id="s-empty" style="display:none;" class="empty-text">
    <p>No sources found</p>
    <small>Adjust filters or add a new source</small>
  </div>
</div>

<!-- Modal Dialog -->
<div id="s-modal" style="display:none;" class="modal-overlay">
  <div class="modal-box">
    <div class="modal-header">
      <h2 id="s-modal-title">Add Source</h2>
      <button class="close-btn" id="s-modal-close">×</button>
    </div>
    <form id="s-form">
      <div class="form-group">
        <label>Type</label>
        <select id="sf-type">
          <option value="state">State-Specific</option>
          <option value="master">Universal</option>
        </select>
      </div>
      <div class="form-group" id="sf-state-group">
        <label>State</label>
        <select id="sf-state"><option value="">Select a state</option></select>
      </div>
      <div class="form-group">
        <label>Name *</label>
        <input type="text" id="sf-name" required />
      </div>
      <div class="form-group">
        <label>URL *</label>
        <input type="url" id="sf-url" required />
      </div>
      <div class="form-group">
        <label>Category *</label>
        <select id="sf-category" required><option value="">Select a category</option></select>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea id="sf-desc" rows="2"></textarea>
      </div>
      <div class="form-group">
        <label>Logo URL</label>
        <input type="url" id="sf-logo" />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Active</label>
          <select id="sf-active">
            <option value="1">Yes</option>
            <option value="0">No</option>
          </select>
        </div>
        <div class="form-group">
          <label>Featured</label>
          <select id="sf-featured">
            <option value="1">Yes</option>
            <option value="0">No</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Trust Score: <span id="sf-trust-label">0%</span></label>
        <input type="range" id="sf-trust" min="0" max="100" value="0" />
      </div>
      <input type="hidden" id="sf-edit-id" />
      <div class="form-actions">
        <button type="button" class="btn-secondary" id="s-modal-cancel">Cancel</button>
        <button type="submit" class="btn-primary" id="s-modal-submit">Create</button>
      </div>
    </form>
  </div>
</div>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .filters {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    flex: 1;
  }
  .filters select,
  .filters input {
    padding: 0.5rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: white;
    font-size: 0.875rem;
    color: #1f2937;
  }
  .filters input {
    flex: 1;
    min-width: 200px;
  }
  .filters select:focus,
  .filters input:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
  }
  .s-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .s-table th {
    background: #f9fafb;
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #374151;
    border-bottom: 2px solid #e5e7eb;
  }
  .s-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e5e7eb;
    vertical-align: middle;
  }
  .s-table tr:hover {
    background: #f9fafb;
  }
  .source-cell {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .source-logo {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .source-name {
    font-weight: 500;
    color: #1f2937;
  }
  .source-url {
    display: block;
    font-size: 0.75rem;
    color: #6b7280;
    word-break: break-all;
  }
  .badge-cat {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: #f3f4f6;
    border-radius: 4px;
    font-size: 0.75rem;
    color: #374151;
  }
  .badge-state {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: #d1fae5;
    color: #065f46;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .badge-type {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
  }
  .badge-type.master {
    background: #dbeafe;
    color: #1e40af;
  }
  .badge-type.state {
    background: #d1fae5;
    color: #065f46;
  }
  .trust-wrap {
    width: 80px;
    height: 6px;
    background: #e5e7eb;
    border-radius: 3px;
    overflow: hidden;
  }
  .trust-bar {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, #10b981, #f59e0b, #ef4444);
  }
  .badge-status {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
  }
  .badge-status.active {
    background: #d1fae5;
    color: #065f46;
  }
  .badge-status.inactive {
    background: #fee2e2;
    color: #991b1b;
  }
  .badge-featured {
    display: inline-block;
    margin-left: 0.25rem;
    font-size: 0.75rem;
  }
  .actions-cell {
    display: flex;
    gap: 0.5rem;
  }
  .btn-sm {
    padding: 0.25rem 0.75rem;
    border: none;
    border-radius: 4px;
    font-size: 0.75rem;
    cursor: pointer;
    background: #f3f4f6;
    color: #374151;
    transition: background 0.2s;
  }
  .btn-sm:hover {
    background: #e5e7eb;
  }
  .btn-sm.danger {
    color: #dc2626;
  }
  .btn-sm.danger:hover {
    background: #fee2e2;
  }
  .btn-primary {
    padding: 0.5rem 1rem;
    background: #3b82f6;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
    transition: background 0.2s;
  }
  .btn-primary:hover {
    background: #2563eb;
  }
  .btn-secondary {
    padding: 0.5rem 1rem;
    background: #6b7280;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
    transition: background 0.2s;
  }
  .btn-secondary:hover {
    background: #4b5563;
  }
  .loading-text,
  .empty-text {
    text-align: center;
    padding: 3rem;
    color: #6b7280;
  }
  .empty-text p {
    font-size: 1.1rem;
    margin: 0;
  }
  .empty-text small {
    color: #9ca3af;
  }
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }
  .modal-box {
    background: white;
    border-radius: 12px;
    max-width: 600px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
    padding: 2rem;
  }
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .modal-header h2 {
    margin: 0;
    font-size: 1.25rem;
    color: #1f2937;
  }
  .close-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #6b7280;
    padding: 0;
    line-height: 1;
  }
  .close-btn:hover {
    color: #1f2937;
  }
  .form-group {
    margin-bottom: 1rem;
  }
  .form-group label {
    display: block;
    margin-bottom: 0.25rem;
    font-weight: 500;
    color: #374151;
    font-size: 0.875rem;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.875rem;
    box-sizing: border-box;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
  }
  .form-group textarea {
    resize: vertical;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
</style>

<script>
  (function() {
    var sources = [];
    var categories = [];
    var states = [];
    var editingId = null;
    
    function get(id) { return document.getElementById(id); }
    
    function init() {
      // Get DOM references
      var loadingEl = get('s-loading');
      var tableWrap = get('s-table-wrap');
      var emptyEl = get('s-empty');
      var tableBody = get('s-table-body');
      var modal = get('s-modal');
      
      var filterType = get('s-filter-type');
      var filterCategory = get('s-filter-category');
      var filterState = get('s-filter-state');
      var searchInput = get('s-search');
      
      var form = get('s-form');
      var fType = get('sf-type');
      var fState = get('sf-state');
      var fName = get('sf-name');
      var fUrl = get('sf-url');
      var fCategory = get('sf-category');
      var fDesc = get('sf-desc');
      var fLogo = get('sf-logo');
      var fSourceType = get('sf-source-type');
      var fActive = get('sf-active');
      var fFeatured = get('sf-featured');
      var fTrust = get('sf-trust');
      var fTrustLabel = get('sf-trust-label');
      var fEditId = get('sf-edit-id');
      var modalTitle = get('s-modal-title');
      var modalSubmit = get('s-modal-submit');
      
      function loadData() {
        loadingEl.style.display = 'block';
        tableWrap.style.display = 'none';
        emptyEl.style.display = 'none';
        
        Promise.all([loadSources(), loadCategories(), loadStates()])
          .then(function() {
            loadingEl.style.display = 'none';
            renderTable();
          })
          .catch(function(err) {
            console.error('Failed to load data:', err);
            alert('Failed to load data');
            loadingEl.style.display = 'none';
          });
      }
      
      function loadSources() {
        var params = new URLSearchParams();
        if (filterType.value && filterType.value !== 'all') params.append('type', filterType.value);
        if (filterCategory.value) params.append('category', filterCategory.value);
        if (filterState.value) params.append('state', filterState.value);
        if (searchInput.value) params.append('search', searchInput.value);
        
        return fetch('/api/admin/sources?' + params.toString())
          .then(function(r) { return r.json(); })
          .then(function(data) {
            sources = data.success ? (data.data || []) : [];
          })
          .catch(function(err) {
            console.error('Error loading sources:', err);
            sources = [];
          });
      }
      
      function loadCategories() {
        return fetch('/api/admin/sources/categories')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.success) {
              categories = data.data || [];
              populateSelects('category');
            }
          })
          .catch(function(err) {
            console.error('Error loading categories:', err);
          });
      }
      
      function loadStates() {
        return fetch('/api/admin/sources/states')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.success) {
              states = data.data || [];
              populateSelects('state');
            }
          })
          .catch(function(err) {
            console.error('Error loading states:', err);
          });
      }
      
      function populateSelects(type) {
        if (type === 'category') {
          [filterCategory, fCategory].forEach(function(sel) {
            var val = sel.value;
            sel.innerHTML = '<option value="">' + (sel === filterCategory ? 'All Categories' : 'Select a category') + '</option>';
            categories.forEach(function(c) {
              var opt = document.createElement('option');
              opt.value = c.id;
              opt.textContent = (c.icon || '📁') + ' ' + c.name;
              sel.appendChild(opt);
            });
            sel.value = val;
          });
        } else if (type === 'state') {
          [filterState, fState].forEach(function(sel) {
            var val = sel.value;
            sel.innerHTML = '<option value="">' + (sel === filterState ? 'All States' : 'Select a state') + '</option>';
            states.forEach(function(s) {
              var opt = document.createElement('option');
              opt.value = s.id;
              opt.textContent = (s.code || s.abbreviation) + ' - ' + s.name;
              sel.appendChild(opt);
            });
            sel.value = val;
          });
        }
      }
      
      function renderTable() {
        if (sources.length === 0) {
          tableWrap.style.display = 'none';
          emptyEl.style.display = 'block';
          return;
        }
        
        tableWrap.style.display = 'block';
        emptyEl.style.display = 'none';
        
        var html = '';
        for (var i = 0; i < sources.length; i++) {
          var s = sources[i];
          var trust = Math.min(s.trust_score || 0, 100);
          html += '<tr>';
          html += '<td><div class="source-cell">';
          if (s.logo_url) html += '<img src="' + escapeHtml(s.logo_url) + '" class="source-logo" />';
          html += '<div><div class="source-name">' + escapeHtml(s.name) + '</div>';
          html += '<span class="source-url">' + escapeHtml(s.url) + '</span></div></div></td>';
          html += '<td><span class="badge-cat">' + escapeHtml(s.category_name || 'Uncategorized') + '</span></td>';
          html += '<td>' + (s.state_code ? '<span class="badge-state">' + escapeHtml(s.state_code) + '</span>' : '<span style="color:#6b7280;font-size:0.75rem;">Universal</span>') + '</td>';
          html += '<td><span class="badge-type ' + (s.source_type_actual || 'state') + '">' + (s.source_type_actual === 'master' ? '🌐 Universal' : '📍 State') + '</span></td>';
          html += '<td><div class="trust-wrap"><div class="trust-bar" style="width:' + trust + '%"></div></div></td>';
          html += '<td><span class="badge-status ' + (s.is_active ? 'active' : 'inactive') + '">' + (s.is_active ? 'Active' : 'Inactive') + '</span>';
          if (s.is_featured) html += ' <span class="badge-featured">⭐</span>';
          html += '</td>';
          html += '<td><div class="actions-cell">';
          html += '<button class="btn-sm" data-id="' + s.id + '" onclick="window.editSource(' + s.id + ')">Edit</button>';
          html += '<button class="btn-sm danger" data-id="' + s.id + '" onclick="window.deleteSource(' + s.id + ')">Delete</button>';
          html += '</div></td>';
          html += '</tr>';
        }
        tableBody.innerHTML = html;
      }
      
      function escapeHtml(text) {
        if (!text) return '';
        var div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }
      
      window.editSource = function(id) {
        var source = null;
        for (var i = 0; i < sources.length; i++) {
          if (sources[i].id === id) { source = sources[i]; break; }
        }
        if (!source) return;
        
        editingId = id;
        modalTitle.textContent = 'Edit Source';
        modalSubmit.textContent = 'Update Source';
        
        fType.value = source.source_type_actual || 'state';
        fState.value = source.state_id || '';
        fName.value = source.name || '';
        fUrl.value = source.url || '';
        fCategory.value = source.category_id || '';
        fDesc.value = source.description || '';
        fLogo.value = source.logo_url || '';
        fActive.value = source.is_active !== undefined ? source.is_active : 1;
        fFeatured.value = source.is_featured !== undefined ? source.is_featured : 0;
        fTrust.value = source.trust_score || 0;
        fTrustLabel.textContent = (source.trust_score || 0) + '%';
        fEditId.value = id;
        
        toggleStateField();
        modal.style.display = 'flex';
      };
      
      window.deleteSource = function(id) {
        var name = '';
        for (var i = 0; i < sources.length; i++) {
          if (sources[i].id === id) { name = sources[i].name; break; }
        }
        if (!confirm('Delete "' + name + '"?')) return;
        
        fetch('/api/admin/sources/' + id, { method: 'DELETE' })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.success) {
              alert('Deleted successfully');
              loadSources().then(renderTable);
            } else {
              alert(data.error || 'Failed to delete');
            }
          })
          .catch(function(err) {
            console.error('Error deleting:', err);
            alert('Error deleting');
          });
      };
      
      function toggleStateField() {
        var group = get('sf-state-group');
        group.style.display = fType.value === 'master' ? 'none' : 'block';
      }
      
      function resetForm() {
        form.reset();
        editingId = null;
        fEditId.value = '';
        modalTitle.textContent = 'Add Source';
        modalSubmit.textContent = 'Create Source';
        fType.value = 'state';
        toggleStateField();
        fTrustLabel.textContent = '0%';
      }
      
      function handleSubmit(e) {
        e.preventDefault();
        
        var data = {
          name: fName.value,
          url: fUrl.value,
          category_id: parseInt(fCategory.value) || null,
          description: fDesc.value,
          source_type: fSourceType.value,
          logo_url: fLogo.value,
          is_active: parseInt(fActive.value),
          is_featured: parseInt(fFeatured.value),
          trust_score: parseInt(fTrust.value) || 0,
          source_type_actual: fType.value,
          state_id: parseInt(fState.value) || null
        };
        
        if (!data.name || !data.url || !data.category_id) {
          alert('Name, URL, and category are required');
          return;
        }
        if (data.source_type_actual === 'state' && !data.state_id) {
          alert('State is required for state-specific sources');
          return;
        }
        
        var url = editingId ? '/api/admin/sources/' + editingId : '/api/admin/sources';
        var method = editingId ? 'PUT' : 'POST';
        
        fetch(url, {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        })
          .then(function(r) { return r.json(); })
          .then(function(result) {
            if (result.success) {
              alert(editingId ? 'Updated!' : 'Created!');
              modal.style.display = 'none';
              resetForm();
              loadSources().then(renderTable);
            } else {
              alert(result.error || 'Failed to save');
            }
          })
          .catch(function(err) {
            console.error('Error saving:', err);
            alert('Error saving');
          });
      }
      
      // Event listeners
      filterType.addEventListener('change', function() { loadSources().then(renderTable); });
      filterCategory.addEventListener('change', function() { loadSources().then(renderTable); });
      filterState.addEventListener('change', function() { loadSources().then(renderTable); });
      
      var searchTimer;
      searchInput.addEventListener('input', function() {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(function() { loadSources().then(renderTable); }, 300);
      });
      
      get('s-add-btn').addEventListener('click', function() {
        resetForm();
        modal.style.display = 'flex';
      });
      
      get('s-modal-close').addEventListener('click', function() {
        modal.style.display = 'none';
        resetForm();
      });
      
      get('s-modal-cancel').addEventListener('click', function() {
        modal.style.display = 'none';
        resetForm();
      });
      
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          modal.style.display = 'none';
          resetForm();
        }
      });
      
      fTrust.addEventListener('input', function() {
        fTrustLabel.textContent = this.value + '%';
      });
      
      fType.addEventListener('change', toggleStateField);
      form.addEventListener('submit', handleSubmit);
      
      // Start
      loadData();
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>