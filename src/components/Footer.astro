---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-white dark:bg-gray-900 border-t border-gray-200/50 dark:border-gray-800/50">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
    
    <!-- Main Footer -->
    <div class="py-14 sm:py-18">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- Brand Column -->
        <div class="lg:col-span-3">
          <a href="/" class="flex items-center gap-2.5 mb-5 group">
            <div class="w-9 h-9 lg:w-10 lg:h-10 bg-gradient-to-br from-blue-600 to-purple-600 rounded-xl flex items-center justify-center text-white font-bold text-base shadow-lg shadow-blue-500/25 group-hover:shadow-blue-500/40 transition-all duration-300 group-hover:scale-105">
              T
            </div>
            <span class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Trendlin</span>
          </a>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed max-w-sm">
            Your trusted source for honest product reviews, buying guides, and local insights — made for Los Angeles.
          </p>
          
          <!-- Social Links -->
          <div class="flex gap-3 mt-6">
            <a href="https://www.facebook.com/trendlinsocial/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 flex items-center justify-center hover:bg-[#1877f2] hover:text-white dark:hover:bg-[#1877f2] transition-all duration-300 hover:scale-110 hover:shadow-lg" aria-label="Follow us on Facebook">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://www.instagram.com/trendlinsocial/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 flex items-center justify-center hover:bg-[#e4405f] hover:text-white dark:hover:bg-[#e4405f] transition-all duration-300 hover:scale-110 hover:shadow-lg" aria-label="Follow us on Instagram">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="https://x.com/trendlinco" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 flex items-center justify-center hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all duration-300 hover:scale-110 hover:shadow-lg" aria-label="Follow us on X">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          </div>
        </div>

        <!-- Explore Links -->
        <div class="lg:col-span-2">
          <h3 class="text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-[0.15em] mb-4 flex items-center gap-2.5">
            <span class="w-6 h-[2px] bg-gray-400 dark:bg-gray-500 rounded-full"></span> Explore
          </h3>
          <ul class="space-y-2.5">
            <li><a href="/" class="text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300 hover:pl-2 block">Home</a></li>
            <li><a href="/categories" class="text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300 hover:pl-2 block">Categories</a></li>
            <li><a href="/about" class="text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300 hover:pl-2 block">About</a></li>
            <li><a href="/contact" class="text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300 hover:pl-2 block">Contact</a></li>
          </ul>
        </div>

        <!-- Company Links -->
        <div class="lg:col-span-2">
          <h3 class="text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-[0.15em] mb-4 flex items-center gap-2.5">
            <span class="w-6 h-[2px] bg-gray-400 dark:bg-gray-500 rounded-full"></span> Company
          </h3>
          <ul class="space-y-2.5">
            <li><a href="/privacy" class="text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300 hover:pl-2 block">Privacy Policy</a></li>
            <li><a href="/terms" class="text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300 hover:pl-2 block">Terms of Service</a></li>
            <li><a href="/cookies" class="text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300 hover:pl-2 block">Cookie Policy</a></li>
            <li><a href="/disclosure" class="text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300 hover:pl-2 block">Affiliate Disclosure</a></li>
          </ul>
        </div>

        <!-- ==========================================
        NEWSLETTER SUBSCRIPTION WITH PREFERENCES
        ========================================== -->
        <div class="lg:col-span-5">
          <div class="relative p-6 rounded-xl bg-gradient-to-br from-blue-50/50 to-purple-50/50 dark:from-blue-900/20 dark:to-purple-900/20 border border-blue-200/50 dark:border-blue-800/30">
            
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-purple-600 flex items-center justify-center text-white shadow-lg shadow-blue-500/25">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Subscribe to Newsletter</h3>
                <p class="text-xs text-gray-500 dark:text-gray-400">Never miss the trend or fresh content</p>
              </div>
            </div>

            <form id="footer-subscribe-form" class="space-y-3">
              <div class="flex flex-col sm:flex-row gap-2">
                <input
                  type="email"
                  id="footer-subscribe-email"
                  placeholder="Enter your email"
                  required
                  class="flex-1 px-4 py-2.5 text-sm rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all"
                />
                <button
                  type="button"
                  id="open-preferences-modal"
                  class="px-6 py-2.5 text-sm font-medium text-white bg-gradient-to-r from-blue-600 to-purple-600 rounded-lg hover:shadow-lg hover:scale-[1.02] transition-all duration-300 whitespace-nowrap"
                >
                  Subscribe
                </button>
              </div>

              <div id="footer-subscribe-message" class="text-xs hidden"></div>
              <p class="text-[10px] text-gray-400 dark:text-gray-500">No spam. Unsubscribe anytime.</p>
            </form>
          </div>
        </div>

      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="py-6 border-t border-gray-200/50 dark:border-gray-800/50 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">© {currentYear} <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200 font-medium">Trendlin</a>. All rights reserved.</p>
      <div class="flex items-center gap-6 text-sm text-gray-500 dark:text-gray-400">
        <a href="/privacy" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200">Privacy</a>
        <a href="/terms" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200">Terms</a>
        <a href="/cookies" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200">Cookies</a>
      </div>
    </div>
  </div>
</footer>

<!-- ==========================================
PREFERENCES MODAL
========================================== -->
<div id="preferences-modal" class="fixed inset-0 z-50 hidden items-center justify-center px-4">
  <div id="preferences-backdrop" class="fixed inset-0 bg-black/50 backdrop-blur-sm"></div>
  
  <div class="relative bg-white dark:bg-gray-800 rounded-2xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto p-6 animate-scale-in">
    <button
      id="preferences-close"
      class="absolute top-4 right-4 p-2 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
      type="button"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="text-center mb-6">
      <div class="w-16 h-16 bg-gradient-to-br from-blue-600 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">Choose Your Interests</h2>
      <p id="preferences-email" class="text-sm text-gray-600 dark:text-gray-400 mt-1"></p>
      <p class="text-xs text-gray-500 dark:text-gray-500 mt-1">
        <span id="selected-count">0</span> categories selected
      </p>
    </div>

    <!-- Status Display -->
    <div id="preferences-status" class="hidden mb-4 p-3 rounded-lg text-sm">
      <span id="preferences-status-text"></span>
    </div>

    <div id="preferences-error" class="hidden mb-4 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg text-red-600 dark:text-red-400 text-sm">
      Please select at least one category.
    </div>

    <div class="space-y-3 mb-6">
      <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Select All Categories</span>
        <button
          id="select-all-preferences"
          type="button"
          class="px-4 py-1.5 text-sm font-medium text-blue-600 dark:text-blue-400 border border-blue-600 dark:border-blue-400 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-all"
        >
          Select All
        </button>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <!-- Category options with SVG icons -->
        <label class="flex items-center gap-3 p-3 rounded-lg border-2 border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 cursor-pointer transition-all">
          <input type="checkbox" name="pref-category" value="health-wellness" class="w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" />
          <svg class="w-5 h-5 text-blue-500 dark:text-blue-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
          <span class="text-sm text-gray-700 dark:text-gray-300">Health & Wellness</span>
        </label>

        <label class="flex items-center gap-3 p-3 rounded-lg border-2 border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 cursor-pointer transition-all">
          <input type="checkbox" name="pref-category" value="food-dining" class="w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" />
          <svg class="w-5 h-5 text-orange-500 dark:text-orange-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4m18-8v3a2 2 0 01-2 2H7a2 2 0 01-2-2V7m18-3a2 2 0 00-2-2H5a2 2 0 00-2 2v3m18 0V7" />
          </svg>
          <span class="text-sm text-gray-700 dark:text-gray-300">Food & Dining</span>
        </label>

        <label class="flex items-center gap-3 p-3 rounded-lg border-2 border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 cursor-pointer transition-all">
          <input type="checkbox" name="pref-category" value="technology" class="w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" />
          <svg class="w-5 h-5 text-purple-500 dark:text-purple-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-sm text-gray-700 dark:text-gray-300">Technology</span>
        </label>

        <label class="flex items-center gap-3 p-3 rounded-lg border-2 border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 cursor-pointer transition-all">
          <input type="checkbox" name="pref-category" value="shopping" class="w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" />
          <svg class="w-5 h-5 text-pink-500 dark:text-pink-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <span class="text-sm text-gray-700 dark:text-gray-300">Shopping</span>
        </label>

        <label class="flex items-center gap-3 p-3 rounded-lg border-2 border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 cursor-pointer transition-all">
          <input type="checkbox" name="pref-category" value="entertainment" class="w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" />
          <svg class="w-5 h-5 text-red-500 dark:text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-sm text-gray-700 dark:text-gray-300">Entertainment</span>
        </label>

        <label class="flex items-center gap-3 p-3 rounded-lg border-2 border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 cursor-pointer transition-all">
          <input type="checkbox" name="pref-category" value="lifestyle" class="w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" />
          <svg class="w-5 h-5 text-yellow-500 dark:text-yellow-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
          <span class="text-sm text-gray-700 dark:text-gray-300">Lifestyle</span>
        </label>

        <label class="flex items-center gap-3 p-3 rounded-lg border-2 border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 cursor-pointer transition-all">
          <input type="checkbox" name="pref-category" value="real-estate" class="w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" />
          <svg class="w-5 h-5 text-green-500 dark:text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z" />
          </svg>
          <span class="text-sm text-gray-700 dark:text-gray-300">Real Estate</span>
        </label>

        <label class="flex items-center gap-3 p-3 rounded-lg border-2 border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 cursor-pointer transition-all">
          <input type="checkbox" name="pref-category" value="finance" class="w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" />
          <svg class="w-5 h-5 text-emerald-500 dark:text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-sm text-gray-700 dark:text-gray-300">Finance</span>
        </label>
      </div>
    </div>

    <!-- Resend Button (shown when pending) -->
    <div id="resend-container" class="hidden mb-4">
      <button
        id="resend-verification-btn"
        class="w-full px-4 py-2.5 text-sm font-medium text-blue-600 dark:text-blue-400 border border-blue-600 dark:border-blue-400 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-all duration-300"
      >
        🔄 Resend Verification Email
      </button>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 text-center">Didn't receive the email? Click to resend.</p>
    </div>

    <div class="flex gap-3 pt-2 border-t border-gray-200 dark:border-gray-700">
      <button
        id="preferences-cancel"
        type="button"
        class="flex-1 px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors font-medium"
      >
        Cancel
      </button>
      <button
        id="preferences-confirm"
        type="button"
        class="flex-1 px-4 py-2.5 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-lg font-medium hover:shadow-lg hover:scale-[1.02] transition-all duration-300"
      >
        Subscribe
      </button>
    </div>
  </div>
</div>

<!-- ==========================================
JAVASCRIPT
========================================== -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('preferences-modal');
    const openModalBtn = document.getElementById('open-preferences-modal');
    const closeModalBtn = document.getElementById('preferences-close');
    const cancelBtn = document.getElementById('preferences-cancel');
    const backdrop = document.getElementById('preferences-backdrop');
    const confirmBtn = document.getElementById('preferences-confirm');
    const emailInput = document.getElementById('footer-subscribe-email');
    const messageEl = document.getElementById('footer-subscribe-message');
    const modalError = document.getElementById('preferences-error');
    const selectedCount = document.getElementById('selected-count');
    const preferencesEmail = document.getElementById('preferences-email');
    const selectAllBtn = document.getElementById('select-all-preferences');
    const checkboxes = document.querySelectorAll('input[name="pref-category"]');
    const resendContainer = document.getElementById('resend-container');
    const resendBtn = document.getElementById('resend-verification-btn');
    const statusDisplay = document.getElementById('preferences-status');
    const statusText = document.getElementById('preferences-status-text');

    let currentEmail = '';
    let selectedCategories = [];
    let currentStatus = '';

    function updateSelectedCount() {
      const checked = document.querySelectorAll('input[name="pref-category"]:checked');
      selectedCategories = Array.from(checked).map(cb => cb.value);
      selectedCount.textContent = selectedCategories.length;
      
      checkboxes.forEach(cb => {
        const label = cb.closest('label');
        if (cb.checked) {
          label?.classList.add('border-blue-500', 'bg-blue-50', 'dark:bg-blue-900/20');
          label?.classList.remove('border-gray-200', 'dark:border-gray-700');
        } else {
          label?.classList.remove('border-blue-500', 'bg-blue-50', 'dark:bg-blue-900/20');
          label?.classList.add('border-gray-200', 'dark:border-gray-700');
        }
      });
    }

    function showMessage(msg, type) {
      messageEl.textContent = msg;
      messageEl.className = `text-xs mt-1 ${type === 'success' ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400'}`;
      messageEl.classList.remove('hidden');
      if (msg && type === 'success') {
        setTimeout(() => { messageEl.classList.add('hidden'); }, 8000);
      }
    }

    function showStatus(message, type) {
      statusDisplay.classList.remove('hidden');
      statusDisplay.className = `mb-4 p-3 rounded-lg text-sm ${type === 'success' ? 'bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-400' : 'bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 text-yellow-700 dark:text-yellow-400'}`;
      statusText.textContent = message;
    }

    function hideStatus() {
      statusDisplay.classList.add('hidden');
    }

    // Open modal
    openModalBtn?.addEventListener('click', async () => {
      const email = emailInput.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showMessage('Please enter a valid email address first.', 'error');
        return;
      }

      currentEmail = email;
      hideStatus();
      resendContainer.classList.add('hidden');

      // Check status
      try {
        const checkRes = await fetch(`/api/newsletter/check?email=${encodeURIComponent(email)}`);
        const checkData = await checkRes.json();

        if (checkData.success) {
          currentStatus = checkData.status;
          
          if (checkData.status === 'active') {
            showStatus('✅ You are already subscribed to our newsletter!', 'success');
            // Pre-fill categories if subscribed
            const subRes = await fetch(`/api/newsletter/get-subscriber?email=${encodeURIComponent(email)}`);
            const subData = await subRes.json();
            if (subData.success && subData.data.categories.length > 0) {
              const preSelected = subData.data.categories;
              checkboxes.forEach(cb => {
                cb.checked = preSelected.includes(cb.value);
              });
              updateSelectedCount();
            }
            confirmBtn.textContent = 'Update Preferences';
            resendContainer.classList.add('hidden');
            preferencesEmail.textContent = `Managing: ${email}`;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
            return;
          }
          
          if (checkData.status === 'pending') {
            showStatus('⏳ Pending verification. Check your inbox or resend the email.', 'warning');
            resendContainer.classList.remove('hidden');
            confirmBtn.textContent = 'Resubscribe';
            preferencesEmail.textContent = `Email: ${email}`;
          }
          
          if (checkData.status === 'unsubscribed') {
            showStatus('You were previously unsubscribed. Subscribe again to receive our newsletter.', 'warning');
            resendContainer.classList.add('hidden');
            confirmBtn.textContent = 'Subscribe';
            preferencesEmail.textContent = `Email: ${email}`;
          }
        }
      } catch (error) {
        console.error('Check error:', error);
      }

      if (currentStatus !== 'active') {
        preferencesEmail.textContent = `Email: ${email}`;
        modalError.classList.add('hidden');
        checkboxes.forEach(cb => cb.checked = false);
        updateSelectedCount();
        confirmBtn.textContent = 'Subscribe';
        resendContainer.classList.add('hidden');
      }
      
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    });

    // Close modal
    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
      hideStatus();
    }

    closeModalBtn?.addEventListener('click', closeModal);
    cancelBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);

    // Select All
    selectAllBtn?.addEventListener('click', () => {
      const allChecked = checkboxes.length === document.querySelectorAll('input[name="pref-category"]:checked').length;
      checkboxes.forEach(cb => cb.checked = !allChecked);
      updateSelectedCount();
      selectAllBtn.textContent = allChecked ? 'Select All' : 'Deselect All';
    });

    checkboxes.forEach(cb => {
      cb.addEventListener('change', updateSelectedCount);
    });

    // Resend Verification
    resendBtn?.addEventListener('click', async () => {
      resendBtn.disabled = true;
      resendBtn.textContent = 'Sending...';
      
      try {
        const response = await fetch('/api/newsletter/resend-verification', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: currentEmail }),
        });
        const data = await response.json();
        if (data.success) {
          showStatus('📧 Verification email resent! Please check your inbox.', 'success');
          showMessage('📧 Verification email sent!', 'success');
        } else {
          showStatus('❌ ' + (data.message || 'Failed to resend verification.'), 'error');
        }
      } catch (error) {
        showStatus('❌ Network error. Please try again.', 'error');
      } finally {
        resendBtn.disabled = false;
        resendBtn.textContent = '🔄 Resend Verification Email';
      }
    });

    // Confirm subscription
    confirmBtn?.addEventListener('click', async () => {
      const checked = document.querySelectorAll('input[name="pref-category"]:checked');
      const categories = Array.from(checked).map(cb => cb.value);

      if (categories.length === 0) {
        modalError.classList.remove('hidden');
        return;
      }

      modalError.classList.add('hidden');
      confirmBtn.disabled = true;
      const originalText = confirmBtn.textContent;
      confirmBtn.textContent = 'Processing...';

      try {
        let endpoint = '/api/newsletter/subscribe';
        let body = { email: currentEmail, firstName: '', categories };

        // If already subscribed, use save-preferences endpoint
        if (currentStatus === 'active') {
          // Get token first
          const subRes = await fetch(`/api/newsletter/get-subscriber?email=${encodeURIComponent(currentEmail)}`);
          const subData = await subRes.json();
          if (subData.success && subData.data.token) {
            endpoint = '/api/newsletter/save-preferences';
            body = { email: currentEmail, token: subData.data.token, categories };
          }
        }

        const response = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        const data = await response.json();

        if (data.success) {
          if (currentStatus === 'active') {
            showMessage('✅ Preferences updated successfully!', 'success');
            showStatus('✅ Preferences updated successfully!', 'success');
          } else {
            showMessage('📧 Please check your email to verify your subscription!', 'success');
            showStatus('📧 Verification email sent! Please check your inbox.', 'success');
            resendContainer.classList.remove('hidden');
          }
          emailInput.value = '';
          setTimeout(() => {
            closeModal();
          }, 3000);
        } else {
          showMessage(data.message || 'Something went wrong. Please try again.', 'error');
          modalError.textContent = data.message || 'Something went wrong. Please try again.';
          modalError.classList.remove('hidden');
        }
      } catch (error) {
        console.error('Subscription error:', error);
        showMessage('Network error. Please try again.', 'error');
        modalError.textContent = 'Network error. Please try again.';
        modalError.classList.remove('hidden');
      } finally {
        confirmBtn.disabled = false;
        confirmBtn.textContent = originalText;
      }
    });

    updateSelectedCount();
  });
</script>

<style is:global>
  @keyframes scale-in {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .animate-scale-in { animation: scale-in 0.25s ease-out; }
  .animate-spin { animation: spin 1s linear infinite; }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>