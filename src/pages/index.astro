---
// ============================================
// HOMEPAGE - Trendlin
// ============================================

import BaseLayout from '../layouts/BaseLayout.astro';

let posts = [];
try {
  const { DB } = Astro.locals.runtime.env;
  const result = await DB.prepare(`
    SELECT * FROM posts WHERE is_draft = 0 ORDER BY created_at DESC LIMIT 6
  `).all();
  posts = result.results || [];
} catch (error) {
  console.error('Error fetching posts:', error);
}
---

<BaseLayout title="Trendlin - Los Angeles' Trusted Source">
  
  <!-- Location Banner -->
  <div class="bg-gradient-to-r from-blue-600 to-purple-600 text-white py-2 px-4 text-center text-sm">
    📍 Serving Los Angeles, California — Your Trusted Local Source
  </div>

  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-center overflow-hidden bg-black">
    <div class="absolute inset-0">
      <img 
        src="https://pub-bf1013d046c946448ed23cbf79e38b92.r2.dev/Webstructmedia/webo.jpg" 
        alt="Los Angeles" 
        class="w-full h-full object-cover opacity-60"
      />
    </div>
    <div class="relative z-10 container text-white text-center py-16">
      <h1 class="text-4xl md:text-6xl font-bold mb-4">
        Discover What's <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">Trending in LA</span>
      </h1>
      <p class="text-xl max-w-2xl mx-auto mb-8">
        Your trusted source for honest product reviews, buying guides, and local insights — made for Los Angeles.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/blog" class="px-6 py-3 bg-blue-600 rounded-lg hover:bg-blue-700">Read the Blog</a>
        <a href="/categories" class="px-6 py-3 bg-white/10 backdrop-blur rounded-lg border border-white/20 hover:bg-white/20">Explore Categories</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-4">Your Trusted Guide for <span class="text-blue-600">Everyday Life</span> in LA</h2>
          <p class="text-gray-600 mb-4">Trendlin is your go-to resource for discovering what matters most in your daily life.</p>
          <ul class="space-y-2">
            <li class="flex items-center gap-2">✅ Honest product reviews</li>
            <li class="flex items-center gap-2">✅ Save money while shopping</li>
            <li class="flex items-center gap-2">✅ No fluff, just facts</li>
          </ul>
        </div>
        <div>
          <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800&q=80" alt="LA lifestyle" class="rounded-xl shadow-lg" />
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16">
    <div class="container">
      <h2 class="text-3xl font-bold text-center mb-4">What Matters to Los Angeles</h2>
      <p class="text-center text-gray-600 mb-12">Honest content, local insights, and actionable recommendations</p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-6 bg-white rounded-xl border hover:shadow-lg transition">
          <div class="text-3xl mb-3">📝</div>
          <h3 class="text-xl font-bold mb-2">Local Product Reviews</h3>
          <p class="text-gray-600">Honest, in-depth reviews of products available in LA stores and online.</p>
        </div>
        <div class="p-6 bg-white rounded-xl border hover:shadow-lg transition">
          <div class="text-3xl mb-3">🌴</div>
          <h3 class="text-xl font-bold mb-2">LA Lifestyle & Culture</h3>
          <p class="text-gray-600">Insightful articles on Los Angeles lifestyle, events, and what's trending.</p>
        </div>
        <div class="p-6 bg-white rounded-xl border hover:shadow-lg transition">
          <div class="text-3xl mb-3">💰</div>
          <h3 class="text-xl font-bold mb-2">Local Affiliate Deals</h3>
          <p class="text-gray-600">Find the best deals on products and services in the Los Angeles area.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="flex justify-between items-center mb-8">
        <h2 class="text-3xl font-bold">Latest in LA</h2>
        <a href="/search" class="text-blue-600 hover:underline">View All →</a>
      </div>
      
      {posts.length > 0 ? (
        <div class="grid md:grid-cols-3 gap-6">
          {posts.map((post) => (
            <div class="bg-white rounded-xl border overflow-hidden hover:shadow-lg transition">
              <div class="p-6">
                <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-1 rounded-full">{post.category}</span>
                <h3 class="text-xl font-bold mt-2 mb-2">
                  <a href={`/posts/${post.slug}`} class="hover:text-blue-600">{post.title}</a>
                </h3>
                <p class="text-gray-600 text-sm">{post.excerpt || 'Read more...'}</p>
                <a href={`/posts/${post.slug}`} class="inline-block mt-3 text-blue-600 font-medium">Read More →</a>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-center text-gray-500 py-12">No posts yet. <a href="/admin/new" class="text-blue-600 hover:underline">Create your first post →</a></p>
      )}
    </div>
  </section>

</BaseLayout>