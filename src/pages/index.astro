---
// ============================================
// SECTION: Imports & Configuration
// ============================================

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

let posts = [];
try {
  const response = await fetch(`${Astro.url.origin}/api/posts?published=true`);
  if (response.ok) {
    posts = await response.json();
  }
} catch (error) {
  console.error('Error fetching posts:', error);
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- ============================================
    SECTION: Head / Meta Tags
    ============================================ -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trendlin - Los Angeles' Trusted Source</title>
    <meta name="description" content="Your trusted source for the latest trends, product reviews, and local insights in Los Angeles, California." />
    
    <!-- ============================================
    SECTION: Google Fonts
    ============================================ -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,600&display=swap" rel="stylesheet" />
    
    <!-- ============================================
    SECTION: All CSS Styles
    ============================================ -->
    <style>
      /* ==========================================
         SUBSECTION: Reset & Base Styles
         ========================================== */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #ffffff;
        color: #0f172a;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        padding-top: 64px;
      }
      
      @media (min-width: 768px) {
        body {
          padding-top: 80px;
        }
      }
      
      a {
        text-decoration: none;
        color: inherit;
      }
      
      img {
        max-width: 100%;
        display: block;
      }
      
      /* ==========================================
         SUBSECTION: Container
         ========================================== */
      .container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 1rem;
      }
      
      @media (min-width: 640px) {
        .container {
          padding: 0 1.5rem;
        }
      }
      
      @media (min-width: 1024px) {
        .container {
          padding: 0 2rem;
        }
      }
      
      /* ==========================================
         SUBSECTION: Location Banner
         ========================================== */
      .location-banner {
        background: linear-gradient(to right, #1e40af, #7c3aed);
        color: white;
        padding: 0.6rem 1rem;
        text-align: center;
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.02em;
      }
      
      .location-banner span {
        opacity: 0.9;
      }
      
      /* ==========================================
         SUBSECTION: Compact Hero
         ========================================== */
      .hero-compact {
        position: relative;
        min-height: 40vh;
        display: flex;
        align-items: center;
        overflow: hidden;
        background: #0a0a0a;
      }
      
      @media (min-width: 640px) {
        .hero-compact {
          min-height: 45vh;
        }
      }
      
      @media (min-width: 1024px) {
        .hero-compact {
          min-height: 50vh;
        }
      }
      
      .hero-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
      }
      
      .hero-bg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      }
      
      .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.7), rgba(0,0,0,0.4), rgba(0,0,0,0.7));
      }
      
      .hero-overlay-2 {
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, rgba(0,0,0,0.3), transparent, rgba(0,0,0,0.3));
      }
      
      .hero-content-compact {
        position: relative;
        width: 100%;
        z-index: 10;
        padding: 2rem 1rem;
      }
      
      @media (min-width: 640px) {
        .hero-content-compact {
          padding: 2.5rem 1.5rem;
        }
      }
      
      .hero-inner-compact {
        max-width: 800px;
        margin: 0 auto;
        text-align: center;
      }
      
      /* ---- Hero Badge ---- */
      .badge-compact {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(4px);
        color: rgba(255,255,255,0.9);
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        border: 1px solid rgba(255,255,255,0.1);
      }
      
      @media (min-width: 640px) {
        .badge-compact {
          padding: 0.375rem 1rem;
          font-size: 0.8rem;
        }
      }
      
      .badge-dot {
        position: relative;
        display: flex;
        height: 0.5rem;
        width: 0.5rem;
      }
      
      .badge-dot-ping {
        position: absolute;
        display: inline-flex;
        height: 100%;
        width: 100%;
        border-radius: 50%;
        background: rgba(96, 165, 250, 0.75);
        animation: ping 1s cubic-bezier(0, 0, 0.2, 1) infinite;
      }
      
      .badge-dot-static {
        position: relative;
        display: inline-flex;
        border-radius: 50%;
        height: 0.5rem;
        width: 0.5rem;
        background: #3b82f6;
      }
      
      @keyframes ping {
        75%, 100% {
          transform: scale(2);
          opacity: 0;
        }
      }
      
      /* ---- Hero Heading ---- */
      .hero-title-compact {
        font-size: 1.75rem;
        font-weight: 800;
        color: #ffffff;
        line-height: 1.15;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
      }
      
      @media (min-width: 480px) {
        .hero-title-compact {
          font-size: 2rem;
        }
      }
      
      @media (min-width: 640px) {
        .hero-title-compact {
          font-size: 2.5rem;
        }
      }
      
      @media (min-width: 768px) {
        .hero-title-compact {
          font-size: 3rem;
        }
      }
      
      .hero-title-block {
        display: block;
      }
      
      @media (min-width: 640px) {
        .hero-title-block {
          display: inline;
        }
      }
      
      .hero-title-gradient {
        display: block;
        background: linear-gradient(to right, #60a5fa, #a78bfa, #f472b6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      
      @media (min-width: 640px) {
        .hero-title-gradient {
          display: inline;
        }
      }
      
      /* ---- Hero Subtitle ---- */
      .hero-subtitle-compact {
        font-size: 0.85rem;
        color: rgba(255,255,255,0.9);
        max-width: 600px;
        margin: 0 auto 1rem;
        padding: 0 1rem;
        line-height: 1.6;
        font-weight: 400;
        letter-spacing: 0.01em;
      }
      
      @media (min-width: 640px) {
        .hero-subtitle-compact {
          font-size: 1rem;
        }
      }
      
      @media (min-width: 768px) {
        .hero-subtitle-compact {
          font-size: 1.1rem;
        }
      }
      
      /* ---- Hero CTA Buttons ---- */
      .cta-group-compact {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        justify-content: center;
        align-items: center;
        padding: 0 1rem;
      }
      
      @media (min-width: 480px) {
        .cta-group-compact {
          flex-direction: row;
        }
      }
      
      .btn-primary-compact {
        width: 100%;
        background: #2563eb;
        color: #ffffff;
        padding: 0.5rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.8rem;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        border: none;
        cursor: pointer;
        letter-spacing: 0.02em;
      }
      
      @media (min-width: 480px) {
        .btn-primary-compact {
          width: auto;
        }
      }
      
      @media (min-width: 640px) {
        .btn-primary-compact {
          padding: 0.6rem 1.5rem;
          font-size: 0.9rem;
        }
      }
      
      .btn-primary-compact:hover {
        background: #1d4ed8;
        transform: scale(1.03);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
      }
      
      .btn-secondary-compact {
        width: 100%;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(4px);
        color: #ffffff;
        padding: 0.5rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.8rem;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        border: 1px solid rgba(255,255,255,0.2);
        cursor: pointer;
        letter-spacing: 0.02em;
      }
      
      @media (min-width: 480px) {
        .btn-secondary-compact {
          width: auto;
        }
      }
      
      @media (min-width: 640px) {
        .btn-secondary-compact {
          padding: 0.6rem 1.5rem;
          font-size: 0.9rem;
        }
      }
      
      .btn-secondary-compact:hover {
        background: rgba(255,255,255,0.2);
        transform: scale(1.03);
      }
      
      .btn-icon {
        width: 0.9rem;
        height: 0.9rem;
        transition: transform 0.3s ease;
      }
      
      .btn-primary-compact:hover .btn-icon {
        transform: translateX(4px);
      }
      
      /* ---- Hero Stats ---- */
      .stats-compact {
        margin-top: 1.25rem;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.5rem;
        max-width: 300px;
        margin-left: auto;
        margin-right: auto;
      }
      
      @media (min-width: 640px) {
        .stats-compact {
          margin-top: 1.5rem;
          gap: 0.75rem;
          max-width: 350px;
        }
      }
      
      .stat-item-compact {
        text-align: center;
        padding: 0.35rem 0.5rem;
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(4px);
        border-radius: 0.5rem;
        border: 1px solid rgba(255,255,255,0.1);
      }
      
      @media (min-width: 640px) {
        .stat-item-compact {
          padding: 0.5rem 0.75rem;
        }
      }
      
      .stat-number-compact {
        font-size: 1rem;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.02em;
      }
      
      @media (min-width: 640px) {
        .stat-number-compact {
          font-size: 1.25rem;
        }
      }
      
      .stat-label-compact {
        font-size: 0.6rem;
        color: #d1d5db;
        font-weight: 400;
        letter-spacing: 0.03em;
      }
      
      @media (min-width: 640px) {
        .stat-label-compact {
          font-size: 0.7rem;
        }
      }
      
      /* ==========================================
         SUBSECTION: About Section
         ========================================== */
      .about-section {
        padding: 3rem 0;
        background: #f8fafc;
      }
      
      @media (min-width: 640px) {
        .about-section {
          padding: 4rem 0;
        }
      }
      
      .about-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        align-items: center;
      }
      
      @media (min-width: 768px) {
        .about-grid {
          grid-template-columns: 1fr 1fr;
          gap: 3rem;
        }
      }
      
      .about-content h2 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 1rem;
        letter-spacing: -0.02em;
      }
      
      @media (min-width: 640px) {
        .about-content h2 {
          font-size: 2rem;
        }
      }
      
      .about-content p {
        color: #475569;
        line-height: 1.7;
        margin-bottom: 1rem;
        font-weight: 400;
        font-size: 0.95rem;
      }
      
      .about-highlights {
        list-style: none;
        padding: 0;
        margin-top: 1.5rem;
      }
      
      .about-highlights li {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0;
        color: #334155;
        font-weight: 500;
        font-size: 0.9rem;
        border-bottom: 1px solid #e2e8f0;
      }
      
      .about-highlights li:last-child {
        border-bottom: none;
      }
      
      .about-highlights li svg {
        flex-shrink: 0;
        color: #2563eb;
      }
      
      .about-image {
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
      }
      
      .about-image img {
        width: 100%;
        height: 300px;
        object-fit: cover;
      }
      
      @media (min-width: 768px) {
        .about-image img {
          height: 400px;
        }
      }
      
      /* ==========================================
         SUBSECTION: Section Titles (Reusable)
         ========================================== */
      .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0f172a;
        letter-spacing: -0.02em;
      }
      
      @media (min-width: 640px) {
        .section-title {
          font-size: 1.875rem;
        }
      }
      
      @media (min-width: 768px) {
        .section-title {
          font-size: 2.25rem;
        }
      }
      
      .section-subtitle {
        color: #64748b;
        margin-top: 0.5rem;
        font-weight: 400;
        letter-spacing: 0.01em;
      }
      
      /* ==========================================
         SUBSECTION: Features Cards
         ========================================== */
      .features {
        padding: 3rem 0;
      }
      
      @media (min-width: 640px) {
        .features {
          padding: 4rem 0;
        }
      }
      
      .features-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        margin-top: 3rem;
      }
      
      @media (min-width: 768px) {
        .features-grid {
          grid-template-columns: repeat(3, 1fr);
        }
      }
      
      .feature-card {
        background: #ffffff;
        padding: 2rem;
        border-radius: 1rem;
        box-shadow: 0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
      }
      
      .feature-card:hover {
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
        transform: translateY(-8px);
      }
      
      .feature-icon {
        width: 3.5rem;
        height: 3.5rem;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
        transition: transform 0.3s ease;
      }
      
      .feature-card:hover .feature-icon {
        transform: scale(1.1);
      }
      
      .feature-icon-blue {
        background: linear-gradient(to bottom right, #3b82f6, #2563eb);
      }
      
      .feature-icon-purple {
        background: linear-gradient(to bottom right, #8b5cf6, #7c3aed);
      }
      
      .feature-icon-green {
        background: linear-gradient(to bottom right, #22c55e, #059669);
      }
      
      .feature-icon svg {
        width: 1.75rem;
        height: 1.75rem;
        color: #ffffff;
      }
      
      .feature-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #0f172a;
        margin-bottom: 0.5rem;
        letter-spacing: -0.01em;
      }
      
      .feature-desc {
        color: #64748b;
        font-size: 0.875rem;
        line-height: 1.6;
        font-weight: 400;
      }
      
      /* ==========================================
         SUBSECTION: Latest Posts Grid
         ========================================== */
      .posts-section {
        padding-bottom: 4rem;
      }
      
      .posts-header {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
      }
      
      @media (min-width: 640px) {
        .posts-header {
          flex-direction: row;
          justify-content: space-between;
          align-items: center;
        }
      }
      
      .posts-header a {
        color: #2563eb;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
        transition: color 0.3s ease;
        font-weight: 500;
      }
      
      .posts-header a:hover {
        color: #1d4ed8;
      }
      
      .posts-header a:hover .btn-icon {
        transform: translateX(4px);
      }
      
      .posts-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      
      @media (min-width: 768px) {
        .posts-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      
      @media (min-width: 1024px) {
        .posts-grid {
          grid-template-columns: repeat(3, 1fr);
        }
      }
      
      .post-card {
        transition: transform 0.3s ease;
      }
      
      .post-card:hover {
        transform: scale(1.02);
      }
      
      .post-card-inner {
        overflow: hidden;
        border-radius: 1rem;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
      }
      
      .post-card-inner:hover {
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1);
      }
      
      .post-image {
        position: relative;
        height: 12rem;
        overflow: hidden;
        background: #f1f5f9;
      }
      
      .post-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
      }
      
      .post-card-inner:hover .post-image img {
        transform: scale(1.05);
      }
      
      .post-category {
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        padding: 0.25rem 0.75rem;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(4px);
        font-size: 0.75rem;
        font-weight: 600;
        color: #334155;
        border-radius: 9999px;
        letter-spacing: 0.02em;
      }
      
      .post-body {
        padding: 1.25rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }
      
      .post-body h3 {
        font-size: 1.125rem;
        font-weight: 600;
        line-height: 1.3;
        letter-spacing: -0.01em;
      }
      
      .post-body h3 a {
        transition: color 0.3s ease;
      }
      
      .post-body h3 a:hover {
        color: #2563eb;
      }
      
      .post-body p {
        font-size: 0.875rem;
        color: #64748b;
        line-height: 1.5;
        font-weight: 400;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      
      .post-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.75rem;
        color: #94a3b8;
        font-weight: 400;
        margin-top: auto;
        padding-top: 0.5rem;
      }
      
      .post-empty {
        text-align: center;
        padding: 3rem 0;
        background: #f8fafc;
        border-radius: 0.75rem;
      }
      
      .post-empty p {
        color: #64748b;
        font-weight: 400;
      }
      
      .post-empty a {
        color: #2563eb;
        display: inline-block;
        margin-top: 0.5rem;
        font-weight: 500;
      }
      
      .post-empty a:hover {
        text-decoration: underline;
      }
      
      /* ==========================================
         SUBSECTION: Utility Classes
         ========================================== */
      .hidden-xs {
        display: none;
      }
      
      @media (min-width: 480px) {
        .hidden-xs {
          display: inline;
        }
      }
      
      .text-center {
        text-align: center;
      }
      
      .text-lg {
        font-size: 1.125rem;
      }
      
      .text-muted {
        color: #64748b;
      }
      
      .font-semibold {
        font-weight: 600;
      }
    </style>
  </head>
  
  <body>
    <!-- ============================================
    SECTION: Navbar
    ============================================ -->
    <Navbar />

    <!-- ============================================
    SECTION: Location Banner
    ============================================ -->
    <div class="location-banner">
      <span>📍</span> Serving Los Angeles, California — Your Trusted Local Source for Trends, Reviews &amp; Insights
    </div>

    <!-- ============================================
SECTION: Compact Hero - FIXED
============================================ -->
<section class="hero-compact" style="
  position: relative;
  min-height: calc(100vh - 64px - 40px);
  display: flex;
  align-items: center;
  overflow: hidden;
  background: #0a0a0a;
  padding: 2rem 0;
">
  <!-- Background Image -->
  <div class="hero-bg" style="position: absolute; inset: 0; width: 100%; height: 100%;">
    <img 
      src="https://pub-bf1013d046c946448ed23cbf79e38b92.r2.dev/Webstructmedia/webo.jpg" 
      alt="Trendlin - Los Angeles" 
      style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.7), rgba(0,0,0,0.4), rgba(0,0,0,0.7));"></div>
    <div style="position: absolute; inset: 0; background: linear-gradient(to right, rgba(0,0,0,0.3), transparent, rgba(0,0,0,0.3));"></div>
  </div>

  <!-- Hero Content -->
  <div style="position: relative; width: 100%; z-index: 10; padding: 1.5rem 1rem;">
    <div style="max-width: 800px; margin: 0 auto; text-align: center;">
      
      <!-- Badge -->
      <div style="
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
