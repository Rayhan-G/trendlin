          <p class="feature-desc">Honest, in-depth reviews of products available in Los Angeles stores and online.</p>
        </div>

        <!-- ---- Feature Card 2 ---- -->
        <div class="feature-card">
          <div class="feature-icon feature-icon-purple">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
            </svg>
          </div>
          <h3 class="feature-title">LA Lifestyle &amp; Culture</h3>
          <p class="feature-desc">Insightful articles on Los Angeles lifestyle, events, and what's trending in the city.</p>
        </div>

        <!-- ---- Feature Card 3 ---- -->
        <div class="feature-card">
          <div class="feature-icon feature-icon-green">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
          </div>
          <h3 class="feature-title">Local Affiliate Deals</h3>
          <p class="feature-desc">Find the best deals on products and services available in the Los Angeles area.</p>
        </div>

      </div>
    </section>

    <!-- ============================================
    SECTION: Latest Posts
    ============================================ -->
    <section class="container posts-section">
      
      <!-- SUBSECTION: Posts Header -->
      <div class="posts-header">
        <h2 class="section-title">Latest in LA</h2>
        <a href="/search">
          View All
          <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- SUBSECTION: Posts Grid -->
      {posts.length > 0 ? (
        <div class="posts-grid">
          {posts.slice(0, 6).map((post) => (
            <div class="post-card">
              <article class="post-card-inner">
                
                <!-- ---- Post Image ---- -->
                {post.cover_image && (
                  <div class="post-image">
                    <img src={post.cover_image} alt={post.title} loading="lazy" />
                    {post.category_name && (
                      <span class="post-category">{post.category_name}</span>
                    )}
                  </div>
                )}
                
                <!-- ---- Post Body ---- -->
                <div class="post-body">
                  <h3>
                    <a href={`/article/${post.slug}`}>{post.title}</a>
                  </h3>
                  {post.excerpt && <p>{post.excerpt}</p>}
                  <div class="post-meta">
                    <span>{new Date(post.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                    <span>5 min read</span>
                  </div>
                </div>

              </article>
            </div>
          ))}
        </div>
      ) : (
        <!-- ---- Empty State ---- -->
        <div class="post-empty">
          <p>No posts yet. Check back soon for the latest from Los Angeles!</p>
          <a href="/admin/posts/new">Create your first post →</a>
        </div>
      )}
    </section>

    <!-- ============================================
    SECTION: Footer
    ============================================ -->
    <Footer />
  </body>
