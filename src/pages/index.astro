---
// ============================================
// HOMEPAGE - Trendlin (Premium Floating Cards)
// ============================================

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import ProductCard from '../components/ProductCard.astro';
import ResourcePopup from '../components/ResourcePopup.astro';

let posts = [];
let products = [];

try {
  const { DB } = Astro.locals.runtime.env;
  
  // Fetch published posts
  const postsResult = await DB.prepare(`
    SELECT 
      id, title, slug, excerpt, category, cover_image, 
      published_at, created_at,
      'post' as type
    FROM posts 
    WHERE is_draft = 0 
    AND is_published = 1
    ORDER BY created_at DESC
  `).all();
  
  posts = postsResult.results || [];
  
  // Fetch products
  const productsResult = await DB.prepare(`
    SELECT 
      p.id, p.name as title, p.slug, p.description as excerpt, 
      p.category, p.cover_image, p.created_at, 
      p.brand,
      'product' as type
    FROM products p
    WHERE p.in_stock = 1
    ORDER BY p.created_at DESC
  `).all();
  
  // ============================================
  // FETCH RESOURCES - NO shop_name
  // ============================================
  const resourcesResult = await DB.prepare(`
    SELECT 
      product_id,
      platform,
      id,
      url,
      title,
      description,
      author
    FROM product_resources
    WHERE is_active = 1
    ORDER BY product_id, platform, display_order
  `).all();
  
  // Group resources by product_id
  const resourcesByProduct = {};
  for (const r of resourcesResult.results || []) {
    const productId = r.product_id;
    if (!resourcesByProduct[productId]) {
      resourcesByProduct[productId] = [];
    }
    resourcesByProduct[productId].push({
      id: r.id,
      platform: r.platform.toLowerCase(),
      url: r.url,
      title: r.title,
      description: r.description || '',
      author: r.author || ''
    });
  }
  
  // Attach resources to products
  products = productsResult.results.map(p => ({
    ...p,
    social_resources: resourcesByProduct[p.id] || []
  }));
  
  // DEBUG: Check product 1
  const p1 = products.find(p => p.id === 1);
  if (p1) {
    console.log('✅ Product 1 loaded:', p1.title);
    console.log('📊 Resources count:', p1.social_resources.length);
  }
  
} catch (error) {
  console.error('Database error:', error);
}

// ============================================
// DATE HELPERS
// ============================================
const now = new Date();
const twentyFourHoursAgo = new Date(now.getTime() - 24 * 60 * 60 * 1000);
const sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);

function isWithinWindow(dateStr, windowStart) {
  if (!dateStr) return false;
  const date = new Date(dateStr);
  return date >= windowStart && date <= now;
}

// ============================================
// FILTER POSTS & PRODUCTS BY TIME WINDOWS
// ============================================

const todaysPosts = posts.filter(post => {
  const date = post.published_at || post.created_at;
  return isWithinWindow(date, twentyFourHoursAgo);
});

// FORCE PRODUCT 1 TO SHOW
const todaysProducts = products.filter(product => {
  return product.id === 1 || isWithinWindow(product.created_at, twentyFourHoursAgo);
});

const recentPosts = posts.filter(post => {
  const date = post.published_at || post.created_at;
  return isWithinWindow(date, sevenDaysAgo);
});

// FORCE PRODUCT 1 TO SHOW
const recentProducts = products.filter(product => {
  return product.id === 1 || isWithinWindow(product.created_at, sevenDaysAgo);
});

// ============================================
// SECTION CONFIGURATION
// ============================================
const sectionData = [
  { 
    id: 0, 
    title: "📌 Today's Picks", 
    subtitle: "Fresh posts from the last 24 hours", 
    align: 'left',
    mainPosts: todaysPosts.slice(0, 10)
  },
  { 
    id: 1, 
    title: "⭐ Top Picks", 
    subtitle: "Hot products from the last 24 hours", 
    align: 'right',
    mainPosts: todaysProducts.slice(0, 10)
  },
  { 
    id: 2, 
    title: "🆕 Recently Added", 
    subtitle: "Fresh posts from the last 7 days", 
    align: 'left',
    mainPosts: recentPosts.slice(0, 10)
  },
  { 
    id: 3, 
    title: "🚀 Newly Released", 
    subtitle: "Latest products from the last 7 days", 
    align: 'right',
    mainPosts: recentProducts.slice(0, 10)
  },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Trendlin - Trusted Reviews & Local Insights for Americans</title>
  <meta name="description" content="Honest product reviews, buying guides, and local insights for Americans." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={Astro.url.href} />
  
  <meta property="og:title" content="Trendlin - Trusted Reviews & Local Insights" />
  <meta property="og:description" content="Honest product reviews and local insights for Americans." />
  <meta property="og:type" content="website" />
  <meta property="og:url" href={Astro.url.href} />
  
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: #f8fafc;
      color: #0f172a;
      -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; display: block; }
    
    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
    @media (min-width: 768px) { .container { padding: 0 2.5rem; } }
    
    /* ===== HERO ===== */
    .hero {
      position: relative;
      min-height: 50vh;
      display: flex;
      align-items: center;
      background: #0a0a0a;
      padding: 4rem 0;
      overflow: hidden;
      margin-bottom: 2.5rem;
    }
    .hero-bg { position: absolute; inset: 0; }
    .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(0,0,0,0.6), rgba(0,0,0,0.3));
    }
    .hero-content {
      position: relative;
      width: 100%;
      z-index: 10;
      text-align: center;
      padding: 2rem 1rem;
    }
    .hero-content h1 {
      font-size: clamp(2rem, 4.5vw, 3.5rem);
      font-weight: 800;
      color: #ffffff;
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }
    .hero-content h1 span {
      background: linear-gradient(to right, #60a5fa, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero-content p {
      font-size: clamp(0.9rem, 1.3vw, 1.2rem);
      color: rgba(255,255,255,0.85);
      max-width: 600px;
      margin: 0 auto 1.5rem;
      line-height: 1.6;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 2rem;
      background: #2563eb;
      color: #fff;
      border-radius: 10px;
      font-weight: 600;
      font-size: 0.95rem;
      transition: all 0.3s ease;
      border: none;
      cursor: pointer;
    }
    .btn-primary:hover {
      background: #1d4ed8;
      transform: scale(1.03);
    }
    .btn-primary svg {
      width: 1rem;
      height: 1rem;
      transition: transform 0.3s ease;
    }
    .btn-primary:hover svg { transform: translateX(4px); }
    
    /* ===== SECTION ===== */
    .section {
      padding: 3rem 0;
    }
    .section:nth-child(odd) { background: #ffffff; }
    .section:nth-child(even) { background: #f8fafc; }
    
    /* ===== 80/20 LAYOUT ===== */
    .row {
      display: flex;
      width: 100%;
      gap: 0;
      flex-wrap: wrap;
      position: relative;
    }
    
    .row-left .col-80 {
      width: 80%;
      border: 2px solid #2563eb;
      border-radius: 14px;
      padding: 1.5rem 1.5rem 1rem 1.5rem;
      background: #ffffff;
      position: relative;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .row-left .col-20 {
      width: 20%;
      margin-left: 1.5rem;
    }
    
    .row-right .col-80 {
      width: 80%;
      border: 2px solid #2563eb;
      border-radius: 14px;
      padding: 1.5rem 1.5rem 1rem 1.5rem;
      background: #ffffff;
      position: relative;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .row-right .col-20 {
      width: 20%;
      margin-right: 1.5rem;
    }
    
    .row-left {
      justify-content: flex-start;
    }
    .row-right {
      justify-content: flex-end;
    }
    
    /* ===== SECTION TITLE ===== */
    .section-title-wrapper {
      width: 80%;
      margin-bottom: 0.75rem;
      padding: 0 0.25rem;
    }
    .section-title-wrapper h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #0f172a;
      letter-spacing: -0.01em;
    }
    .section-title-wrapper p {
      color: #64748b;
      margin-top: 0.2rem;
      font-size: 0.95rem;
      font-weight: 400;
    }
    .row-left .section-title-wrapper {
      text-align: left;
    }
    .row-right .section-title-wrapper {
      text-align: right;
    }
    
    /* ===== SCROLLABLE CARD CONTAINER ===== */
    .scroll-wrapper {
      position: relative;
      overflow: hidden;
      padding: 0.5rem 0;
    }
    
    .card-grid {
      display: flex;
      gap: 2rem;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      padding: 0.75rem 0.25rem 1.25rem 0.25rem;
      scrollbar-width: none;
      -ms-overflow-style: none;
      align-items: stretch;
    }
    .card-grid::-webkit-scrollbar {
      display: none;
    }
    
    /* ===== CARD WRAPPER - PROFESSIONAL SPACING ===== */
    .post-card-wrapper {
      flex: 0 0 320px;
      min-width: 280px;
      max-width: 360px;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      height: 100%;
      display: flex;
      flex-direction: column;
      position: relative;
    }
    .post-card-wrapper:not(:last-child) {
      margin-right: 0.25rem;
    }
    .post-card-wrapper:hover {
      transform: translateY(-6px);
    }
    
    /* Ensure cards inside wrapper fill height properly */
    .post-card-wrapper > * {
      height: 100%;
      display: flex;
      flex-direction: column;
      width: 100%;
    }
    
    /* ===== SCROLL BUTTONS ===== */
    .scroll-btn {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
      background: rgba(37, 99, 235, 0.92);
      color: white;
      border: none;
      border-radius: 50%;
      width: 44px;
      height: 44px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 16px rgba(37, 99, 235, 0.25);
      transition: all 0.3s ease;
      backdrop-filter: blur(8px);
      border: 2px solid rgba(255,255,255,0.3);
      opacity: 1;
    }
    .scroll-btn:hover {
      background: rgba(29, 78, 216, 0.98);
      transform: translateY(-50%) scale(1.08);
      box-shadow: 0 6px 20px rgba(37, 99, 235, 0.35);
    }
    .scroll-btn:active {
      transform: translateY(-50%) scale(0.95);
    }
    .scroll-btn.left { left: -6px; }
    .scroll-btn.right { right: -6px; }
    .scroll-btn svg {
      width: 22px;
      height: 22px;
      stroke: white;
      stroke-width: 2.5;
      fill: none;
    }
    
    /* Show buttons only when there's scrollable content */
    .scroll-wrapper .scroll-btn {
      display: none;
    }
    .scroll-wrapper.has-scroll .scroll-btn {
      display: flex;
    }
    
    /* ===== EMPTY STATE ===== */
    .empty-state {
      padding: 4rem 2rem;
      text-align: center;
      color: #64748b;
      background: #f8fafc;
      border-radius: 12px;
      border: 2px dashed #cbd5e1;
      width: 100%;
      min-height: 240px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      flex: 1;
    }
    .empty-state p {
      font-size: 1.05rem;
      margin: 0;
      font-weight: 400;
    }
    .empty-state .emoji {
      font-size: 3.5rem;
      display: block;
      margin-bottom: 0.75rem;
    }
    
    /* ===== RESPONSIVE ===== */
    @media (max-width: 1024px) {
      .post-card-wrapper {
        flex: 0 0 calc(50% - 1rem);
        min-width: 200px;
        max-width: none;
      }
      .card-grid {
        gap: 1.5rem;
      }
    }
    
    @media (max-width: 768px) {
      .row { flex-direction: column; align-items: center; }
      .row-left .col-80, .row-right .col-80 { 
        width: 100%; 
        padding: 1.25rem 1.25rem 0.75rem 1.25rem;
      }
      .row-left .col-20, .row-right .col-20 { 
        width: 100%; 
        margin: 0;
      }
      .section-title-wrapper {
        width: 100%;
        text-align: left !important;
        padding: 0 0.25rem;
      }
      .section-title-wrapper h2 {
        font-size: 1.25rem;
      }
      .scroll-btn {
        width: 36px;
        height: 36px;
      }
      .scroll-btn svg {
        width: 18px;
        height: 18px;
      }
      .post-card-wrapper {
        flex: 0 0 calc(50% - 0.75rem);
        min-width: 160px;
        max-width: none;
      }
      .card-grid {
        gap: 1.25rem;
        padding: 0.5rem 0.15rem 1rem 0.15rem;
      }
      .section {
        padding: 2rem 0;
      }
    }
    
    @media (max-width: 480px) {
      .card-grid { 
        gap: 1rem; 
        padding: 0.5rem 0.1rem 0.8rem 0.1rem;
      }
      .post-card-wrapper {
        flex: 0 0 calc(85% - 0.5rem);
        min-width: 140px;
        max-width: none;
      }
      .col-80 {
        padding: 1rem 0.75rem 0.5rem 0.75rem !important;
      }
      .scroll-btn {
        width: 32px;
        height: 32px;
      }
      .scroll-btn svg {
        width: 16px;
        height: 16px;
      }
      .scroll-btn.left { left: -2px; }
      .scroll-btn.right { right: -2px; }
    }
    
    @media (max-width: 640px) {
      .hero { min-height: 35vh; padding: 2rem 0; }
      .section { padding: 1.5rem 0; }
      .section-title-wrapper h2 { font-size: 1.1rem; }
      .empty-state { padding: 1.5rem; min-height: 150px; }
      .empty-state .emoji { font-size: 2.5rem; }
    }
  </style>
</head>
<body>

<Navbar />

<section class="hero">
  <div class="hero-bg">
    <img src="https://images.unsplash.com/photo-1480714378408-67cf0d13bc1b?w=1600&q=80" alt="America" loading="eager" />
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-content container">
    <h1>Discover What's <span>Trending</span> in America</h1>
    <p>Honest product reviews, buying guides, and local insights — made for Americans.</p>
    <a href="/categories" class="btn-primary">
      Explore Categories
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
      </svg>
    </a>
  </div>
</section>

{sectionData.map((section) => (
  <section class="section" key={section.id}>
    <div class="container">
      
      {section.align === 'left' ? (
        <div class="row row-left">
          <div class="section-title-wrapper">
            <h2>{section.title}</h2>
            <p>{section.subtitle}</p>
          </div>
          <div class="col-80">
            <div class="scroll-wrapper" data-section={section.id}>
              <div class="card-grid" id="scroll-{section.id}">
                {section.mainPosts.length === 0 ? (
                  <div class="empty-state">
                    <span class="emoji">👀</span>
                    <p>Nothing new yet. Check back soon!</p>
                  </div>
                ) : (
                  section.mainPosts.map((item) => (
                    <div class="post-card-wrapper">
                      {item.type === 'product' ? (
                        <ProductCard product={item} />
                      ) : (
                        <PostCard post={item} />
                      )}
                    </div>
                  ))
                )}
              </div>
              
              <button class="scroll-btn left" data-scroll="left-{section.id}" aria-label="Scroll left">
                <svg viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
                </svg>
              </button>
              <button class="scroll-btn right" data-scroll="right-{section.id}" aria-label="Scroll right">
                <svg viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
                </svg>
              </button>
            </div>
          </div>
          <div class="col-20"></div>
        </div>
      ) : (
        <div class="row row-right">
          <div class="col-20"></div>
          <div class="section-title-wrapper">
            <h2>{section.title}</h2>
            <p>{section.subtitle}</p>
          </div>
          <div class="col-80">
            <div class="scroll-wrapper" data-section={section.id}>
              <div class="card-grid" id="scroll-{section.id}">
                {section.mainPosts.length === 0 ? (
                  <div class="empty-state">
                    <span class="emoji">👀</span>
                    <p>Nothing new yet. Check back soon!</p>
                  </div>
                ) : (
                  section.mainPosts.map((item) => (
                    <div class="post-card-wrapper">
                      {item.type === 'product' ? (
                        <ProductCard product={item} />
                      ) : (
                        <PostCard post={item} />
                      )}
                    </div>
                  ))
                )}
              </div>
              
              <button class="scroll-btn left" data-scroll="left-{section.id}" aria-label="Scroll left">
                <svg viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
                </svg>
              </button>
              <button class="scroll-btn right" data-scroll="right-{section.id}" aria-label="Scroll right">
                <svg viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>
))}

<Footer />

<!-- ============================================
   RESOURCE POPUP - Single Instance
   ============================================ -->
<ResourcePopup />

<!-- ============================================
   SCROLL BUTTON CONTROLLER
   ============================================ -->
<script is:inline>
  (function() {
    'use strict';
    
    function initScrollButtons() {
      document.querySelectorAll('.scroll-wrapper').forEach(wrapper => {
        const grid = wrapper.querySelector('.card-grid');
        const leftBtn = wrapper.querySelector('.scroll-btn.left');
        const rightBtn = wrapper.querySelector('.scroll-btn.right');
        
        if (!grid || !leftBtn || !rightBtn) return;
        
        function checkScroll() {
          const hasScroll = grid.scrollWidth > grid.clientWidth;
          wrapper.classList.toggle('has-scroll', hasScroll);
        }
        
        leftBtn.addEventListener('click', () => {
          grid.scrollBy({ left: -grid.clientWidth * 0.8, behavior: 'smooth' });
        });
        
        rightBtn.addEventListener('click', () => {
          grid.scrollBy({ left: grid.clientWidth * 0.8, behavior: 'smooth' });
        });
        
        checkScroll();
        window.addEventListener('resize', checkScroll);
        
        grid.addEventListener('scroll', () => {
          const atLeft = grid.scrollLeft <= 10;
          const atRight = grid.scrollLeft >= grid.scrollWidth - grid.clientWidth - 10;
          leftBtn.style.opacity = atLeft ? '0.3' : '1';
          rightBtn.style.opacity = atRight ? '0.3' : '1';
        });
      });
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScrollButtons);
    } else {
      initScrollButtons();
    }
    
  })();
</script>

</body>
</html>