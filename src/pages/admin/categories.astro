<!-- ============================================ -->
<!-- JAVASCRIPT -->
<!-- ============================================ -->
<script>
  // Toast Notification
  function showToast(message, type = 'success') {
    document.querySelectorAll('.toast').forEach(el => el.remove());
    
    const toast = document.createElement('div');
    toast.className = 'toast toast-' + type;
    toast.textContent = message;
    document.body.appendChild(toast);
    
    setTimeout(function() {
      toast.style.transform = 'translateY(0)';
      toast.style.opacity = '1';
    }, 50);
    
    setTimeout(function() {
      toast.style.transform = 'translateY(20px)';
      toast.style.opacity = '0';
      setTimeout(function() {
        if (toast.parentNode) toast.parentNode.removeChild(toast);
      }, 300);
    }, 3000);
  }

  // Modal Functions
  function openEditModal(data) {
    var title = document.getElementById('modalTitle');
    if (data.hero_image) {
      title.textContent = '🔄 Change Hero Image';
    } else {
      title.textContent = '➕ Add Hero Image';
    }
    
    document.getElementById('categoryId').value = data.id || '';
    document.getElementById('categoryHeroId').value = data.hero_id || '';
    document.getElementById('categoryDisplayName').textContent = data.name || '';
    document.getElementById('categoryHero').value = data.hero_image || '';
    
    var preview = document.getElementById('heroPreview');
    var previewImg = document.getElementById('heroPreviewImage');
    
    if (data.hero_image) {
      previewImg.src = data.hero_image;
      preview.style.display = 'block';
    } else {
      preview.style.display = 'none';
    }
    
    document.getElementById('editModal').style.display = 'flex';
  }
  
  function closeModal() {
    document.getElementById('editModal').style.display = 'none';
  }
  
  document.getElementById('editModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
  
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var modal = document.getElementById('editModal');
      if (modal.style.display === 'flex') closeModal();
      var mediaModal = document.getElementById('mediaLibraryModal');
      if (mediaModal.style.display === 'flex') closeMediaLibrary();
    }
  });
  
  // Media Library
  function openMediaLibrary() {
    document.getElementById('mediaLibraryModal').style.display = 'flex';
    loadMediaLibrary();
  }
  
  function closeMediaLibrary() {
    document.getElementById('mediaLibraryModal').style.display = 'none';
  }
  
  function refreshMediaLibrary() {
    loadMediaLibrary();
  }
  
  async function loadMediaLibrary() {
    var content = document.getElementById('mediaLibraryContent');
    content.innerHTML = `
      <div class="media-loading text-center py-8">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
        <p class="text-gray-500 mt-2">Loading media...</p>
      </div>
    `;
    
    try {
      var response = await fetch('/api/admin/media');
      var result = await response.json();
      
      if (result.success) {
        var media = result.media || [];
        var imageMedia = media.filter(function(m) {
          return m.mime_type && m.mime_type.startsWith('image/');
        });
        
        if (imageMedia.length === 0) {
          content.innerHTML = `
            <div class="text-center py-8">
              <p class="text-gray-500">No images found in your media library.</p>
              <button onclick="closeMediaLibrary(); document.getElementById('heroFileInput').click()" class="mt-2 btn btn-primary">
                📤 Upload an Image
              </button>
            </div>
          `;
          return;
        }
        
        var html = '<div class="media-grid-mini">';
        imageMedia.forEach(function(item) {
          var displayName = item.original_name || item.filename.split('/').pop() || 'Unknown';
          html += `
            <div class="media-item-mini" onclick="selectMediaImage('${item.url}', '${displayName}')" title="${displayName}">
              <img src="${item.url}" alt="${displayName}" loading="lazy" />
              <div class="overlay">${displayName}</div>
            </div>
          `;
        });
        html += '</div>';
        
        content.innerHTML = html;
      } else {
        content.innerHTML = '<p class="text-red-500 text-center py-4">Error loading media: ' + result.error + '</p>';
      }
    } catch (error) {
      console.error('Error loading media library:', error);
      content.innerHTML = '<p class="text-red-500 text-center py-4">Failed to load media library</p>';
    }
  }
  
  function selectMediaImage(url, name) {
    document.getElementById('categoryHero').value = url;
    document.getElementById('heroPreviewImage').src = url;
    document.getElementById('heroPreview').style.display = 'block';
    closeMediaLibrary();
    showToast('✅ Image selected: ' + name);
  }
  
  // Hero Image Functions
  function removeHeroPreview() {
    document.getElementById('categoryHero').value = '';
    document.getElementById('heroPreview').style.display = 'none';
  }
  
  async function removeHeroImage(categoryId, heroId) {
    if (!confirm('⚠️ Are you sure you want to remove this hero image?')) return;
    
    try {
      var response = await fetch('/api/admin/categories/' + categoryId + '/hero', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ heroId: heroId })
      });
      
      var result = await response.json();
      
      if (response.ok) {
        showToast('✅ Hero image removed successfully!');
        setTimeout(function() { window.location.reload(); }, 500);
      } else {
        showToast('❌ Error: ' + (result.error || 'Failed to remove hero image'), 'error');
      }
    } catch (error) {
      console.error('Remove hero error:', error);
      showToast('❌ Failed to remove hero image', 'error');
    }
  }
  
  // Upload
  document.getElementById('heroFileInput').addEventListener('change', async function(e) {
    var file = this.files[0];
    if (!file) return;
    
    if (!file.type.startsWith('image/')) {
      showToast('Please upload an image file.', 'error');
      this.value = '';
      return;
    }
    
    if (file.size > 5 * 1024 * 1024) {
      showToast('Image must be less than 5MB.', 'error');
      this.value = '';
      return;
    }
    
    var formData = new FormData();
    formData.append('image', file);
    
    var uploadBtn = document.querySelector('.upload-btn');
    var originalText = uploadBtn.textContent;
    uploadBtn.textContent = '⏳ Uploading...';
    uploadBtn.disabled = true;
    
    try {
      var response = await fetch('/api/upload', {
        method: 'POST',
        body: formData
      });
      
      var result = await response.json();
      
      if (result.success) {
        document.getElementById('categoryHero').value = result.url;
        document.getElementById('heroPreviewImage').src = result.url;
        document.getElementById('heroPreview').style.display = 'block';
        showToast('✅ Image uploaded successfully!');
      } else {
        showToast('Upload failed: ' + (result.error || 'Unknown error'), 'error');
      }
    } catch (error) {
      console.error('Upload error:', error);
      showToast('Upload failed. Please try again.', 'error');
    } finally {
      uploadBtn.textContent = originalText;
      uploadBtn.disabled = false;
    }
    
    this.value = '';
  });
  
  // Form Submission (Save Hero Image)
  document.getElementById('categoryForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    var formData = new FormData(this);
    var data = Object.fromEntries(formData);
    
    var categoryId = data.id;
    var heroImage = data.hero_image;
    var heroId = data.hero_id || '';
    
    if (!heroImage) {
      showToast('❌ Please select or enter a hero image URL', 'error');
      return;
    }
    
    var saveBtn = document.getElementById('saveBtn');
    var saveBtnText = document.getElementById('saveBtnText');
    var saveBtnLoading = document.getElementById('saveBtnLoading');
    saveBtn.disabled = true;
    saveBtnText.style.display = 'none';
    saveBtnLoading.style.display = 'inline';
    
    try {
      var response = await fetch('/api/admin/categories/' + categoryId + '/hero', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ hero_image: heroImage, hero_id: heroId || null })
      });
      
      var result = await response.json();
      
      if (response.ok) {
        showToast('✅ Hero image saved successfully!');
        setTimeout(function() { window.location.reload(); }, 500);
      } else {
        showToast('❌ Error: ' + (result.error || 'Failed to save hero image'), 'error');
      }
    } catch (error) {
      console.error('Save error:', error);
      showToast('❌ Failed to save hero image', 'error');
    } finally {
      saveBtn.disabled = false;
      saveBtnText.style.display = 'inline';
      saveBtnLoading.style.display = 'none';
    }
  });
</script>