<!-- DELETE FUNCTIONALITY -->
<!-- ============================================ -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Delete Posts
    const deleteButtons = document.querySelectorAll('.delete-btn');
    
    deleteButtons.forEach(function(button) {
      button.addEventListener('click', async function(e) {
        e.preventDefault();
        
        const postId = this.getAttribute('data-id');
        
        if (!confirm('Are you sure you want to delete this post?')) {
          return;
        }
        
        const originalText = this.innerHTML;
        this.innerHTML = 'Deleting...';
        this.disabled = true;
        this.classList.add('opacity-50');
        
        try {
          const response = await fetch(`/api/admin/posts/${postId}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
          });
          
          const result = await response.json();
          
          if (!response.ok) {
            throw new Error(result.error || 'Delete failed');
          }
          
          alert('✅ Post deleted successfully!');
          window.location.reload();
          
        } catch (error) {
          console.error('Error:', error);
          alert('❌ Failed to delete post');
          this.innerHTML = originalText;
          this.disabled = false;
          this.classList.remove('opacity-50');
        }
      });
    });

    // Delete Content Calendar Items
    const deleteContentButtons = document.querySelectorAll('.delete-content-btn');
    
    deleteContentButtons.forEach(function(button) {
      button.addEventListener('click', async function(e) {
        e.preventDefault();
        
        const contentId = this.getAttribute('data-id');
        
        if (!confirm('Are you sure you want to delete this content?')) {
          return;
        }
        
        const originalText = this.innerHTML;
        this.innerHTML = 'Deleting...';
        this.disabled = true;
        this.classList.add('opacity-50');
        
        try {
          const response = await fetch(`/api/admin/content/${contentId}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
          });
          
          const result = await response.json();
          
          if (!response.ok) {
            throw new Error(result.error || 'Delete failed');
          }
          
          alert('✅ Content deleted successfully!');
          window.location.reload();
          
        } catch (error) {
          console.error('Error:', error);
          alert('❌ Failed to delete content');
          this.innerHTML = originalText;
          this.disabled = false;
          this.classList.remove('opacity-50');
        }
      });
    });

    // Search functionality
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase();
        const rows = document.querySelectorAll('.posts-table tbody tr');
        
        rows.forEach(row => {
          const title = row.querySelector('.post-title')?.textContent?.toLowerCase() || '';
          row.style.display = title.includes(searchTerm) ? '' : 'none';
        });
      });
    }
  });
</script>

