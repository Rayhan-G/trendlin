<!-- ============================================ -->
<!-- DELETE FUNCTIONALITY -->
<!-- ============================================ -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Delete Posts
    const deleteButtons = document.querySelectorAll('.delete-btn');
    
    deleteButtons.forEach(function(button) {
      button.addEventListener('click', async function(e) {
        e.preventDefault();
        
        const postId = this.getAttribute('data-id');
        
        if (!confirm('Are you sure you want to delete this post?')) {
          return;
        }
        
        const originalHTML = this.innerHTML;
        this.innerHTML = 'Deleting...';
        this.disabled = true;
        this.classList.add('loading');
        
        try {
          const response = await fetch(`/api/admin/posts/${postId}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
          });
          
          const result = await response.json();
          
          if (!response.ok) {
            throw new Error(result.error || 'Delete failed');
          }
          
          // Show success feedback
          const postItem = this.closest('.post-item');
          postItem.style.opacity = '0.5';
          postItem.style.transition = 'opacity 0.3s';
          
          setTimeout(() => {
            window.location.reload();
          }, 500);
          
        } catch (error) {
          console.error('Error:', error);
          alert('❌ Failed to delete post');
          this.innerHTML = originalHTML;
          this.disabled = false;
          this.classList.remove('loading');
        }
      });
    });

    // Delete Content Calendar Items
    const deleteContentButtons = document.querySelectorAll('.delete-content-btn');
    
    deleteContentButtons.forEach(function(button) {
      button.addEventListener('click', async function(e) {
        e.preventDefault();
        
        const contentId = this.getAttribute('data-id');
        
        if (!confirm('Are you sure you want to delete this content?')) {
          return;
        }
        
        const originalHTML = this.innerHTML;
        this.innerHTML = 'Deleting...';
        this.disabled = true;
        this.classList.add('loading');
        
        try {
          const response = await fetch(`/api/admin/content/${contentId}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
          });
          
          const result = await response.json();
          
          if (!response.ok) {
            throw new Error(result.error || 'Delete failed');
          }
          
          const contentItem = this.closest('.content-item');
          contentItem.style.opacity = '0.5';
          contentItem.style.transition = 'opacity 0.3s';
          
          setTimeout(() => {
            window.location.reload();
          }, 500);
          
        } catch (error) {
          console.error('Error:', error);
          alert('❌ Failed to delete content');
          this.innerHTML = originalHTML;
          this.disabled = false;
          this.classList.remove('loading');
        }
      });
    });

    // Search functionality
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase().trim();
        const postItems = document.querySelectorAll('.post-item');
        
        postItems.forEach(item => {
          const title = item.querySelector('.post-item-title')?.textContent?.toLowerCase() || '';
          const shouldShow = searchTerm === '' || title.includes(searchTerm);
          item.style.display = shouldShow ? '' : 'none';
        });
      });
    }
  });
</script>

