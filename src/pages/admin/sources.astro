      width: 100%;
      min-width: unset;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }

    .actions-cell {
      flex-direction: column;
      gap: 0.25rem;
    }

    .sources-table {
      font-size: 0.75rem;
    }

    .sources-table th,
    .sources-table td {
      padding: 0.5rem;
    }

