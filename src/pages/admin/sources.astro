  window.deleteWebsite = function(id) {
    const website = websites.find(w => w.id === id);
    if (!confirm(`Delete "${website?.name}"? This cannot be undone.`)) return;
    
    fetch('/api/admin/reliable/websites/' + id, { method: 'DELETE' })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          showToast('✅ Website deleted', 'success');
          loadData();
        } else {
          showToast('❌ ' + (data.error || 'Failed'), 'error');
        }
      })
      .catch(err => {
        showToast('❌ Error deleting website', 'error');
