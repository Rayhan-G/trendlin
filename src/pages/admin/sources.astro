</style>

<script>
  // ============================================
  // STATE
  // ============================================
  let websites = [];
  let categories = [];
  let subcategories = [];
  let subsubcategories = [];
  let editingId = null;
  let currentTab = 'websites';

  // ============================================
  // DOM REFS
  // ============================================
  const $ = (id) => document.getElementById(id);
  const loadingEl = $('loading-state');
  const tableWrap = $('table-wrap');
  const emptyEl = $('empty-state');
  const tableBody = $('table-body');
  const toast = $('toast');

  // ============================================
  // TOAST
  // ============================================
  function showToast(message, type = 'success') {
    toast.textContent = message;
    toast.className = `toast ${type}`;
    toast.classList.add('show');
    clearTimeout(toast._timeout);
    toast._timeout = setTimeout(() => toast.classList.remove('show'), 3000);
  }

  // ============================================
  // TABS
  // ============================================
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
      this.classList.add('active');
      const tabName = this.dataset.tab;
      document.getElementById(`tab-${tabName}`).classList.add('active');
      currentTab = tabName;
      if (tabName === 'categories') renderCategories();
      else if (tabName === 'subcategories') renderSubcategories();
      else if (tabName === 'subsubcategories') renderSubSubcategories();
    });
  });

  // ============================================
  // LOAD DATA
  // ============================================
  function loadData() {
    loadingEl.style.display = 'block';
    tableWrap.style.display = 'none';
    emptyEl.style.display = 'none';
    
    Promise.all([loadWebsites(), loadCategories(), loadSubcategories(), loadSubSubcategories()])
      .then(() => {
        loadingEl.style.display = 'none';
        renderTable();
        updateStats();
        populateAllSelects();
        renderCategories();
        renderSubcategories();
        renderSubSubcategories();
      })
      .catch((err) => {
        console.error('Failed to load data:', err);
        showToast('Failed to load data: ' + err.message, 'error');
        loadingEl.style.display = 'none';
      });
  }

  function loadWebsites() {
    const params = new URLSearchParams();
    if ($('filter-category').value) params.append('category', $('filter-category').value);
    if ($('filter-subcategory').value) params.append('subcategory', $('filter-subcategory').value);
    if ($('filter-subsubcategory').value) params.append('subsubcategory', $('filter-subsubcategory').value);
    if ($('filter-score').value) params.append('min_score', $('filter-score').value);
    if ($('search-input').value) params.append('search', $('search-input').value);
    
    return fetch('/api/admin/reliable/websites?' + params.toString())
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          websites = data.data || [];
        } else {
          console.error('API error:', data.error);
          websites = [];
        }
      })
      .catch(err => {
        console.error('Error loading websites:', err);
        websites = [];
      });
  }

  function loadCategories() {
    return fetch('/api/admin/reliable/categories')
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          categories = data.data || [];
        }
      })
      .catch(err => console.error('Error loading categories:', err));
  }

  function loadSubcategories() {
    return fetch('/api/admin/reliable/subcategories')
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          subcategories = data.data || [];
        }
      })
      .catch(err => console.error('Error loading subcategories:', err));
  }

  function loadSubSubcategories() {
    return fetch('/api/admin/reliable/subsubcategories')
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          subsubcategories = data.data || [];
        }
      })
      .catch(err => console.error('Error loading sub-subcategories:', err));
  }

  // ============================================
  // POPULATE SELECTS
  // ============================================
  function populateAllSelects() {
    populateCategorySelects();
    populateSubcategoryFilter();
    populateSubSubcategoryFilter();
    populateModalSelects();
  }

  function populateCategorySelects() {
    const selects = ['filter-category', 'form-category', 'subcat-filter-category', 'form-subcategory-category'];
    selects.forEach(id => {
      const sel = $(id);
      if (!sel) return;
      const val = sel.value;
      sel.innerHTML = '<option value="">Select Category</option>';
      categories.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = (c.icon || '📚') + ' ' + c.name;
        sel.appendChild(opt);
      });
      sel.value = val;
    });
  }

  function populateSubcategoryFilter() {
    const sel = $('filter-subcategory');
    const val = sel.value;
    sel.innerHTML = '<option value="">All Subcategories</option>';
    
    let filtered = subcategories;
    if ($('filter-category').value) {
      filtered = subcategories.filter(sc => sc.category_id === parseInt($('filter-category').value));
    }
    
    filtered.forEach(sc => {
      const opt = document.createElement('option');
      opt.value = sc.id;
      opt.textContent = sc.name;
      sel.appendChild(opt);
    });
    sel.value = val;
  }

  function populateSubSubcategoryFilter() {
    const sel = $('filter-subsubcategory');
    const val = sel.value;
    sel.innerHTML = '<option value="">All Sub-Subcategories</option>';
    
    let filtered = subsubcategories;
    if ($('filter-subcategory').value) {
      filtered = subsubcategories.filter(ssc => ssc.subcategory_id === parseInt($('filter-subcategory').value));
    } else if ($('filter-category').value) {
      const subcatIds = subcategories.filter(sc => sc.category_id === parseInt($('filter-category').value)).map(sc => sc.id);
      filtered = subsubcategories.filter(ssc => subcatIds.includes(ssc.subcategory_id));
    }
    
    filtered.forEach(ssc => {
      const opt = document.createElement('option');
      opt.value = ssc.id;
      opt.textContent = ssc.name;
      sel.appendChild(opt);
    });
    sel.value = val;
  }

  function populateModalSelects() {
    // Website modal - category
    const fCat = $('form-category');
    if (fCat) {
      const val = fCat.value;
      fCat.innerHTML = '<option value="">Select a category</option>';
      categories.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = (c.icon || '📚') + ' ' + c.name;
        fCat.appendChild(opt);
      });
      fCat.value = val;
    }

    // Subcategory modal - category
    const fSubCat = $('form-subcategory-category');
    if (fSubCat) {
      const val = fSubCat.value;
      fSubCat.innerHTML = '<option value="">Select a category</option>';
      categories.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = (c.icon || '📚') + ' ' + c.name;
        fSubCat.appendChild(opt);
      });
      fSubCat.value = val;
    }

    // Sub-subcategory modal - subcategory
    const fSubSubCat = $('form-subsubcategory-subcategory');
    if (fSubSubCat) {
      const val = fSubSubCat.value;
      fSubSubCat.innerHTML = '<option value="">Select a subcategory</option>';
      subcategories.forEach(sc => {
        const opt = document.createElement('option');
        opt.value = sc.id;
        const cat = categories.find(c => c.id === sc.category_id);
        opt.textContent = (cat ? cat.name + ' → ' : '') + sc.name;
        fSubSubCat.appendChild(opt);
      });
      fSubSubCat.value = val;
    }
  }

  function populateSubcategoryForm(categoryId) {
    const sel = $('form-subcategory');
    const val = sel.value;
    sel.innerHTML = '<option value="">Select a subcategory</option>';
    
    const filtered = subcategories.filter(sc => sc.category_id === parseInt(categoryId));
    filtered.forEach(sc => {
      const opt = document.createElement('option');
      opt.value = sc.id;
      opt.textContent = sc.name;
      sel.appendChild(opt);
    });
    sel.value = val;
    populateSubSubcategoryForm(sel.value);
  }

  function populateSubSubcategoryForm(subcategoryId) {
    const sel = $('form-subsubcategory');
    const val = sel.value;
    sel.innerHTML = '<option value="">None (optional)</option>';
    
    const filtered = subsubcategories.filter(ssc => ssc.subcategory_id === parseInt(subcategoryId));
    filtered.forEach(ssc => {
      const opt = document.createElement('option');
      opt.value = ssc.id;
      opt.textContent = ssc.name;
      sel.appendChild(opt);
    });
    sel.value = val;
  }

  // ============================================
  // UPDATE STATS
  // ============================================
  function updateStats() {
    const total = websites.length;
    const featured = websites.filter(w => w.is_featured).length;
    
    $('total-count').textContent = total;
    $('category-count').textContent = categories.length;
    $('subcategory-count').textContent = subcategories.length;
    $('subsubcategory-count').textContent = subsubcategories.length;
    $('featured-count').textContent = featured;
  }

  // ============================================
  // RENDER TABLE - WEBSITES
  // ============================================
  function renderTable() {
    if (!websites || websites.length === 0) {
      tableWrap.style.display = 'none';
      emptyEl.style.display = 'block';
      return;
    }
    
    tableWrap.style.display = 'block';
    emptyEl.style.display = 'none';
    
    let html = '';
    websites.forEach(w => {
      const score = w.reliability_score || 0;
      let scoreClass = 'low';
      if (score >= 10) scoreClass = 'perfect';
      else if (score >= 8) scoreClass = 'high';
      else if (score >= 6) scoreClass = 'medium';
      
      html += `
        <tr>
          <td>
            <div class="source-cell">
              ${w.logo_url ? `<img src="${w.logo_url}" class="source-logo" />` : `<div class="source-logo" style="display:flex;align-items:center;justify-content:center;font-size:1.2rem;">🌐</div>`}
              <div>
                <div class="source-name">${escapeHtml(w.name)}</div>
                <span class="source-url">${escapeHtml(w.url)}</span>
              </div>
            </div>
          </td>
          <td><span class="badge-category">${escapeHtml(w.category_name || 'Uncategorized')}</span></td>
          <td><span class="badge-subcategory">${escapeHtml(w.subcategory_name || '')}</span></td>
          <td>${w.subsubcategory_name ? `<span class="badge-subsubcategory">${escapeHtml(w.subsubcategory_name)}</span>` : '<span style="color:#94a3b8;font-size:0.75rem;">—</span>'}</td>
          <td><span class="badge-score ${scoreClass}">${score}/10</span></td>
          <td><span class="badge-country">${escapeHtml(w.country || 'USA')}</span></td>
          <td>
            <span class="badge-status ${w.is_active ? 'active' : 'inactive'}">${w.is_active ? 'Active' : 'Inactive'}</span>
            ${w.is_featured ? '<span class="badge-featured">⭐</span>' : ''}
          </td>
          <td>
            <div class="actions-cell">
              <button class="btn-sm btn-sm-edit" onclick="editWebsite(${w.id})">✏️ Edit</button>
              <button class="btn-sm btn-sm-verify" onclick="verifyWebsite(${w.id})">✅ Verify</button>
              <button class="btn-sm btn-sm-delete" onclick="deleteWebsite(${w.id})">🗑️</button>
            </div>
          </td>
        </tr>
      `;
    });
    tableBody.innerHTML = html;
  }

  // ============================================
  // RENDER CATEGORIES
  // ============================================
  function renderCategories() {
    const tbody = $('categories-table-body');
    if (!categories || categories.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="empty">No categories found</td></tr>';
      return;
    }
    
    let html = '';
    categories.forEach(c => {
      html += `
        <tr>
          <td style="font-size:1.5rem;">${c.icon || '📚'}</td>
          <td><strong>${escapeHtml(c.name)}</strong></td>
          <td><code>${escapeHtml(c.slug)}</code></td>
          <td>${escapeHtml(c.description || '')}</td>
          <td><span class="badge-category">${c.subcategory_count || 0}</span></td>
          <td><span class="badge-status ${c.is_active ? 'active' : 'inactive'}">${c.is_active ? 'Active' : 'Inactive'}</span></td>
          <td>
            <div class="actions-cell">
              <button class="btn-sm btn-sm-edit" onclick="editCategory(${c.id})">✏️</button>
              <button class="btn-sm btn-sm-delete" onclick="deleteCategory(${c.id})">🗑️</button>
            </div>
          </td>
        </tr>
      `;
    });
    tbody.innerHTML = html;
  }

  // ============================================
  // RENDER SUBCATEGORIES
  // ============================================
  function renderSubcategories() {
    const tbody = $('subcategories-table-body');
    const filterCat = $('subcat-filter-category').value;
    
    let filtered = subcategories;
    if (filterCat) {
      filtered = subcategories.filter(sc => sc.category_id === parseInt(filterCat));
    }
    
    if (!filtered || filtered.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="empty">No subcategories found</td></tr>';
      return;
    }
    
    let html = '';
    filtered.forEach(sc => {
      const cat = categories.find(c => c.id === sc.category_id);
      html += `
        <tr>
          <td><strong>${escapeHtml(sc.name)}</strong></td>
          <td><code>${escapeHtml(sc.slug)}</code></td>
          <td><span class="badge-category">${escapeHtml(cat ? cat.name : 'Unknown')}</span></td>
          <td><span class="badge-subcategory">${sc.subsubcategory_count || 0}</span></td>
          <td><span class="badge-subcategory">${sc.website_count || 0}</span></td>
          <td><span class="badge-status ${sc.is_active ? 'active' : 'inactive'}">${sc.is_active ? 'Active' : 'Inactive'}</span></td>
          <td>
            <div class="actions-cell">
              <button class="btn-sm btn-sm-edit" onclick="editSubcategory(${sc.id})">✏️</button>
              <button class="btn-sm btn-sm-delete" onclick="deleteSubcategory(${sc.id})">🗑️</button>
            </div>
          </td>
        </tr>
      `;
    });
    tbody.innerHTML = html;
  }

  // ============================================
  // RENDER SUB-SUBCATEGORIES
  // ============================================
  function renderSubSubcategories() {
    const tbody = $('subsubcategories-table-body');
    const filterSub = $('subsubcat-filter-subcategory').value;
    
    let filtered = subsubcategories;
    if (filterSub) {
      filtered = subsubcategories.filter(ssc => ssc.subcategory_id === parseInt(filterSub));
    }
    
    if (!filtered || filtered.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="empty">No sub-subcategories found</td></tr>';
      return;
    }
    
    let html = '';
    filtered.forEach(ssc => {
      const subcat = subcategories.find(sc => sc.id === ssc.subcategory_id);
      const cat = categories.find(c => c.id === (subcat ? subcat.category_id : null));
      html += `
        <tr>
          <td><strong>${escapeHtml(ssc.name)}</strong></td>
          <td><code>${escapeHtml(ssc.slug)}</code></td>
          <td><span class="badge-subcategory">${escapeHtml(subcat ? subcat.name : 'Unknown')}</span></td>
          <td><span class="badge-category">${escapeHtml(cat ? cat.name : 'Unknown')}</span></td>
          <td><span class="badge-subcategory">${ssc.website_count || 0}</span></td>
          <td><span class="badge-status ${ssc.is_active ? 'active' : 'inactive'}">${ssc.is_active ? 'Active' : 'Inactive'}</span></td>
          <td>
            <div class="actions-cell">
              <button class="btn-sm btn-sm-edit" onclick="editSubSubcategory(${ssc.id})">✏️</button>
              <button class="btn-sm btn-sm-delete" onclick="deleteSubSubcategory(${ssc.id})">🗑️</button>
            </div>
          </td>
        </tr>
      `;
    });
    tbody.innerHTML = html;
  }

  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

