    document.getElementById('website-form').reset();
    editingWebsiteId = null;
    document.getElementById('website-edit-id').value = '';
    document.getElementById('website-form-message').style.display = 'none';
    
    if (data) {
      editingWebsiteId = data.id;
      document.getElementById('website-modal-title').textContent = 'Edit Website';
      document.getElementById('website-edit-id').value = data.id;
      document.getElementById('website-form-category').value = data.category_id || '';
      populateSubcategoryForm(data.category_id);
      document.getElementById('website-form-subcategory').value = data.subcategory_id || '';
      populateSubSubcategoryForm(data.subcategory_id);
      document.getElementById('website-form-subsubcategory').value = data.subsubcategory_id || '';
      document.getElementById('website-form-name').value = data.name || '';
