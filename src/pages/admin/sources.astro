---
// ============================================
// TEMPLATES MANAGEMENT - Trendlin Admin
// ============================================

import AdminLayout from '../../layouts/AdminLayout.astro';

let templates = [];
let categories = [];

try {
  // Fetch templates
  const templatesResponse = await fetch(`${Astro.url.origin}/api/admin/templates`);
  if (templatesResponse.ok) {
    const data = await templatesResponse.json();
    if (data && data.templates && Array.isArray(data.templates)) {
      templates = data.templates;
    }
  }
  
  // Fetch categories
  const categoriesResponse = await fetch(`${Astro.url.origin}/api/admin/templates/categories`);
  if (categoriesResponse.ok) {
    const data = await categoriesResponse.json();
    if (data && data.categories && Array.isArray(data.categories)) {
      categories = data.categories;
    }
  }
  
} catch (error) {
  console.error('Error fetching templates:', error);
}

const categoryOptions = [
  'Health & Wellness',
  'Food & Dining',
  'Entertainment',
  'Lifestyle',
  'Technology',
  'Shopping',
  'Real Estate'
];
---

<AdminLayout title="Templates Management - Trendlin">
  
  <!-- Header -->
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 tracking-tight">
          📋 Content Templates
        </h1>
        <p class="text-sm text-gray-500 mt-1">
          Manage templates for each category ({templates.length} total)
        </p>
      </div>
      <button 
        id="openAddTemplateModal" 
        class="inline-flex items-center gap-2 px-4 py-2.5 bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-700 hover:to-blue-700 text-white text-sm font-medium rounded-xl transition-all duration-200 shadow-lg shadow-indigo-500/25 hover:shadow-indigo-500/40 hover:scale-105"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Template
      </button>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-2xl p-5 border border-gray-100">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Total Templates</p>
          <p class="text-2xl font-bold text-gray-900 mt-1">{templates.length}</p>
        </div>
        <div class="w-11 h-11 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
      </div>
      <div class="mt-3 flex items-center gap-1 text-xs text-gray-400">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500"></span>
        <span>Content templates</span>
      </div>
    </div>
    
    <div class="bg-white rounded-2xl p-5 border border-gray-100">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Categories</p>
          <p class="text-2xl font-bold text-purple-600 mt-1">{categories.length}</p>
        </div>
        <div class="w-11 h-11 bg-purple-50 rounded-xl flex items-center justify-center text-purple-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
          </svg>
        </div>
      </div>
      <div class="mt-3 flex items-center gap-1 text-xs text-gray-400">
        <span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>
        <span>Unique categories</span>
      </div>
    </div>
    
    <div class="bg-white rounded-2xl p-5 border border-gray-100">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Active</p>
          <p class="text-2xl font-bold text-green-600 mt-1">
            {templates.filter(t => t.is_active === 1).length}
          </p>
        </div>
        <div class="w-11 h-11 bg-green-50 rounded-xl flex items-center justify-center text-green-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
      </div>
      <div class="mt-3 flex items-center gap-1 text-xs text-gray-400">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
        <span>Available for use</span>
      </div>
    </div>
    
    <div class="bg-white rounded-2xl p-5 border border-gray-100">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Total Usage</p>
          <p class="text-2xl font-bold text-orange-600 mt-1">
            {templates.reduce((sum, t) => sum + (t.usage_count || 0), 0)}
          </p>
        </div>
        <div class="w-11 h-11 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          </svg>
        </div>
      </div>
      <div class="mt-3 flex items-center gap-1 text-xs text-gray-400">
        <span class="w-1.5 h-1.5 rounded-full bg-orange-500"></span>
        <span>Times used</span>
      </div>
    </div>
  </div>

  <!-- Category Breakdown -->
  <div class="mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">📊 Category Breakdown</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {categories.map(cat => (
        <div class="bg-white rounded-xl border border-gray-100 p-4 hover:shadow-md transition-all">
          <div class="flex items-center justify-between">
            <span class="font-medium text-sm text-gray-700">{cat.category}</span>
            <span class="text-sm font-bold text-indigo-600">{cat.template_count}</span>
          </div>
          <div class="mt-1 flex items-center gap-2 text-xs text-gray-400">
            <span>{cat.active_count} active</span>
            <span>•</span>
            <span>{cat.total_usage || 0} uses</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Templates Table -->
  <div>
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-4">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">All Templates</h2>
        <p class="text-sm text-gray-500">Manage your content templates by category</p>
      </div>
      <div class="flex items-center gap-3">
        <div class="relative">
          <input 
            type="text" 
            id="searchInput"
            placeholder="Search templates..." 
            class="pl-9 pr-4 py-2 text-sm border border-gray-200 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500 w-40 sm:w-48"
            oninput="filterTemplates()"
          />
          <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
        <select 
          id="categoryFilter" 
          class="px-3 py-2 text-sm border border-gray-200 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
          onchange="filterTemplates()"
        >
          <option value="">All Categories</option>
          {categoryOptions.map(cat => (
            <option key={cat} value={cat}>{cat}</option>
          ))}
        </select>
      </div>
    </div>

    <div class="bg-white rounded-2xl overflow-hidden border border-gray-100">
      {templates.length > 0 ? (
        <div class="overflow-x-auto">
          <table class="w-full" id="templatesTable">
            <thead>
              <tr class="bg-gray-50">
                <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
                <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Category</th>
                <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Description</th>
                <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Usage</th>
                <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Status</th>
                <th class="px-5 py-3.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100" id="templatesTableBody">
              {templates.map((template) => (
                <tr key={template.id} class="hover:bg-gray-50 transition-colors duration-150 template-row" data-name={template.name.toLowerCase()} data-category={template.category}>
                  <td class="px-5 py-4">
                    <div class="font-medium text-gray-900 text-sm">{template.name}</div>
                  </td>
                  <td class="px-5 py-4">
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700">
                      {template.category}
                    </span>
                  </td>
                  <td class="px-5 py-4 text-sm text-gray-500 hidden md:table-cell max-w-xs truncate">
                    {template.description || '—'}
                  </td>
                  <td class="px-5 py-4 text-sm text-gray-500 hidden lg:table-cell">
                    {template.usage_count || 0} uses
                  </td>
                  <td class="px-5 py-4 hidden sm:table-cell">
                    <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium ${
                      template.is_active === 1
                        ? 'bg-green-50 text-green-700'
                        : 'bg-gray-100 text-gray-500'
                    }`}>
                      <span class={`w-1.5 h-1.5 rounded-full ${template.is_active === 1 ? 'bg-green-500' : 'bg-gray-400'}`}></span>
                      {template.is_active === 1 ? 'Active' : 'Inactive'}
                    </span>
                  </td>
                  <td class="px-5 py-4 text-right">
                    <div class="flex items-center justify-end gap-1.5">
                      <button 
                        class="edit-template-btn px-3 py-1.5 text-xs font-medium text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all duration-200"
                        data-id={template.id}
                        data-name={template.name}
                        data-category={template.category}
                        data-content={template.content}
                        data-description={template.description || ''}
                        data-is-active={template.is_active}
                      >
                        Edit
                      </button>
                      <span class="text-gray-300">|</span>
                      <button 
                        class="delete-template-btn px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 rounded-lg transition-all duration-200"
                        data-id={template.id}
                      >
                        Delete
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="py-12 text-center">
          <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <p class="text-gray-500 text-sm">No templates yet</p>
          <p class="text-gray-400 text-xs mt-1">Click "Add Template" to create your first one</p>
        </div>
      )}
    </div>

    {templates.length > 0 && (
      <div class="mt-4 flex items-center justify-between text-sm text-gray-400">
        <span>Showing <span id="visibleCount">{templates.length}</span> template{templates.length > 1 ? 's' : ''}</span>
        <div class="flex items-center gap-2">
          <span class="text-xs text-gray-400">
            {templates.filter(t => t.is_active === 1).length} active
          </span>
        </div>
      </div>
    )}
  </div>

  <!-- ============================================ -->
  <!-- ADD TEMPLATE MODAL -->
  <!-- ============================================ -->
  <div id="addTemplateModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden p-4">
    <div class="bg-white rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-hidden flex flex-col">
      <div class="flex items-center justify-between p-6 border-b border-gray-200">
        <h2 class="text-xl font-bold text-gray-900">Add New Template</h2>
        <button onclick="closeAddTemplateModal()" class="text-gray-500 hover:text-gray-700 text-2xl">&times;</button>
      </div>
      <div class="p-6 overflow-y-auto flex-1">
        <form id="addTemplateForm" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Template Name *</label>
            <input 
              type="text" 
              id="templateName" 
              required
              placeholder="e.g., Health & Wellness - Basic"
              class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Category *</label>
            <select 
              id="templateCategory" 
              required
              class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500"
            >
              <option value="">Select a category</option>
              {categoryOptions.map(cat => (
                <option key={cat} value={cat}>{cat}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Description</label>
            <input 
              type="text" 
              id="templateDescription" 
              placeholder="Brief description of this template"
              class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">HTML Content *</label>
            <textarea 
              id="templateContent" 
              rows="8"
              required
              placeholder="<h1>Your heading</h1><p>Your content...</p>"
              class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono text-sm resize-none"
            ></textarea>
            <p class="mt-1 text-xs text-gray-400">Enter HTML content for the template</p>
          </div>
          <div>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="templateActive" checked class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
              <span class="text-sm font-medium text-gray-700">Active (available for use)</span>
            </label>
          </div>
        </form>
      </div>
      <div class="flex items-center justify-end gap-3 p-6 border-t border-gray-200 bg-gray-50">
        <button 
          onclick="closeAddTemplateModal()" 
          class="px-6 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-800 border border-gray-200 rounded-xl hover:bg-gray-100"
        >
          Cancel
        </button>
        <button 
          type="submit"
          form="addTemplateForm"
          id="saveTemplateBtn"
          class="px-6 py-2.5 bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-700 hover:to-blue-700 text-white font-medium rounded-xl shadow-lg shadow-indigo-500/25"
        >
          Save Template
        </button>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- EDIT TEMPLATE MODAL -->
  <!-- ============================================ -->
  <div id="editTemplateModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden p-4">
    <div class="bg-white rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-hidden flex flex-col">
      <div class="flex items-center justify-between p-6 border-b border-gray-200">
        <h2 class="text-xl font-bold text-gray-900">Edit Template</h2>
        <button onclick="closeEditTemplateModal()" class="text-gray-500 hover:text-gray-700 text-2xl">&times;</button>
      </div>
      <div class="p-6 overflow-y-auto flex-1">
        <form id="editTemplateForm" class="space-y-4">
          <input type="hidden" id="editTemplateId" />
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Template Name *</label>
            <input 
              type="text" 
              id="editTemplateName" 
              required
              class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Category *</label>
            <select 
              id="editTemplateCategory" 
              required
              class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500"
            >
              {categoryOptions.map(cat => (
                <option key={cat} value={cat}>{cat}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Description</label>
            <input 
              type="text" 
              id="editTemplateDescription" 
              class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">HTML Content *</label>
            <textarea 
              id="editTemplateContent" 
              rows="8"
              required
              class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono text-sm resize-none"
            ></textarea>
          </div>
          <div>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="editTemplateActive" class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
              <span class="text-sm font-medium text-gray-700">Active (available for use)</span>
            </label>
          </div>
        </form>
      </div>
      <div class="flex items-center justify-end gap-3 p-6 border-t border-gray-200 bg-gray-50">
        <button 
          onclick="closeEditTemplateModal()" 
          class="px-6 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-800 border border-gray-200 rounded-xl hover:bg-gray-100"
        >
          Cancel
        </button>
        <button 
          type="submit"
          form="editTemplateForm"
          id="updateTemplateBtn"
          class="px-6 py-2.5 bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-700 hover:to-blue-700 text-white font-medium rounded-xl shadow-lg shadow-indigo-500/25"
        >
          Update Template
        </button>
      </div>
    </div>
  </div>

</AdminLayout>

<!-- ============================================ -->
<!-- JAVASCRIPT -->
<!-- ============================================ -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    
    // ============================================
    // FILTER TEMPLATES
    // ============================================
    window.filterTemplates = function() {
      const search = document.getElementById('searchInput').value.toLowerCase();
      const category = document.getElementById('categoryFilter').value;
      const rows = document.querySelectorAll('.template-row');
      let visible = 0;
      
      rows.forEach(row => {
        const name = row.dataset.name || '';
        const rowCategory = row.dataset.category || '';
        let show = true;
        
        if (search && !name.includes(search)) {
          show = false;
        }
        
        if (category && rowCategory !== category) {
          show = false;
        }
        
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      
      document.getElementById('visibleCount').textContent = visible;
    };
    
    // ============================================
    // ADD TEMPLATE MODAL
    // ============================================
    document.getElementById('openAddTemplateModal').addEventListener('click', function() {
      document.getElementById('addTemplateModal').classList.remove('hidden');
      document.getElementById('addTemplateForm').reset();
      document.getElementById('templateActive').checked = true;
    });
    
    window.closeAddTemplateModal = function() {
      document.getElementById('addTemplateModal').classList.add('hidden');
    };
    
    document.getElementById('addTemplateModal').addEventListener('click', function(e) {
      if (e.target === this) closeAddTemplateModal();
    });
    
    // ============================================
    // EDIT TEMPLATE MODAL
    // ============================================
    window.closeEditTemplateModal = function() {
      document.getElementById('editTemplateModal').classList.add('hidden');
    };
    
    document.getElementById('editTemplateModal').addEventListener('click', function(e) {
      if (e.target === this) closeEditTemplateModal();
    });
    
    // ============================================
    // SAVE TEMPLATE
    // ============================================
    document.getElementById('addTemplateForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const name = document.getElementById('templateName').value.trim();
      const category = document.getElementById('templateCategory').value;
      const description = document.getElementById('templateDescription').value.trim();
      const content = document.getElementById('templateContent').value.trim();
      const is_active = document.getElementById('templateActive').checked ? 1 : 0;
      
      if (!name || !category || !content) {
        alert('Please fill in all required fields');
        return;
      }
      
      const saveBtn = document.getElementById('saveTemplateBtn');
      const originalText = saveBtn.textContent;
      saveBtn.textContent = 'Saving...';
      saveBtn.disabled = true;
      
      try {
        console.log('📤 Creating template:', { name, category, description, contentLength: content.length });
        
        const response = await fetch('/api/admin/templates', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ name, category, description, content, is_active })
        });
        
        if (!response.ok) {
          const errorText = await response.text();
          console.error('❌ Response error:', errorText);
          let errorMsg = 'Failed to save template';
          try {
            const errorJson = JSON.parse(errorText);
            errorMsg = errorJson.error || errorMsg;
          } catch (parseError) {
            errorMsg = `Server error: ${response.status}`;
          }
          throw new Error(errorMsg);
        }
        
        const result = await response.json();
        console.log('✅ Create response:', result);
        
        if (!result.success) {
          throw new Error(result.error || 'Failed to save template');
        }
        
        alert('✅ Template saved successfully!');
        closeAddTemplateModal();
        window.location.reload();
        
      } catch (error) {
        console.error('❌ Error saving template:', error);
        alert('❌ Failed to save template: ' + error.message);
      } finally {
        saveBtn.textContent = originalText;
        saveBtn.disabled = false;
      }
    });
    
    // ============================================
    // EDIT TEMPLATE - Open Modal
    // ============================================
    document.querySelectorAll('.edit-template-btn').forEach(function(button) {
      button.addEventListener('click', function() {
        const id = this.dataset.id;
        const name = this.dataset.name;
        const category = this.dataset.category;
        const content = this.dataset.content;
        const description = this.dataset.description;
        const isActive = this.dataset.isActive;
        
        document.getElementById('editTemplateId').value = id;
        document.getElementById('editTemplateName').value = name;
        document.getElementById('editTemplateCategory').value = category;
        document.getElementById('editTemplateContent').value = content;
        document.getElementById('editTemplateDescription').value = description;
        document.getElementById('editTemplateActive').checked = isActive == 1;
        
        document.getElementById('editTemplateModal').classList.remove('hidden');
      });
    });
    
    // ============================================
    // UPDATE TEMPLATE
    // ============================================
    document.getElementById('editTemplateForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const id = document.getElementById('editTemplateId').value;
      const name = document.getElementById('editTemplateName').value.trim();
      const category = document.getElementById('editTemplateCategory').value;
      const description = document.getElementById('editTemplateDescription').value.trim();
      const content = document.getElementById('editTemplateContent').value.trim();
      const is_active = document.getElementById('editTemplateActive').checked ? 1 : 0;
      
      if (!name || !category || !content) {
        alert('Please fill in all required fields');
        return;
      }
      
      const updateBtn = document.getElementById('updateTemplateBtn');
      const originalText = updateBtn.textContent;
      updateBtn.textContent = 'Updating...';
      updateBtn.disabled = true;
      
      try {
        console.log('📤 Updating template ID:', id);
        
        const response = await fetch(`/api/admin/templates/${id}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ name, category, description, content, is_active })
        });
        
        if (!response.ok) {
          const errorText = await response.text();
          console.error('❌ Response error:', errorText);
          let errorMsg = 'Failed to update template';
          try {
            const errorJson = JSON.parse(errorText);
            errorMsg = errorJson.error || errorMsg;
          } catch (parseError) {
            errorMsg = `Server error: ${response.status}`;
          }
          throw new Error(errorMsg);
        }
        
        const result = await response.json();
        console.log('✅ Update response:', result);
        
        if (!result.success) {
          throw new Error(result.error || 'Failed to update template');
        }
        
        alert('✅ Template updated successfully!');
        closeEditTemplateModal();
        window.location.reload();
        
      } catch (error) {
        console.error('❌ Error updating template:', error);
        alert('❌ Failed to update template: ' + error.message);
      } finally {
        updateBtn.textContent = originalText;
        updateBtn.disabled = false;
      }
    });
    
    // ============================================
    // DELETE TEMPLATE
    // ============================================
    document.querySelectorAll('.delete-template-btn').forEach(function(button) {
      button.addEventListener('click', async function(e) {
        e.preventDefault();
        
        const templateId = this.dataset.id;
        
        if (!confirm('Are you sure you want to delete this template? This action cannot be undone.')) {
          return;
        }
        
        const originalText = this.textContent;
        this.textContent = 'Deleting...';
        this.disabled = true;
        this.classList.add('opacity-50');
        
        try {
          console.log('🗑️ Deleting template ID:', templateId);
          
          const response = await fetch(`/api/admin/templates/${templateId}`, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json'
            }
          });
          
          if (!response.ok) {
            const errorText = await response.text();
            console.error('❌ Response error:', errorText);
            let errorMsg = 'Failed to delete template';
            try {
              const errorJson = JSON.parse(errorText);
              errorMsg = errorJson.error || errorMsg;
            } catch (parseError) {
              errorMsg = `Server error: ${response.status}`;
            }
            throw new Error(errorMsg);
          }
          
          const result = await response.json();
          console.log('✅ Delete response:', result);
          
          if (!result.success) {
            throw new Error(result.error || 'Failed to delete template');
          }
          
          alert('✅ Template deleted successfully!');
          window.location.reload();
          
        } catch (error) {
          console.error('❌ Error deleting template:', error);
          alert('❌ Failed to delete template: ' + error.message);
          
          this.textContent = originalText;
          this.disabled = false;
          this.classList.remove('opacity-50');
        }
      });
    });
    
  });
</script>

