---
// ============================================
// SOURCES MANAGEMENT - Trendlin Admin
// ============================================

import AdminLayout from '../../layouts/AdminLayout.astro';

let masterSources = [];
let stateSources = [];
let categories = [];
let states = [];
let error = null;

try {
  // Fetch sources
  const sourcesResponse = await fetch(`${Astro.url.origin}/api/admin/sources`);
  
  if (sourcesResponse.ok) {
    const data = await sourcesResponse.json();
    console.log('📥 Sources API Response:', data);
    
    if (data && data.success) {
      masterSources = data.master || [];
      stateSources = data.state || [];
      console.log(`✅ Loaded ${masterSources.length} master sources and ${stateSources.length} state sources`);
    } else {
      error = data?.error || 'Failed to load sources';
      console.error('❌ API Error:', error);
    }
  } else {
    error = `Server error: ${sourcesResponse.status}`;
    console.error('❌ HTTP Error:', sourcesResponse.status);
  }
  
  // Fetch categories
  const categoriesResponse = await fetch(`${Astro.url.origin}/api/admin/sources/categories`);
  if (categoriesResponse.ok) {
    const data = await categoriesResponse.json();
    if (data && data.success) {
      categories = data.categories || [];
      console.log(`✅ Loaded ${categories.length} categories`);
    }
  }
  
  // Fetch states
  const statesResponse = await fetch(`${Astro.url.origin}/api/admin/sources/states`);
  if (statesResponse.ok) {
    const data = await statesResponse.json();
    if (data && data.success) {
      states = data.states || [];
      console.log(`✅ Loaded ${states.length} states`);
    }
  }
  
} catch (err) {
  console.error('❌ Error fetching sources:', err);
  error = err.message;
}

const totalSources = masterSources.length + stateSources.length;
const totalMasterSources = masterSources.length;
const totalStateSources = stateSources.length;
const totalCategories = categories.length;

// Debug: Log the actual data
console.log('📊 Final Data:', {
  totalSources,
  masterSources: masterSources.length,
  stateSources: stateSources.length,
  categories: categories.length,
  states: states.length
});
---

<AdminLayout title="Sources Management - Trendlin">
  
  <!-- Debug Info -->
  <div class="mb-4 p-4 bg-blue-50 border border-blue-200 rounded-xl text-blue-700 text-sm">
    <strong>Debug Info:</strong> 
    Total: {totalSources}, 
    Master: {masterSources.length}, 
    State: {stateSources.length}, 
    Categories: {categories.length}, 
    States: {states.length}
  </div>

  <!-- Error Alert -->
  {error && (
    <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
      <strong>Error:</strong> {error}
    </div>
  )}

  <!-- Header -->
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 tracking-tight">
          📚 Sources Management
        </h1>
        <p class="text-sm text-gray-500 mt-1">
          Manage trusted sources across all categories ({totalSources} total)
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <button 
          id="addMasterBtn" 
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-700 hover:to-blue-700 text-white text-sm font-medium rounded-xl transition-all duration-200 shadow-lg shadow-cyan-500/25 hover:shadow-cyan-500/40 hover:scale-105"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Universal Source
        </button>
        <button 
          id="addStateBtn" 
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-gradient-to-r from-teal-600 to-green-600 hover:from-teal-700 hover:to-green-700 text-white text-sm font-medium rounded-xl transition-all duration-200 shadow-lg shadow-teal-500/25 hover:shadow-teal-500/40 hover:scale-105"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          State Source
        </button>
      </div>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-2xl p-5 border border-gray-100 hover:shadow-lg transition-all duration-200">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Total Sources</p>
          <p class="text-2xl font-bold text-gray-900 mt-1">{totalSources}</p>
        </div>
        <div class="w-11 h-11 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
      </div>
      <div class="mt-3 flex items-center gap-1 text-xs text-gray-400">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
        <span>All sources</span>
      </div>
    </div>

    <div class="bg-white rounded-2xl p-5 border border-gray-100 hover:shadow-lg transition-all duration-200">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Universal</p>
          <p class="text-2xl font-bold text-cyan-600 mt-1">{totalMasterSources}</p>
        </div>
        <div class="w-11 h-11 bg-cyan-50 rounded-xl flex items-center justify-center text-cyan-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
      </div>
      <div class="mt-3 flex items-center gap-1 text-xs text-gray-400">
        <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
        <span>Global sources</span>
      </div>
    </div>

    <div class="bg-white rounded-2xl p-5 border border-gray-100 hover:shadow-lg transition-all duration-200">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">State</p>
          <p class="text-2xl font-bold text-teal-600 mt-1">{totalStateSources}</p>
        </div>
        <div class="w-11 h-11 bg-teal-50 rounded-xl flex items-center justify-center text-teal-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
      </div>
      <div class="mt-3 flex items-center gap-1 text-xs text-gray-400">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
        <span>State-specific</span>
      </div>
    </div>

    <div class="bg-white rounded-2xl p-5 border border-gray-100 hover:shadow-lg transition-all duration-200">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Categories</p>
          <p class="text-2xl font-bold text-purple-600 mt-1">{totalCategories}</p>
        </div>
        <div class="w-11 h-11 bg-purple-50 rounded-xl flex items-center justify-center text-purple-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
          </svg>
        </div>
      </div>
      <div class="mt-3 flex items-center gap-1 text-xs text-gray-400">
        <span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>
        <span>Available categories</span>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="border-b border-gray-200 mb-6">
    <nav class="flex gap-6">
      <button onclick="switchTab('master')" id="masterTab" class="py-3 px-1 border-b-2 border-cyan-600 text-cyan-600 font-medium text-sm transition-colors flex items-center gap-2">
        🌐 Universal Sources
        <span class="bg-cyan-100 text-cyan-700 text-xs px-2 py-0.5 rounded-full">{totalMasterSources}</span>
      </button>
      <button onclick="switchTab('state')" id="stateTab" class="py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm transition-colors flex items-center gap-2">
        🏛️ State Sources
        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-0.5 rounded-full">{totalStateSources}</span>
      </button>
    </nav>
  </div>

  <!-- Search & Filter -->
  <div class="flex flex-wrap items-center gap-3 mb-4">
    <div class="relative flex-1 min-w-[200px]">
      <input 
        type="text" 
        id="searchInput" 
        placeholder="Search sources..." 
        class="w-full pl-9 pr-4 py-2 text-sm border border-gray-200 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-cyan-500"
        oninput="filterSources()"
      />
      <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </div>
    
    <!-- Category Filter -->
    <select 
      id="categoryFilter" 
      class="px-3 py-2 text-sm border border-gray-200 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-cyan-500"
      onchange="filterSources()"
    >
      <option value="">All Categories</option>
      {categories.map(cat => (
        <option key={cat.id} value={cat.id}>{cat.icon} {cat.name}</option>
      ))}
    </select>

    <!-- State Filter (only for state tab) -->
    <select 
      id="stateFilter" 
      class="px-3 py-2 text-sm border border-gray-200 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-cyan-500 hidden"
      onchange="filterSources()"
    >
      <option value="">All States</option>
      {states.map(state => (
        <option key={state.id} value={state.id}>{state.name}</option>
      ))}
    </select>

    <button onclick="window.location.reload()" class="px-3 py-2 text-sm bg-gray-100 hover:bg-gray-200 rounded-xl transition-colors flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
      </svg>
      Refresh
    </button>

    <div class="text-sm text-gray-400 ml-auto">
      <span id="visibleCount">0</span> sources
    </div>
  </div>

  <!-- Master Sources Grid -->
  <div id="masterSources">
    <div id="masterSourcesList" class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-4">
      <!-- Populated by JavaScript -->
    </div>
  </div>

  <!-- State Sources Grid -->
  <div id="stateSources" class="hidden">
    <div id="stateSourcesList" class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-4">
      <!-- Populated by JavaScript -->
    </div>
  </div>

  <!-- Empty State -->
  <div id="emptyState" class="hidden text-center py-16 bg-white rounded-2xl border border-gray-100">
    <div class="text-6xl mb-4">📭</div>
    <h3 class="text-xl font-semibold text-gray-700 mb-2">No sources found</h3>
    <p class="text-gray-500">Try adjusting your filters or add a new source</p>
    <div class="mt-4 flex items-center justify-center gap-3">
      <button onclick="document.getElementById('addMasterBtn').click()" class="px-4 py-2 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg text-sm font-medium transition-colors">Add Universal Source</button>
      <button onclick="document.getElementById('addStateBtn').click()" class="px-4 py-2 bg-teal-600 hover:bg-teal-700 text-white rounded-lg text-sm font-medium transition-colors">Add State Source</button>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- SOURCE MODAL (Add/Edit) -->
  <!-- ============================================ -->
  <div id="sourceModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden p-4">
    <div class="bg-white rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
      <div class="sticky top-0 bg-white z-10 flex justify-between items-center p-6 border-b border-gray-200">
        <h2 id="modalTitle" class="text-xl font-bold text-gray-900">Add Source</h2>
        <button type="button" onclick="closeModal()" class="text-gray-500 hover:text-gray-700 text-2xl">&times;</button>
      </div>
      <div class="p-6">
        <form id="sourceForm" class="space-y-4" onsubmit="return false;">
          <input type="hidden" id="editId" />
          <input type="hidden" id="editType" />
          
          <!-- Source Name -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Source Name *</label>
            <input 
              type="text" 
              id="sourceName" 
              required 
              placeholder="e.g., Los Angeles Times"
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500"
            />
          </div>
          
          <!-- URL -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">URL *</label>
            <input 
              type="url" 
              id="sourceUrl" 
              required 
              placeholder="https://..."
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500"
            />
          </div>
          
          <!-- Category -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Category *</label>
            <select 
              id="sourceCategory" 
              required 
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500"
            >
              <option value="">Select Category</option>
              {categories.map(cat => (
                <option key={cat.id} value={cat.id}>{cat.icon} {cat.name}</option>
              ))}
            </select>
          </div>
          
          <!-- State (only for state sources) -->
          <div id="stateSelectWrapper" class="hidden">
            <label class="block text-sm font-medium text-gray-700 mb-1.5">State *</label>
            <select 
              id="sourceState" 
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500"
            >
              <option value="">Select State</option>
              {states.map(state => (
                <option key={state.id} value={state.id}>{state.name}</option>
              ))}
            </select>
          </div>
          
          <!-- Source Type -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Source Type</label>
            <select 
              id="sourceType" 
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500"
            >
              <option value="official">Official</option>
              <option value="review">Review</option>
              <option value="news">News</option>
              <option value="community">Community</option>
            </select>
          </div>
          
          <!-- Description -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Description</label>
            <textarea 
              id="sourceDescription" 
              rows="2" 
              placeholder="Brief description of this source..."
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500"
            ></textarea>
          </div>
          
          <!-- Logo URL -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Logo URL</label>
            <input 
              type="url" 
              id="sourceLogo" 
              placeholder="https://..."
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500"
            />
          </div>
          
          <!-- State Extra Fields -->
          <div id="stateExtraFields" class="hidden space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Address</label>
              <input 
                type="text" 
                id="sourceAddress" 
                placeholder="123 Main St, City, State"
                class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Phone</label>
              <input 
                type="tel" 
                id="sourcePhone" 
                placeholder="(555) 123-4567"
                class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
              <input 
                type="email" 
                id="sourceEmail" 
                placeholder="contact@example.com"
                class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500"
              />
            </div>
          </div>
          
          <!-- Active & Featured -->
          <div class="flex items-center gap-6">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="sourceActive" checked class="w-4 h-4 rounded border-gray-300 text-cyan-600 focus:ring-cyan-500" />
              <span class="text-sm font-medium text-gray-700">Active</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="sourceFeatured" class="w-4 h-4 rounded border-gray-300 text-yellow-600 focus:ring-yellow-500" />
              <span class="text-sm font-medium text-gray-700">⭐ Featured</span>
            </label>
          </div>
          
          <!-- Message -->
          <div id="modalMessage" class="hidden p-3 rounded-lg text-sm"></div>
          
          <!-- Submit -->
          <button 
            type="button"
            id="saveSourceBtn"
            class="w-full py-2.5 bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-700 hover:to-blue-700 text-white font-medium rounded-xl transition-all duration-200 shadow-lg shadow-cyan-500/25"
          >
            Save Source
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-6 right-6 max-w-sm p-4 rounded-xl shadow-2xl z-50 transform transition-all duration-500 translate-y-20 opacity-0 hidden"></div>

  <!-- Loading Overlay -->
  <div id="loadingOverlay" class="fixed inset-0 bg-black/30 flex items-center justify-center z-40 hidden">
    <div class="bg-white rounded-2xl p-8 flex flex-col items-center gap-3 shadow-2xl">
      <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-cyan-600"></div>
      <p class="text-sm text-gray-600 font-medium">Loading...</p>
    </div>
  </div>

</AdminLayout>

<!-- ============================================ -->
<!-- JAVASCRIPT - COMPLETE WITH FORCED RENDER -->
<!-- ============================================ -->
<script>
  // ============================================
  // DATA - Parse from server
  // ============================================
  const masterData = JSON.parse(`[${masterSources.map(s => JSON.stringify(s)).join(',')}]`);
  const stateData = JSON.parse(`[${stateSources.map(s => JSON.stringify(s)).join(',')}]`);
  const categoriesData = JSON.parse(`[${categories.map(c => JSON.stringify(c)).join(',')}]`);
  const statesData = JSON.parse(`[${states.map(s => JSON.stringify(s)).join(',')}]`);

  console.log('📊 Master Data:', masterData);
  console.log('📊 State Data:', stateData);
  console.log('📊 Categories:', categoriesData);
  console.log('📊 States:', statesData);

  let allSources = { master: masterData, state: stateData };
  let filteredSources = { master: [], state: [] };
  let currentTab = 'master';
  let isSubmitting = false;

  // ============================================
  // DOM READY
  // ============================================
  document.addEventListener('DOMContentLoaded', function() {
    console.log('🚀 DOM Ready - Setting up event listeners');
    console.log('📊 Total sources:', allSources.master.length + allSources.state.length);
    
    // Add click handlers
    document.getElementById('addMasterBtn').addEventListener('click', function() {
      console.log('🔵 Add Master Source clicked');
      openModal('master');
    });
    
    document.getElementById('addStateBtn').addEventListener('click', function() {
      console.log('🟢 Add State Source clicked');
      openModal('state');
    });
    
    // Save button handler
    document.getElementById('saveSourceBtn').addEventListener('click', function() {
      console.log('💾 Save button clicked');
      handleFormSubmit();
    });
    
    // Close modal on background click
    document.getElementById('sourceModal').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });
    
    // Initial render - FORCE RENDER
    switchTab('master');
    
    // Force render after a short delay
    setTimeout(function() {
      console.log('🔄 Force rendering...');
      filterSources();
    }, 100);
  });

  // ============================================
  // SWITCH TAB
  // ============================================
  window.switchTab = function(tab) {
    console.log('📑 Switching to tab:', tab);
    currentTab = tab;
    
    document.getElementById('masterTab').className = tab === 'master' 
      ? 'py-3 px-1 border-b-2 border-cyan-600 text-cyan-600 font-medium text-sm transition-colors flex items-center gap-2'
      : 'py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm transition-colors flex items-center gap-2';
    
    document.getElementById('stateTab').className = tab === 'state'
      ? 'py-3 px-1 border-b-2 border-teal-600 text-teal-600 font-medium text-sm transition-colors flex items-center gap-2'
      : 'py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm transition-colors flex items-center gap-2';
    
    document.getElementById('masterSources').className = tab === 'master' ? '' : 'hidden';
    document.getElementById('stateSources').className = tab === 'state' ? '' : 'hidden';
    
    const stateFilter = document.getElementById('stateFilter');
    if (tab === 'state') {
      stateFilter.classList.remove('hidden');
    } else {
      stateFilter.classList.add('hidden');
    }
    
    filterSources();
  };

  // ============================================
  // FILTER SOURCES
  // ============================================
  window.filterSources = function() {
    const search = document.getElementById('searchInput').value.toLowerCase();
    const category = document.getElementById('categoryFilter').value;
    const state = document.getElementById('stateFilter').value;
    
    console.log('🔍 Filtering - Search:', search, 'Category:', category, 'State:', state);
    
    if (currentTab === 'master') {
      filteredSources.master = allSources.master.filter(source => {
        const matchSearch = source.name.toLowerCase().includes(search) || 
                           (source.description && source.description.toLowerCase().includes(search));
        const matchCategory = !category || source.category_id == category;
        return matchSearch && matchCategory;
      });
      console.log('✅ Filtered Master:', filteredSources.master.length);
      renderSources('master');
    } else {
      filteredSources.state = allSources.state.filter(source => {
        const matchSearch = source.name.toLowerCase().includes(search) || 
                           (source.description && source.description.toLowerCase().includes(search));
        const matchCategory = !category || source.category_id == category;
        const matchState = !state || source.state_id == state;
        return matchSearch && matchCategory && matchState;
      });
      console.log('✅ Filtered State:', filteredSources.state.length);
      renderSources('state');
    }
  };

  // ============================================
  // RENDER SOURCES
  // ============================================
  function renderSources(type) {
    const container = document.getElementById(type === 'master' ? 'masterSourcesList' : 'stateSourcesList');
    const sources = type === 'master' ? filteredSources.master : filteredSources.state;
    const empty = document.getElementById('emptyState');
    
    console.log(`🎨 Rendering ${type} sources:`, sources.length);
    
    if (!container) {
      console.error('❌ Container not found for type:', type);
      return;
    }
    
    if (sources.length === 0) {
      container.innerHTML = '';
      empty.classList.remove('hidden');
      document.getElementById('visibleCount').textContent = '0';
      console.log('📭 No sources to display');
      return;
    }
    
    empty.classList.add('hidden');
    document.getElementById('visibleCount').textContent = sources.length;
    
    container.innerHTML = sources.map(source => {
      const categoryIcon = categoriesData.find(c => c.id === source.category_id)?.icon || '📁';
      
      return `
      <div class="bg-white rounded-xl border border-gray-100 p-5 hover:shadow-lg transition-all duration-200 group">
        <div class="flex items-start justify-between">
          <div class="flex-1 min-w-0">
            <div class="flex items-start gap-3">
              ${source.logo_url ? `
                <img src="${source.logo_url}" alt="${source.name}" class="w-10 h-10 rounded-lg object-cover flex-shrink-0" />
              ` : `
                <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-cyan-100 to-blue-100 flex items-center justify-center text-xl flex-shrink-0">
                  ${categoryIcon}
                </div>
              `}
              <div class="min-w-0">
                <h3 class="font-semibold text-gray-900 truncate">${source.name}</h3>
                <div class="flex items-center gap-2 mt-1 flex-wrap">
                  <span class="text-xs px-2 py-0.5 bg-blue-50 text-blue-700 rounded-full">${source.category_name || 'Uncategorized'}</span>
                  ${source.source_type ? `<span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-600 rounded-full">${source.source_type}</span>` : ''}
                  ${source.state_name ? `<span class="text-xs px-2 py-0.5 bg-teal-50 text-teal-700 rounded-full">${source.state_code || source.state_name}</span>` : ''}
                  ${source.is_featured ? `<span class="text-xs px-2 py-0.5 bg-yellow-50 text-yellow-700 rounded-full">⭐ Featured</span>` : ''}
                  ${source.is_active === 0 ? `<span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full">Inactive</span>` : ''}
                </div>
              </div>
            </div>
            ${source.description ? `<p class="text-sm text-gray-500 mt-2 line-clamp-2">${source.description}</p>` : ''}
            <div class="mt-2 flex items-center gap-3">
              <a href="${source.url}" target="_blank" class="text-xs text-blue-600 hover:text-blue-800 truncate">${source.url}</a>
              ${source.address ? `<span class="text-xs text-gray-400">📍 ${source.address}</span>` : ''}
            </div>
          </div>
          <div class="flex items-center gap-1 ml-3 flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
            <button onclick="editSource(${source.id}, '${source.source_type || type}')" class="p-1.5 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Edit">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            </button>
            <button onclick="deleteSource(${source.id}, '${source.source_type || type}')" class="p-1.5 text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Delete">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    `}).join('');
    
    console.log(`✅ Rendered ${sources.length} sources in ${type} view`);
  }

  // ============================================
  // OPEN MODAL
  // ============================================
  window.openModal = function(type, data = null) {
    console.log('📝 Opening modal for:', type, data);
    
    const modal = document.getElementById('sourceModal');
    const title = document.getElementById('modalTitle');
    const stateWrapper = document.getElementById('stateSelectWrapper');
    const stateExtra = document.getElementById('stateExtraFields');
    const form = document.getElementById('sourceForm');
    
    form.reset();
    document.getElementById('editId').value = '';
    document.getElementById('editType').value = type;
    document.getElementById('sourceActive').checked = true;
    document.getElementById('sourceFeatured').checked = false;
    document.getElementById('modalMessage').className = 'hidden p-3 rounded-lg text-sm';
    
    if (type === 'master') {
      title.textContent = data ? 'Edit Universal Source' : 'Add Universal Source';
      stateWrapper.classList.add('hidden');
      stateExtra.classList.add('hidden');
      document.getElementById('sourceState').removeAttribute('required');
    } else {
      title.textContent = data ? 'Edit State Source' : 'Add State Source';
      stateWrapper.classList.remove('hidden');
      stateExtra.classList.remove('hidden');
      document.getElementById('sourceState').setAttribute('required', 'required');
    }
    
    if (data) {
      document.getElementById('editId').value = data.id;
      document.getElementById('sourceName').value = data.name || '';
      document.getElementById('sourceUrl').value = data.url || '';
      document.getElementById('sourceCategory').value = data.category_id || '';
      document.getElementById('sourceType').value = data.source_type || 'official';
      document.getElementById('sourceDescription').value = data.description || '';
      document.getElementById('sourceLogo').value = data.logo_url || '';
      document.getElementById('sourceActive').checked = data.is_active === 1;
      document.getElementById('sourceFeatured').checked = data.is_featured === 1;
      
      if (type === 'state') {
        document.getElementById('sourceState').value = data.state_id || '';
        document.getElementById('sourceAddress').value = data.address || '';
        document.getElementById('sourcePhone').value = data.phone || '';
        document.getElementById('sourceEmail').value = data.email || '';
      }
    }
    
    modal.classList.remove('hidden');
    modal.style.display = 'flex';
  };

  // ============================================
  // CLOSE MODAL
  // ============================================
  window.closeModal = function() {
    console.log('🔒 Closing modal');
    const modal = document.getElementById('sourceModal');
    modal.classList.add('hidden');
    modal.style.display = 'none';
  };

  // ============================================
  // EDIT SOURCE
  // ============================================
  window.editSource = function(id, type) {
    console.log('✏️ Editing source:', id, type);
    const source = allSources[type === 'master' ? 'master' : 'state'].find(s => s.id === id);
    if (source) {
      openModal(type === 'master' ? 'master' : 'state', source);
    } else {
      showToast('Source not found', 'error');
    }
  };

  // ============================================
  // DELETE SOURCE
  // ============================================
  window.deleteSource = async function(id, type) {
    console.log('🗑️ Deleting source:', id, type);
    
    if (!confirm('Are you sure you want to delete this source? This action cannot be undone.')) {
      return;
    }
    
    showLoading(true);
    
    try {
      const response = await fetch(`/api/admin/sources/${id}`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type })
      });
      
      const result = await response.json();
      
      if (!response.ok) {
        throw new Error(result.error || `Server error: ${response.status}`);
      }
      
      if (result.success) {
        showToast('✅ Source deleted successfully', 'success');
        window.location.reload();
      } else {
        showToast('❌ Failed to delete source: ' + (result.error || 'Unknown error'), 'error');
      }
    } catch (error) {
      console.error('❌ Error deleting source:', error);
      showToast('❌ Failed to delete source: ' + error.message, 'error');
    } finally {
      showLoading(false);
    }
  };

  // ============================================
  // HANDLE FORM SUBMIT
  // ============================================
  async function handleFormSubmit() {
    console.log('📤 Handling form submit...');
    
    if (isSubmitting) {
      console.log('⏳ Already submitting, please wait...');
      return;
    }
    
    const id = document.getElementById('editId').value;
    const type = document.getElementById('editType').value;
    const name = document.getElementById('sourceName').value.trim();
    const url = document.getElementById('sourceUrl').value.trim();
    const category_id = document.getElementById('sourceCategory').value;
    const description = document.getElementById('sourceDescription').value.trim();
    const source_type = document.getElementById('sourceType').value;
    const logo_url = document.getElementById('sourceLogo').value.trim();
    const is_active = document.getElementById('sourceActive').checked ? 1 : 0;
    const is_featured = document.getElementById('sourceFeatured').checked ? 1 : 0;
    
    console.log('📝 Form data:', { id, type, name, url, category_id, description, source_type, logo_url, is_active, is_featured });
    
    if (!name || !url || !category_id) {
      showModalMessage('Name, URL, and category are required', 'error');
      return;
    }
    
    let data = { type, name, url, category_id, description, source_type, logo_url, is_active, is_featured };
    
    if (type === 'state') {
      const state_id = document.getElementById('sourceState').value;
      const address = document.getElementById('sourceAddress').value.trim();
      const phone = document.getElementById('sourcePhone').value.trim();
      const email = document.getElementById('sourceEmail').value.trim();
      
      if (!state_id) {
        showModalMessage('State is required for state sources', 'error');
        return;
      }
      
      data = { ...data, state_id, address, phone, email };
    }
    
    if (id) data.id = parseInt(id);
    
    const method = id ? 'PUT' : 'POST';
    const urlPath = id ? `/api/admin/sources/${id}` : '/api/admin/sources';
    
    console.log(`📤 ${method} request to ${urlPath}`, data);
    
    isSubmitting = true;
    showLoading(true);
    
    try {
      const response = await fetch(urlPath, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      
      const result = await response.json();
      console.log('📥 Response:', result);
      
      if (!response.ok) {
        throw new Error(result.error || 'Failed to save source');
      }
      
      if (result.success) {
        showToast(id ? '✅ Source updated successfully' : '✅ Source created successfully', 'success');
        closeModal();
        setTimeout(() => window.location.reload(), 500);
      } else {
        showModalMessage(result.error || 'Failed to save source', 'error');
      }
    } catch (error) {
      console.error('❌ Error saving source:', error);
      showModalMessage('Failed to save source: ' + error.message, 'error');
    } finally {
      isSubmitting = false;
      showLoading(false);
    }
  }

  // ============================================
  // SHOW MODAL MESSAGE
  // ============================================
  function showModalMessage(message, type) {
    const msg = document.getElementById('modalMessage');
    msg.textContent = message;
    msg.className = `p-3 rounded-lg text-sm ${type === 'error' ? 'bg-red-50 text-red-700' : 'bg-blue-50 text-blue-700'}`;
    msg.classList.remove('hidden');
  }

  // ============================================
  // TOAST NOTIFICATION
  // ============================================
  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = message;
    toast.className = `fixed bottom-6 right-6 max-w-sm p-4 rounded-xl shadow-2xl z-50 transform transition-all duration-500 ${
      type === 'success' ? 'bg-green-500 text-white' : 
      type === 'error' ? 'bg-red-500 text-white' : 
      'bg-blue-500 text-white'
    }`;
    toast.classList.remove('hidden', 'translate-y-20', 'opacity-0');
    toast.classList.add('translate-y-0', 'opacity-100');
    
    setTimeout(() => {
      toast.classList.add('translate-y-20', 'opacity-0');
      setTimeout(() => toast.classList.add('hidden'), 500);
    }, 3000);
  }

  // ============================================
  // LOADING OVERLAY
  // ============================================
  function showLoading(show) {
    document.getElementById('loadingOverlay').className = show 
      ? 'fixed inset-0 bg-black/30 flex items-center justify-center z-40'
      : 'fixed inset-0 bg-black/30 flex items-center justify-center z-40 hidden';
  }
  
  // ============================================
  // FORCE RENDER AFTER DELAY
  // ============================================
  setTimeout(function() {
    console.log('🔄 Final force render...');
    if (allSources.master.length > 0 || allSources.state.length > 0) {
      filterSources();
    } else {
      console.warn('⚠️ No data available to render');
    }
  }, 500);
</script>

