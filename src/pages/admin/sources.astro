---
// Admin Reliable Sources Management Page
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Reliable Sources Management">
  <div class="sources-page">
    <!-- Header -->
    <div class="page-header">
      <div class="header-content">
        <div class="header-icon-wrapper">
          <svg class="header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
            <line x1="12" y1="17" x2="12.01" y2="17" />
          </svg>
        </div>
        <div>
          <h1 class="page-title">Reliable Sources</h1>
          <p class="page-subtitle">Manage trusted websites across categories</p>
        </div>
      </div>
      <div class="header-actions">
        <button class="btn btn-secondary" id="add-category-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
            <line x1="12" y1="11" x2="12" y2="17" />
            <line x1="9" y1="14" x2="15" y2="14" />
          </svg>
          Category
        </button>
        <button class="btn btn-primary" id="add-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
          Add Website
        </button>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon-wrapper stat-icon-blue">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="2" y1="12" x2="22" y2="12" />
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
          </svg>
        </div>
        <div>
          <div class="stat-value" id="total-count">0</div>
          <div class="stat-label">Total Websites</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon-wrapper stat-icon-purple">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
          </svg>
        </div>
        <div>
          <div class="stat-value" id="category-count">0</div>
          <div class="stat-label">Categories</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon-wrapper stat-icon-indigo">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z" />
            <path d="M2 17l10 5 10-5" />
            <path d="M2 12l10 5 10-5" />
          </svg>
        </div>
        <div>
          <div class="stat-value" id="subcategory-count">0</div>
          <div class="stat-label">Subcategories</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon-wrapper stat-icon-pink">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z" />
            <path d="M2 17l10 5 10-5" />
            <path d="M2 12l10 5 10-5" />
            <polyline points="2 7 2 17 12 22" />
            <polyline points="22 7 22 17 12 22" />
          </svg>
        </div>
        <div>
          <div class="stat-value" id="subsubcategory-count">0</div>
          <div class="stat-label">Sub-Subcategories</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon-wrapper stat-icon-yellow">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
        </div>
        <div>
          <div class="stat-value" id="featured-count">0</div>
          <div class="stat-label">Featured</div>
        </div>
      </div>
    </div>

    <!-- Tabs -->
    <div class="tabs-wrapper">
      <div class="tabs">
        <button class="tab active" data-tab="websites">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="2" y1="12" x2="22" y2="12" />
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
          </svg>
          Websites
        </button>
        <button class="tab" data-tab="categories">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
          </svg>
          Categories
        </button>
        <button class="tab" data-tab="subcategories">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z" />
            <path d="M2 17l10 5 10-5" />
            <path d="M2 12l10 5 10-5" />
          </svg>
          Subcategories
        </button>
        <button class="tab" data-tab="subsubcategories">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z" />
            <path d="M2 17l10 5 10-5" />
            <path d="M2 12l10 5 10-5" />
            <polyline points="2 7 2 17 12 22" />
            <polyline points="22 7 22 17 12 22" />
          </svg>
          Sub-Subcategories
        </button>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- TAB 1: WEBSITES -->
    <!-- ============================================ -->
    <div id="tab-websites" class="tab-content active">
      <div class="filters-bar">
        <div class="filters">
          <select id="filter-category">
            <option value="">All Categories</option>
          </select>
          <select id="filter-subcategory">
            <option value="">All Subcategories</option>
          </select>
          <select id="filter-subsubcategory">
            <option value="">All Sub-Subcategories</option>
          </select>
          <select id="filter-score">
            <option value="">All Scores</option>
            <option value="10">⭐ 10</option>
            <option value="9">9</option>
            <option value="8">8</option>
            <option value="7">7</option>
            <option value="6">6</option>
            <option value="5">5</option>
          </select>
          <div class="search-box">
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input type="text" id="search-input" placeholder="Search websites..." />
          </div>
        </div>
        <button class="btn-refresh" onclick="loadData()" title="Refresh">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10" />
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
          </svg>
        </button>
      </div>

      <div id="loading-state" class="loading">
        <div class="spinner"></div>
        <p>Loading websites...</p>
      </div>

      <div id="table-wrap" style="display:none;">
        <div class="table-wrapper">
          <table class="sources-table">
            <thead>
              <tr>
                <th>Website</th>
                <th>Category</th>
                <th>Subcategory</th>
                <th>Sub-Subcategory</th>
                <th>Score</th>
                <th>Country</th>
                <th>Status</th>
                <th class="col-actions">Actions</th>
              </tr>
            </thead>
            <tbody id="table-body"></tbody>
          </table>
        </div>
      </div>

      <div id="empty-state" style="display:none;" class="empty-state">
        <div class="empty-icon-wrapper">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="2" y1="12" x2="22" y2="12" />
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
          </svg>
        </div>
        <h3>No websites found</h3>
        <p>Add your first reliable source to get started</p>
        <button class="btn btn-primary" onclick="openWebsiteModal()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
          Add Website
        </button>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- TAB 2: CATEGORIES -->
    <!-- ============================================ -->
    <div id="tab-categories" class="tab-content">
      <div class="table-toolbar">
        <div class="table-toolbar-left">
          <span class="table-info">Manage your content categories</span>
        </div>
        <div class="table-toolbar-right">
          <button class="btn btn-sm btn-primary" id="add-category-btn-tab">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Add Category
          </button>
        </div>
      </div>
      <div class="table-wrapper">
        <table class="sources-table">
          <thead>
            <tr>
              <th style="width:60px;">Icon</th>
              <th>Name</th>
              <th>Slug</th>
              <th>Description</th>
              <th style="width:120px;">Subcategories</th>
              <th style="width:120px;">Status</th>
              <th style="width:100px;" class="col-actions">Actions</th>
            </tr>
          </thead>
          <tbody id="categories-table-body"></tbody>
        </table>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- TAB 3: SUBCATEGORIES -->
    <!-- ============================================ -->
    <div id="tab-subcategories" class="tab-content">
      <div class="table-toolbar">
        <div class="table-toolbar-left">
          <select id="subcat-filter-category" class="filter-select">
            <option value="">Filter by Category</option>
          </select>
          <span class="table-info" id="subcat-count"></span>
        </div>
        <div class="table-toolbar-right">
          <button class="btn btn-sm btn-primary" id="add-subcategory-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Add Subcategory
          </button>
        </div>
      </div>
      <div class="table-wrapper">
        <table class="sources-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Slug</th>
              <th>Category</th>
              <th style="width:140px;">Sub-Subcategories</th>
              <th style="width:120px;">Websites</th>
              <th style="width:120px;">Status</th>
              <th style="width:100px;" class="col-actions">Actions</th>
            </tr>
          </thead>
          <tbody id="subcategories-table-body"></tbody>
        </table>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- TAB 4: SUB-SUBCATEGORIES -->
    <!-- ============================================ -->
    <div id="tab-subsubcategories" class="tab-content">
      <div class="table-toolbar">
        <div class="table-toolbar-left">
          <select id="subsubcat-filter-subcategory" class="filter-select">
            <option value="">Filter by Subcategory</option>
          </select>
          <span class="table-info" id="subsubcat-count"></span>
        </div>
        <div class="table-toolbar-right">
          <button class="btn btn-sm btn-primary" id="add-subsubcategory-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Add Sub-Subcategory
          </button>
        </div>
      </div>
      <div class="table-wrapper">
        <table class="sources-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Slug</th>
              <th>Subcategory</th>
              <th>Category</th>
              <th style="width:120px;">Websites</th>
              <th style="width:120px;">Status</th>
              <th style="width:100px;" class="col-actions">Actions</th>
            </tr>
          </thead>
          <tbody id="subsubcategories-table-body"></tbody>
        </table>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- WEBSITE MODAL -->
    <!-- ============================================ -->
    <div id="website-modal" class="modal-overlay" style="display:none;">
      <div class="modal">
        <div class="modal-header">
          <h2 id="website-modal-title">Add Website</h2>
          <button class="modal-close" id="website-modal-close">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>
        <form id="website-form">
          <input type="hidden" id="website-edit-id" />
          <div class="form-row">
            <div class="form-group">
              <label>Category *</label>
              <select id="website-form-category" required>
                <option value="">Select a category</option>
              </select>
            </div>
            <div class="form-group">
              <label>Subcategory *</label>
              <select id="website-form-subcategory" required>
                <option value="">Select a subcategory</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label>Sub-Subcategory</label>
            <select id="website-form-subsubcategory">
              <option value="">None (optional)</option>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Website Name *</label>
              <input type="text" id="website-form-name" required placeholder="Enter website name" />
            </div>
            <div class="form-group">
              <label>URL *</label>
              <input type="url" id="website-form-url" required placeholder="https://example.com" />
            </div>
          </div>
          <div class="form-group">
            <label>Description</label>
            <textarea id="website-form-desc" rows="2" placeholder="Brief description of the website"></textarea>
          </div>
          <div class="form-group">
            <label>Notes</label>
            <textarea id="website-form-notes" rows="2" placeholder="Internal notes (optional)"></textarea>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Score *</label>
              <div class="score-slider">
                <input type="range" id="website-form-score" min="1" max="10" value="5" step="1" />
                <span id="website-score-label">5/10</span>
              </div>
            </div>
            <div class="form-group">
              <label>Country</label>
              <input type="text" id="website-form-country" value="USA" />
            </div>
          </div>
          <div class="form-group">
            <label>Logo URL</label>
            <input type="url" id="website-form-logo" placeholder="https://example.com/logo.png" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="checkbox-label">
                <input type="checkbox" id="website-form-active" checked />
                <span class="checkbox-custom"></span>
                Active
              </label>
            </div>
            <div class="form-group">
              <label class="checkbox-label">
                <input type="checkbox" id="website-form-featured" />
                <span class="checkbox-custom"></span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
                Featured
              </label>
            </div>
          </div>
          <div id="website-form-message" class="form-message" style="display:none;"></div>
          <div class="form-actions">
            <button type="button" class="btn btn-secondary" id="website-modal-cancel">Cancel</button>
            <button type="submit" class="btn btn-primary">Save Website</button>
          </div>
        </form>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- CATEGORY MODAL -->
    <!-- ============================================ -->
    <div id="category-modal" class="modal-overlay" style="display:none;">
      <div class="modal">
        <div class="modal-header">
          <h2 id="category-modal-title">Add Category</h2>
          <button class="modal-close" id="category-modal-close">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>
        <form id="category-form">
          <input type="hidden" id="category-edit-id" />
          <div class="form-row">
            <div class="form-group">
              <label>Name *</label>
              <input type="text" id="category-form-name" required placeholder="Category name" />
            </div>
            <div class="form-group">
              <label>Slug *</label>
              <input type="text" id="category-form-slug" required placeholder="category-slug" />
            </div>
          </div>
          <div class="form-group">
            <label>Description</label>
            <textarea id="category-form-desc" rows="2" placeholder="Category description"></textarea>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Icon</label>
              <input type="text" id="category-form-icon" value="📚" />
            </div>
            <div class="form-group">
              <label>Display Order</label>
              <input type="number" id="category-form-order" value="0" />
            </div>
          </div>
          <div class="form-group">
            <label class="checkbox-label">
              <input type="checkbox" id="category-form-active" checked />
              <span class="checkbox-custom"></span>
              Active
            </label>
          </div>
          <div id="category-form-message" class="form-message" style="display:none;"></div>
          <div class="form-actions">
            <button type="button" class="btn btn-secondary" id="category-modal-cancel">Cancel</button>
            <button type="submit" class="btn btn-primary">Save Category</button>
          </div>
        </form>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- SUBCATEGORY MODAL -->
    <!-- ============================================ -->
    <div id="subcategory-modal" class="modal-overlay" style="display:none;">
      <div class="modal">
        <div class="modal-header">
          <h2 id="subcategory-modal-title">Add Subcategory</h2>
          <button class="modal-close" id="subcategory-modal-close">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>
        <form id="subcategory-form">
          <input type="hidden" id="subcategory-edit-id" />
          <div class="form-group">
            <label>Category *</label>
            <select id="subcategory-form-category" required>
              <option value="">Select a category</option>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Name *</label>
              <input type="text" id="subcategory-form-name" required placeholder="Subcategory name" />
            </div>
            <div class="form-group">
              <label>Slug *</label>
              <input type="text" id="subcategory-form-slug" required placeholder="subcategory-slug" />
            </div>
          </div>
          <div class="form-group">
            <label>Description</label>
            <textarea id="subcategory-form-desc" rows="2" placeholder="Subcategory description"></textarea>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Display Order</label>
              <input type="number" id="subcategory-form-order" value="0" />
            </div>
            <div class="form-group" style="display:flex;align-items:center;padding-top:1.5rem;">
              <label class="checkbox-label">
                <input type="checkbox" id="subcategory-form-active" checked />
                <span class="checkbox-custom"></span>
                Active
              </label>
            </div>
          </div>
          <div id="subcategory-form-message" class="form-message" style="display:none;"></div>
          <div class="form-actions">
            <button type="button" class="btn btn-secondary" id="subcategory-modal-cancel">Cancel</button>
            <button type="submit" class="btn btn-primary">Save Subcategory</button>
          </div>
        </form>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- SUB-SUBCATEGORY MODAL -->
    <!-- ============================================ -->
    <div id="subsubcategory-modal" class="modal-overlay" style="display:none;">
      <div class="modal">
        <div class="modal-header">
          <h2 id="subsubcategory-modal-title">Add Sub-Subcategory</h2>
          <button class="modal-close" id="subsubcategory-modal-close">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>
