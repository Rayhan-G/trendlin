---
// Admin Sources Management Page
import AdminLayout from '../../layouts/AdminLayout.astro';
import SourcesManager from '../../components/admin/SourcesManager.astro';
import { checkAuth } from '../../lib/auth.js';

// Check authentication
const auth = await checkAuth(Astro.request);
if (!auth.authenticated) {
  return Astro.redirect('/admin/login');
}
---

<AdminLayout title="Sources Management">
  <div class="sources-page">
    <div class="page-header">
      <h1>Sources Management</h1>
      <p class="text-muted">Manage trusted content sources for all platforms</p>
    </div>
    
    <div class="sources-container">
      <SourcesManager client:load />
    </div>
  </div>
</AdminLayout>

<style>
  .sources-page {
    padding: 2rem;
  }
  
  .page-header {
    margin-bottom: 2rem;
  }
  
  .page-header h1 {
    font-size: 2rem;
    font-weight: 600;
    color: #1a1a2e;
    margin: 0;
  }
  
  .page-header .text-muted {
    color: #6c757d;
    margin: 0.5rem 0 0;
  }
  
  .sources-container {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    padding: 1.5rem;
  }
</style>