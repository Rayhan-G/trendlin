<script>
  // ============================================
  // STATE
  // ============================================
  let sources = [];
  let categories = [];
  let states = [];
  let editingId = null;
  let isSubmitting = false;
  let isLoading = false;

  // ============================================
  // DOM REFS
  // ============================================
  const $ = (id) => document.getElementById(id);
  const loadingEl = $('loading-state');
  const tableWrap = $('table-wrap');
  const emptyEl = $('empty-state');
  const tableBody = $('table-body');
  const modal = $('source-modal');
  const tableCount = $('table-count');

  const filterType = $('filter-type');
  const filterCategory = $('filter-category');
  const filterState = $('filter-state');
  const searchInput = $('search-input');

  // ============================================
  // TOAST
  // ============================================
  function showToast(message, type = 'success') {
    const container = document.getElementById('toast');
    if (!container) return;
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.innerHTML = message;
    container.appendChild(toast);
    setTimeout(() => {
      if (toast.parentNode) toast.remove();
    }, 3000);
  }

  // ============================================
  // LOAD DATA
  // ============================================
  function loadData() {
    if (isLoading) return;
    isLoading = true;
    
    if (loadingEl) loadingEl.style.display = 'block';
    if (tableWrap) tableWrap.style.display = 'none';
    if (emptyEl) emptyEl.style.display = 'none';
    
    // Build query parameters from filters
    const params = new URLSearchParams();
    
    if (filterType && filterType.value && filterType.value !== 'all') {
      params.append('type', filterType.value);
    }
    if (filterCategory && filterCategory.value && filterCategory.value !== '') {
      params.append('category', filterCategory.value);
    }
    if (filterState && filterState.value && filterState.value !== '') {
      params.append('state', filterState.value);
    }
    if (searchInput && searchInput.value && searchInput.value.trim() !== '') {
      params.append('search', searchInput.value.trim());
    }
    
    const url = '/api/admin/sources?' + params.toString();
    console.log('🔍 Fetching:', url);
    
    fetch(url)
      .then(r => {
        if (!r.ok) {
          throw new Error(`HTTP ${r.status}`);
        }
        return r.json();
      })
      .then(data => {
        if (data.success) {
          sources = data.data || [];
          console.log('✅ Loaded', sources.length, 'sources');
        } else {
          console.error('API error:', data.error);
          sources = [];
        }
        renderTable();
        updateStats();
      })
      .catch(err => {
        console.error('Error loading sources:', err);
        sources = [];
        renderTable();
        updateStats();
        showToast('❌ Error loading sources: ' + err.message, 'error');
      })
      .finally(() => {
        isLoading = false;
        if (loadingEl) loadingEl.style.display = 'none';
      });
  }

  // ============================================
  // LOAD CATEGORIES & STATES
  // ============================================
  function loadCategories() {
    return fetch('/api/admin/sources/categories')
      .then(r => {
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        return r.json();
      })
      .then(data => {
        if (data.success) {
          categories = data.data || [];
          populateSelects('category');
          console.log('✅ Loaded', categories.length, 'categories');
        }
      })
      .catch(err => {
        console.error('Error loading categories:', err);
        // Use fallback categories if API fails
        categories = [
          { id: 1, name: 'Health & Wellness', icon: '🏥' },
          { id: 2, name: 'Food & Dining', icon: '🍽️' },
          { id: 3, name: 'Entertainment', icon: '🎬' },
          { id: 4, name: 'Lifestyle', icon: '🏠' },
          { id: 5, name: 'Technology', icon: '💻' },
          { id: 6, name: 'Shopping', icon: '🛍️' },
          { id: 7, name: 'Real Estate', icon: '🏡' }
        ];
        populateSelects('category');
      });
  }

  function loadStates() {
    return fetch('/api/admin/sources/states')
      .then(r => {
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        return r.json();
      })
      .then(data => {
        if (data.success) {
          states = data.data || [];
          populateSelects('state');
          console.log('✅ Loaded', states.length, 'states');
        }
      })
      .catch(err => {
        console.error('Error loading states:', err);
        // Use fallback states if API fails
        states = [
          { id: 1, name: 'California', code: 'CA' },
          { id: 2, name: 'New York', code: 'NY' },
          { id: 3, name: 'Texas', code: 'TX' },
          { id: 4, name: 'Florida', code: 'FL' },
          { id: 5, name: 'Illinois', code: 'IL' }
        ];
        populateSelects('state');
      });
  }

  // ============================================
  // POPULATE SELECTS
  // ============================================
  function populateSelects(type) {
    if (type === 'category') {
      const selects = [filterCategory, $('form-category')];
      selects.forEach(sel => {
        if (!sel) return;
        const val = sel.value;
        sel.innerHTML = '<option value="">All Categories</option>';
        categories.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c.id;
          opt.textContent = (c.icon || '📁') + ' ' + c.name;
          sel.appendChild(opt);
        });
        sel.value = val;
      });
    } else if (type === 'state') {
      const selects = [filterState, $('form-state')];
      selects.forEach(sel => {
        if (!sel) return;
        const val = sel.value;
        sel.innerHTML = '<option value="">All States</option>';
        states.forEach(s => {
          const opt = document.createElement('option');
          opt.value = s.id;
          opt.textContent = (s.code || s.abbreviation) + ' - ' + s.name;
          sel.appendChild(opt);
        });
        sel.value = val;
      });
    }
  }

  // ============================================
  // UPDATE STATS
  // ============================================
  function updateStats() {
    const total = sources.length;
    const master = sources.filter(s => s.source_type_actual === 'master').length;
    const state = sources.filter(s => s.source_type_actual === 'state').length;
    const featured = sources.filter(s => s.is_featured).length;
    
    const totalEl = $('total-count');
    const masterEl = $('master-count');
    const stateEl = $('state-count');
    const featuredEl = $('featured-count');
    
    if (totalEl) totalEl.textContent = total;
    if (masterEl) masterEl.textContent = master;
    if (stateEl) stateEl.textContent = state;
    if (featuredEl) featuredEl.textContent = featured;
  }

  // ============================================
  // RENDER TABLE
  // ============================================
  function renderTable() {
    if (!sources || sources.length === 0) {
      if (tableWrap) tableWrap.style.display = 'none';
      if (emptyEl) emptyEl.style.display = 'block';
      if (tableCount) tableCount.textContent = 'Showing 0 sources';
      return;
    }
    
    if (tableWrap) tableWrap.style.display = 'block';
    if (emptyEl) emptyEl.style.display = 'none';
    if (tableCount) tableCount.textContent = `Showing ${sources.length} source${sources.length > 1 ? 's' : ''}`;
    
    if (!tableBody) return;
    
    let html = '';
    sources.forEach((s, index) => {
      const trust = Math.min(s.trust_score || 0, 100);
      const statusClass = s.is_active ? 'active' : 'inactive';
      const statusText = s.is_active ? 'Active' : 'Inactive';
      const typeClass = s.source_type_actual || 'master';
      const typeLabel = s.source_type_actual === 'master' ? '🌐 Universal' : '📍 State';
      const featuredStar = s.is_featured ? '⭐' : '';
      
      html += `
        <tr style="animation: fadeIn 0.3s ease ${index * 0.05}s both;">
          <td>
            <div class="source-cell">
              ${s.logo_url 
                ? `<img src="${s.logo_url}" class="source-logo" alt="${s.name}" onerror="this.style.display='none'" />` 
                : `<div class="source-logo-placeholder">📄</div>`}
              <div>
                <div class="source-name">${escapeHtml(s.name)}</div>
                <span class="source-url">${escapeHtml(s.url)}</span>
              </div>
            </div>
          </td>
          <td><span class="badge-category">${escapeHtml(s.category_name || 'Uncategorized')}</span></td>
          <td>${s.state_code ? `<span class="badge-state">${escapeHtml(s.state_code)}</span>` : '<span style="color:#94a3b8;font-size:0.75rem;">—</span>'}</td>
          <td><span class="badge-type ${typeClass}">${typeLabel}</span></td>
          <td>
            <div class="trust-cell">
              <div class="trust-bar-wrap"><div class="trust-bar-fill" style="width:${trust}%"></div></div>
              <span class="trust-value">${trust}%</span>
            </div>
          </td>
          <td>
            <span class="badge-status ${statusClass}">${statusText}</span>
            ${featuredStar ? `<span class="badge-featured">${featuredStar}</span>` : ''}
          </td>
          <td>
            <div class="actions-cell">
              <button class="btn-sm btn-sm-edit" onclick="window.editSource(${s.id})" title="Edit">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
              </button>
              <button class="btn-sm btn-sm-delete" onclick="window.deleteSource(${s.id})" title="Delete">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6"></polyline>
                  <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                </svg>
              </button>
            </div>
          </td>
        </tr>
      `;
    });
    tableBody.innerHTML = html;
  }

  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // ============================================
  // MODAL FUNCTIONS
  // ============================================
  window.openModal = function(type = 'master', data = null) {
    const form = $('source-form');
    const formMessage = $('form-message');
    const fType = $('form-type');
    const fState = $('form-state');
    const fName = $('form-name');
    const fUrl = $('form-url');
    const fCategory = $('form-category');
    const fDesc = $('form-desc');
    const fLogo = $('form-logo');
    const fSourceType = $('form-source-type');
    const fActive = $('form-active');
    const fFeatured = $('form-featured');
    const fTrust = $('form-trust');
    const fTrustLabel = $('trust-label');
    const fEditId = $('form-edit-id');
    const modalTitle = $('modal-title');
    const modalSubtitle = $('modal-subtitle');
    const submitText = $('submit-text');
    
    if (form) form.reset();
    editingId = null;
    if (fEditId) fEditId.value = '';
    if (formMessage) {
      formMessage.style.display = 'none';
      formMessage.className = 'form-message';
    }
    
    if (data) {
      editingId = data.id;
      if (modalTitle) modalTitle.textContent = 'Edit Source';
      if (modalSubtitle) modalSubtitle.textContent = 'Update an existing source';
      if (submitText) submitText.textContent = 'Update Source';
      
      if (fType) fType.value = data.source_type_actual || 'master';
      if (fState) fState.value = data.state_id || '';
      if (fName) fName.value = data.name || '';
      if (fUrl) fUrl.value = data.url || '';
      if (fCategory) fCategory.value = data.category_id || '';
      if (fDesc) fDesc.value = data.description || '';
      if (fLogo) fLogo.value = data.logo_url || '';
      if (fSourceType) fSourceType.value = data.source_type || 'official';
      if (fActive) fActive.checked = data.is_active === 1;
      if (fFeatured) fFeatured.checked = data.is_featured === 1;
      if (fTrust) {
        fTrust.value = data.trust_score || 50;
        if (fTrustLabel) fTrustLabel.textContent = (data.trust_score || 50) + '%';
      }
      if (fEditId) fEditId.value = data.id;
    } else {
      if (modalTitle) modalTitle.textContent = 'Add Source';
      if (modalSubtitle) modalSubtitle.textContent = 'Add a new trusted source to your collection';
      if (submitText) submitText.textContent = 'Create Source';
      
      if (fType) fType.value = type;
      if (fActive) fActive.checked = true;
      if (fFeatured) fFeatured.checked = false;
      if (fTrust) {
        fTrust.value = 50;
        if (fTrustLabel) fTrustLabel.textContent = '50%';
      }
    }
    
    toggleStateField();
    if (modal) {
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
  };

  window.editSource = function(id) {
    const source = sources.find(s => s.id === id);
    if (source) window.openModal(source.source_type_actual || 'master', source);
  };

  function toggleStateField() {
    const fType = $('form-type');
    const stateGroup = $('state-group');
    if (stateGroup && fType) {
      stateGroup.style.display = fType.value === 'master' ? 'none' : 'block';
    }
  }

  window.closeModal = function() {
    if (modal) {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }
    isSubmitting = false;
  };

  // ============================================
  // DELETE SOURCE
  // ============================================
  window.deleteSource = function(id) {
    const source = sources.find(s => s.id === id);
    if (!source) {
      showToast('❌ Source not found', 'error');
      return;
    }
    
    if (!confirm(`Delete "${source.name}"? This action cannot be undone.`)) return;
    
    const type = source.source_type_actual || 'master';
    
    fetch('/api/admin/sources/' + id, { 
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type: type })
    })
      .then(r => {
        if (!r.ok) {
          return r.json().then(data => {
            throw new Error(data.error || `HTTP ${r.status}`);
          });
        }
        return r.json();
      })
      .then(data => {
        if (data.success) {
          showToast(`✅ "${source.name}" deleted successfully`, 'success');
          loadData();
        } else {
          showToast('❌ ' + (data.error || 'Failed to delete'), 'error');
        }
      })
      .catch(err => {
        console.error('Delete error:', err);
        showToast('❌ Error: ' + err.message, 'error');
      });
  };

  // ============================================
  // FORM SUBMIT
  // ============================================
  document.addEventListener('DOMContentLoaded', function() {
    const form = $('source-form');
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        if (isSubmitting) return;
        isSubmitting = true;
        const submitText = $('submit-text');
        if (submitText) submitText.textContent = 'Saving...';
        
        const fName = $('form-name');
        const fUrl = $('form-url');
        const fCategory = $('form-category');
        const fDesc = $('form-desc');
        const fSourceType = $('form-source-type');
        const fLogo = $('form-logo');
        const fActive = $('form-active');
        const fFeatured = $('form-featured');
        const fTrust = $('form-trust');
        const fType = $('form-type');
        const fState = $('form-state');
        const fEditId = $('form-edit-id');
        const formMessage = $('form-message');
        
        const data = {
          name: fName ? fName.value.trim() : '',
          url: fUrl ? fUrl.value.trim() : '',
          category_id: fCategory ? parseInt(fCategory.value) || null : null,
          description: fDesc ? fDesc.value.trim() : '',
          source_type: fSourceType ? fSourceType.value : 'official',
          logo_url: fLogo ? fLogo.value.trim() : '',
          is_active: fActive ? (fActive.checked ? 1 : 0) : 1,
          is_featured: fFeatured ? (fFeatured.checked ? 1 : 0) : 0,
          trust_score: fTrust ? parseInt(fTrust.value) || 0 : 0,
          source_type_actual: fType ? fType.value : 'master',
          state_id: fState ? parseInt(fState.value) || null : null
        };
        
        if (!data.name || !data.url || !data.category_id) {
          showFormMessage('Name, URL, and category are required', 'error');
          isSubmitting = false;
          if (submitText) submitText.textContent = editingId ? 'Update Source' : 'Create Source';
          return;
        }
        
        if (data.source_type_actual === 'state' && !data.state_id) {
          showFormMessage('State is required for state-specific sources', 'error');
          isSubmitting = false;
          if (submitText) submitText.textContent = editingId ? 'Update Source' : 'Create Source';
          return;
        }
        
        const url = editingId ? '/api/admin/sources/' + editingId : '/api/admin/sources';
        const method = editingId ? 'PUT' : 'POST';
        
        fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        })
          .then(r => r.json())
          .then(result => {
            if (result.success) {
              showToast(editingId ? '✅ Source updated!' : '✅ Source created!', 'success');
              window.closeModal();
              loadData();
            } else {
              showFormMessage(result.error || 'Failed to save', 'error');
              isSubmitting = false;
              if (submitText) submitText.textContent = editingId ? 'Update Source' : 'Create Source';
            }
          })
          .catch(err => {
            showFormMessage('Error saving source: ' + err.message, 'error');
            isSubmitting = false;
            if (submitText) submitText.textContent = editingId ? 'Update Source' : 'Create Source';
          });
      });
    }

    function showFormMessage(msg, type) {
      const formMessage = $('form-message');
      if (!formMessage) return;
      formMessage.textContent = msg;
      formMessage.className = 'form-message ' + type;
      formMessage.style.display = 'block';
    }

    // ============================================
    // EVENT LISTENERS
    // ============================================
    
    // Load categories and states first, then load sources
    Promise.all([loadCategories(), loadStates()])
      .then(() => {
        console.log('✅ Categories and states loaded');
        loadData();
      })
      .catch(err => {
        console.error('Error loading categories/states:', err);
        // Still try to load sources
        loadData();
      });
    
    // Add button
    const addBtn = $('add-btn');
    if (addBtn) {
      addBtn.addEventListener('click', () => window.openModal('master'));
    }
    
    // Modal close buttons
    const modalClose = $('modal-close');
    const modalCancel = $('modal-cancel');
    if (modalClose) modalClose.addEventListener('click', window.closeModal);
    if (modalCancel) modalCancel.addEventListener('click', window.closeModal);
    if (modal) {
      modal.addEventListener('click', e => { 
        if (e.target === modal) window.closeModal(); 
      });
    }
    
    // Trust slider
    const fTrust = $('form-trust');
    const fTrustLabel = $('trust-label');
    if (fTrust && fTrustLabel) {
      fTrust.addEventListener('input', () => {
        fTrustLabel.textContent = fTrust.value + '%';
      });
    }
    
    // Type toggle
    const fType = $('form-type');
    if (fType) {
      fType.addEventListener('change', toggleStateField);
    }
    
    // FILTERS
    if (filterType) {
      filterType.addEventListener('change', function() {
        console.log('🔄 Filter: type =', this.value);
        loadData();
      });
    }
    
    if (filterCategory) {
      filterCategory.addEventListener('change', function() {
        console.log('🔄 Filter: category =', this.value);
        loadData();
      });
    }
    
    if (filterState) {
      filterState.addEventListener('change', function() {
        console.log('🔄 Filter: state =', this.value);
        loadData();
      });
    }
    
    if (searchInput) {
      let searchTimer;
      searchInput.addEventListener('input', function() {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(() => {
          console.log('🔍 Search:', this.value);
          loadData();
        }, 300);
      });
    }
    
    // Refresh button
    const refreshBtn = document.querySelector('.btn-refresh');
    if (refreshBtn) {
      refreshBtn.addEventListener('click', loadData);
    }
    
    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      if (e.ctrlKey && e.key === 'n') {
        e.preventDefault();
        window.openModal('master');
      }
      if (e.key === 'Escape' && modal && modal.style.display === 'flex') {
        window.closeModal();
      }
    });
  });

  // Expose functions to window
  window.loadData = loadData;
  window.editSource = editSource;
  window.deleteSource = deleteSource;
  window.openModal = openModal;
  window.closeModal = closeModal;
</script>