  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-weight: 400;
    padding-top: 0.25rem;
    color: var(--color-gray-700);
  }

  .checkbox-label input[type="checkbox"] {
    display: none;
  }

  .checkbox-custom {
    width: 18px;
    height: 18px;
    border: 2px solid var(--color-gray-300);
    border-radius: 4px;
    display: inline-block;
    position: relative;
    flex-shrink: 0;
    transition: var(--transition);
  }

  .checkbox-label input:checked + .checkbox-custom {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .checkbox-label input:checked + .checkbox-custom::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 2px;
    width: 5px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .checkbox-label svg {
    color: var(--color-gray-400);
    width: 16px;
    height: 16px;
  }

  .score-slider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .score-slider input[type="range"] {
    flex: 1;
    padding: 0;
    height: 6px;
    background: var(--color-gray-200);
    border-radius: 3px;
    appearance: none;
    outline: none;
  }

  .score-slider input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-primary);
    cursor: pointer;
    transition: var(--transition);
  }

  .score-slider input[type="range"]::-webkit-slider-thumb:hover {
    transform: scale(1.1);
  }

  .score-slider span {
    font-weight: 700;
    color: var(--color-gray-900);
    min-width: 2.75rem;
    font-size: 0.875rem;
  }

  .form-message {
    padding: 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  .form-message.error {
    background: var(--color-danger-bg);
    color: #991b1b;
  }

  .form-message.success {
    background: var(--color-success-bg);
    color: #166534;
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-gray-200);
  }

  /* ============================================
     TOAST
     ============================================ */
  .toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    font-weight: 500;
    font-size: 0.875rem;
    font-family: var(--font-family);
    color: white;
    opacity: 0;
    transform: translateY(1rem);
    transition: all 0.3s ease;
    pointer-events: none;
    z-index: 2000;
    box-shadow: var(--shadow-lg);
  }

  .toast.show {
    opacity: 1;
    transform: translateY(0);
  }

  .toast.success {
    background: var(--color-success);
  }

  .toast.error {
    background: var(--color-danger);
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    }
  }

  @media (max-width: 768px) {
    .page-header {
      flex-direction: column;
      align-items: stretch;
    }

    .header-content {
      gap: 0.75rem;
    }

    .header-icon-wrapper {
      width: 40px;
      height: 40px;
    }

    .header-icon {
      width: 20px;
      height: 20px;
    }

    .page-title {
      font-size: 1.25rem;
    }

    .header-actions {
      flex-direction: column;
    }

    .header-actions .btn {
      justify-content: center;
      width: 100%;
    }

    .stats-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
    }

    .stat-card {
      padding: 0.75rem 1rem;
    }

    .stat-value {
      font-size: 1.25rem;
    }

    .filters {
      flex-direction: column;
    }

    .filters select,
    .search-box {
      width: 100%;
      min-width: unset;
    }

    .filters-bar {
      flex-direction: column;
    }

    .table-toolbar {
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
    }

    .table-toolbar-left,
    .table-toolbar-right {
      flex-direction: column;
      align-items: stretch;
    }

    .filter-select {
      width: 100%;
      min-width: unset;
    }

    .tabs {
      overflow-x: auto;
      flex-wrap: nowrap;
      gap: 0;
    }

    .tab {
      white-space: nowrap;
      padding: 0.5rem 0.875rem;
      font-size: 0.75rem;
    }

    .tab svg {
      display: none;
    }

    .sources-table {
      font-size: 0.75rem;
    }

    .sources-table th,
    .sources-table td {
      padding: 0.5rem 0.625rem;
    }

    .source-cell {
      gap: 0.5rem;
    }

    .source-logo,
    .source-logo-placeholder {
      width: 28px;
      height: 28px;
    }

    .source-name {
      font-size: 0.813rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .modal {
      padding: 1.25rem;
      margin: 0.5rem;
    }

    .actions-cell {
      justify-content: flex-start;
    }

    .col-actions {
      text-align: left;
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }

    .stat-value {
      font-size: 1.125rem;
    }

    .empty-state {
      padding: 2rem 1rem;
    }

    .empty-icon-wrapper {
      width: 60px;
      height: 60px;
    }
  }
</style>

<script>
  // ============================================
  // STATE
  // ============================================
  let websites = [];
  let categories = [];
  let subcategories = [];
  let subsubcategories = [];

  let editingWebsiteId = null;
  let editingCategoryId = null;
  let editingSubcategoryId = null;
  let editingSubSubcategoryId = null;

  // ============================================
  // TOAST
  // ============================================
  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = message;
    toast.className = `toast ${type}`;
    toast.classList.add('show');
    clearTimeout(toast._timeout);
    toast._timeout = setTimeout(() => toast.classList.remove('show'), 3000);
  }

  // ============================================
  // TABS
  // ============================================
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
      this.classList.add('active');
      const tabName = this.dataset.tab;
      document.getElementById(`tab-${tabName}`).classList.add('active');
      if (tabName === 'categories') renderCategories();
      else if (tabName === 'subcategories') renderSubcategories();
      else if (tabName === 'subsubcategories') renderSubSubcategories();
    });
  });

  // ============================================
  // LOAD DATA
  // ============================================
  function loadData() {
    const loadingEl = document.getElementById('loading-state');
    const tableWrap = document.getElementById('table-wrap');
    const emptyEl = document.getElementById('empty-state');
    
    loadingEl.style.display = 'block';
    tableWrap.style.display = 'none';
    emptyEl.style.display = 'none';
    
    Promise.all([loadWebsites(), loadCategories(), loadSubcategories(), loadSubSubcategories()])
      .then(() => {
        loadingEl.style.display = 'none';
        renderTable();
        updateStats();
        populateAllSelects();
        renderCategories();
        renderSubcategories();
        renderSubSubcategories();
      })
      .catch((err) => {
        console.error('Failed to load data:', err);
        showToast('Failed to load data: ' + err.message, 'error');
        loadingEl.style.display = 'none';
      });
  }

  function loadWebsites() {
    const params = new URLSearchParams();
    const filterCategory = document.getElementById('filter-category');
    const filterSubcategory = document.getElementById('filter-subcategory');
    const filterSubsubcategory = document.getElementById('filter-subsubcategory');
    const filterScore = document.getElementById('filter-score');
    const searchInput = document.getElementById('search-input');
    
    if (filterCategory.value) params.append('category', filterCategory.value);
    if (filterSubcategory.value) params.append('subcategory', filterSubcategory.value);
    if (filterSubsubcategory.value) params.append('subsubcategory', filterSubsubcategory.value);
    if (filterScore.value) params.append('min_score', filterScore.value);
    if (searchInput.value) params.append('search', searchInput.value);
    
    return fetch('/api/admin/reliable/websites?' + params.toString())
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          websites = data.data || [];
        } else {
          console.error('API error:', data.error);
          websites = [];
        }
        return websites;
      })
      .catch(err => {
        console.error('Error loading websites:', err);
        websites = [];
        return websites;
      });
  }

  function loadCategories() {
    return fetch('/api/admin/reliable/categories')
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          categories = data.data || [];
        }
        return categories;
      })
      .catch(err => {
        console.error('Error loading categories:', err);
        categories = [];
        return categories;
      });
  }

  function loadSubcategories() {
    return fetch('/api/admin/reliable/subcategories')
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          subcategories = data.data || [];
        }
        return subcategories;
      })
      .catch(err => {
        console.error('Error loading subcategories:', err);
        subcategories = [];
        return subcategories;
      });
  }

  function loadSubSubcategories() {
    return fetch('/api/admin/reliable/subsubcategories')
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          subsubcategories = data.data || [];
        }
        return subsubcategories;
      })
      .catch(err => {
        console.error('Error loading sub-subcategories:', err);
        subsubcategories = [];
        return subsubcategories;
      });
  }

  // ============================================
  // UPDATE STATS
  // ============================================
  function updateStats() {
    const total = websites.length;
    const featured = websites.filter(w => w.is_featured).length;
    
    document.getElementById('total-count').textContent = total;
    document.getElementById('category-count').textContent = categories.length;
    document.getElementById('subcategory-count').textContent = subcategories.length;
    document.getElementById('subsubcategory-count').textContent = subsubcategories.length;
    document.getElementById('featured-count').textContent = featured;
  }

  // ============================================
  // POPULATE SELECTS
  // ============================================
  function populateAllSelects() {
    populateCategorySelects();
    populateSubcategoryFilter();
    populateSubSubcategoryFilter();
    populateModalSelects();
  }

  function populateCategorySelects() {
    const selects = [
      'filter-category', 
      'website-form-category', 
      'subcat-filter-category', 
      'subcategory-form-category'
    ];
    
    selects.forEach(id => {
      const sel = document.getElementById(id);
      if (!sel) return;
      const val = sel.value;
      sel.innerHTML = '<option value="">Select Category</option>';
      categories.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = (c.icon || '📚') + ' ' + c.name;
        sel.appendChild(opt);
      });
      sel.value = val;
    });
  }

  function populateSubcategoryFilter() {
    const sel = document.getElementById('filter-subcategory');
    const val = sel.value;
    sel.innerHTML = '<option value="">All Subcategories</option>';
    
    let filtered = subcategories;
    const filterCat = document.getElementById('filter-category');
    if (filterCat.value) {
      filtered = subcategories.filter(sc => sc.category_id === parseInt(filterCat.value));
    }
    
    filtered.forEach(sc => {
      const opt = document.createElement('option');
      opt.value = sc.id;
      opt.textContent = sc.name;
      sel.appendChild(opt);
    });
    sel.value = val;
  }

  function populateSubSubcategoryFilter() {
    const sel = document.getElementById('filter-subsubcategory');
    const val = sel.value;
    sel.innerHTML = '<option value="">All Sub-Subcategories</option>';
    
    let filtered = subsubcategories;
    const filterSub = document.getElementById('filter-subcategory');
    const filterCat = document.getElementById('filter-category');
    
    if (filterSub.value) {
      filtered = subsubcategories.filter(ssc => ssc.subcategory_id === parseInt(filterSub.value));
    } else if (filterCat.value) {
      const subcatIds = subcategories.filter(sc => sc.category_id === parseInt(filterCat.value)).map(sc => sc.id);
      filtered = subsubcategories.filter(ssc => subcatIds.includes(ssc.subcategory_id));
    }
    
    filtered.forEach(ssc => {
      const opt = document.createElement('option');
      opt.value = ssc.id;
      opt.textContent = ssc.name;
      sel.appendChild(opt);
    });
    sel.value = val;
  }

  function populateModalSelects() {
    const fCat = document.getElementById('website-form-category');
    if (fCat) {
      const val = fCat.value;
      fCat.innerHTML = '<option value="">Select a category</option>';
      categories.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = (c.icon || '📚') + ' ' + c.name;
        fCat.appendChild(opt);
      });
      fCat.value = val;
    }

    const fSubCat = document.getElementById('subcategory-form-category');
    if (fSubCat) {
      const val = fSubCat.value;
      fSubCat.innerHTML = '<option value="">Select a category</option>';
      categories.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = (c.icon || '📚') + ' ' + c.name;
        fSubCat.appendChild(opt);
      });
      fSubCat.value = val;
    }

    const fSubSubCat = document.getElementById('subsubcategory-form-subcategory');
    if (fSubSubCat) {
      const val = fSubSubCat.value;
      fSubSubCat.innerHTML = '<option value="">Select a subcategory</option>';
      subcategories.forEach(sc => {
        const opt = document.createElement('option');
        opt.value = sc.id;
        const cat = categories.find(c => c.id === sc.category_id);
        opt.textContent = (cat ? cat.name + ' → ' : '') + sc.name;
        fSubSubCat.appendChild(opt);
      });
      fSubSubCat.value = val;
    }
  }

  function populateSubcategoryForm(categoryId) {
    const sel = document.getElementById('website-form-subcategory');
    const val = sel.value;
    sel.innerHTML = '<option value="">Select a subcategory</option>';
    
    const filtered = subcategories.filter(sc => sc.category_id === parseInt(categoryId));
    filtered.forEach(sc => {
      const opt = document.createElement('option');
      opt.value = sc.id;
      opt.textContent = sc.name;
      sel.appendChild(opt);
    });
    sel.value = val;
    populateSubSubcategoryForm(sel.value);
  }

  function populateSubSubcategoryForm(subcategoryId) {
    const sel = document.getElementById('website-form-subsubcategory');
    const val = sel.value;
    sel.innerHTML = '<option value="">None (optional)</option>';
    
    const filtered = subsubcategories.filter(ssc => ssc.subcategory_id === parseInt(subcategoryId));
    filtered.forEach(ssc => {
      const opt = document.createElement('option');
      opt.value = ssc.id;
      opt.textContent = ssc.name;
      sel.appendChild(opt);
    });
    sel.value = val;
  }

  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // ============================================
  // RENDER WEBSITES TABLE
  // ============================================
  function renderTable() {
    const tableWrap = document.getElementById('table-wrap');
    const emptyEl = document.getElementById('empty-state');
    
    if (!websites || websites.length === 0) {
      tableWrap.style.display = 'none';
      emptyEl.style.display = 'block';
      return;
    }
    
    tableWrap.style.display = 'block';
    emptyEl.style.display = 'none';
    
    let html = '';
    websites.forEach(w => {
      const score = w.reliability_score || 0;
      let scoreClass = 'low';
      if (score >= 10) scoreClass = 'perfect';
      else if (score >= 8) scoreClass = 'high';
      else if (score >= 6) scoreClass = 'medium';
      
      html += `
        <tr>
          <td>
            <div class="source-cell">
              ${w.logo_url ? `<img src="${w.logo_url}" class="source-logo" />` : `<div class="source-logo-placeholder">🌐</div>`}
              <div>
                <div class="source-name">${escapeHtml(w.name)}</div>
                <span class="source-url">${escapeHtml(w.url)}</span>
              </div>
            </div>
          </td>
          <td><span class="badge-category">${escapeHtml(w.category_name || 'Uncategorized')}</span></td>
          <td><span class="badge-subcategory">${escapeHtml(w.subcategory_name || '')}</span></td>
          <td>${w.subsubcategory_name ? `<span class="badge-subsubcategory">${escapeHtml(w.subsubcategory_name)}</span>` : '<span style="color:var(--color-gray-400);font-size:0.75rem;">—</span>'}</td>
          <td><span class="badge-score ${scoreClass}">${score}/10</span></td>
          <td><span class="badge-country">${escapeHtml(w.country || 'USA')}</span></td>
          <td>
            <span class="badge-status ${w.is_active ? 'active' : 'inactive'}">
              <span class="status-dot"></span>
              ${w.is_active ? 'Active' : 'Inactive'}
            </span>
            ${w.is_featured ? '<span class="badge-featured">⭐ Featured</span>' : ''}
          </td>
          <td>
            <div class="actions-cell">
              <button class="btn-sm-edit" onclick="editWebsite(${w.id})" title="Edit">✏️</button>
              <button class="btn-sm-verify" onclick="verifyWebsite(${w.id})" title="Verify">✅</button>
              <button class="btn-sm-delete" onclick="deleteWebsite(${w.id})" title="Delete">🗑️</button>
            </div>
          </td>
        </tr>
      `;
    });
    document.getElementById('table-body').innerHTML = html;
  }

  // ============================================
  // RENDER CATEGORIES TABLE
  // ============================================
  function renderCategories() {
    const tbody = document.getElementById('categories-table-body');
    if (!categories || categories.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--color-gray-400);">No categories found</td></tr>';
      return;
    }
    
    let html = '';
    categories.forEach(c => {
      html += `
        <tr>
          <td style="font-size:1.5rem;text-align:center;">${c.icon || '📚'}</td>
          <td><strong style="color:var(--color-gray-900);">${escapeHtml(c.name)}</strong></td>
          <td><code style="background:var(--color-gray-50);padding:0.125rem 0.5rem;border-radius:4px;font-size:0.75rem;color:var(--color-gray-600);">${escapeHtml(c.slug)}</code></td>
          <td style="color:var(--color-gray-500);font-size:0.813rem;">${escapeHtml(c.description || '')}</td>
          <td><span class="badge-category">${c.subcategory_count || 0}</span></td>
          <td>
            <span class="badge-status ${c.is_active ? 'active' : 'inactive'}">
              <span class="status-dot"></span>
              ${c.is_active ? 'Active' : 'Inactive'}
            </span>
          </td>
          <td>
            <div class="actions-cell">
              <button class="btn-sm-edit" onclick="editCategory(${c.id})" title="Edit">✏️</button>
              <button class="btn-sm-delete" onclick="deleteCategory(${c.id})" title="Delete">🗑️</button>
            </div>
          </td>
        </tr>
      `;
    });
    tbody.innerHTML = html;
  }

  // ============================================
  // RENDER SUBCATEGORIES TABLE
  // ============================================
  function renderSubcategories() {
    const tbody = document.getElementById('subcategories-table-body');
    const filterCat = document.getElementById('subcat-filter-category').value;
    
    let filtered = subcategories;
    if (filterCat) {
      filtered = subcategories.filter(sc => sc.category_id === parseInt(filterCat));
    }
    
    document.getElementById('subcat-count').textContent = `${filtered.length} items`;
    
    if (!filtered || filtered.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--color-gray-400);">No subcategories found</td></tr>';
      return;
    }
    
    let html = '';
    filtered.forEach(sc => {
      const cat = categories.find(c => c.id === sc.category_id);
      html += `
        <tr>
          <td><strong style="color:var(--color-gray-900);">${escapeHtml(sc.name)}</strong></td>
          <td><code style="background:var(--color-gray-50);padding:0.125rem 0.5rem;border-radius:4px;font-size:0.75rem;color:var(--color-gray-600);">${escapeHtml(sc.slug)}</code></td>
          <td><span class="badge-category">${escapeHtml(cat ? cat.name : 'Unknown')}</span></td>
          <td><span class="badge-subcategory">${sc.subsubcategory_count || 0}</span></td>
          <td><span class="badge-subcategory">${sc.website_count || 0}</span></td>
          <td>
            <span class="badge-status ${sc.is_active ? 'active' : 'inactive'}">
              <span class="status-dot"></span>
              ${sc.is_active ? 'Active' : 'Inactive'}
            </span>
          </td>
          <td>
            <div class="actions-cell">
              <button class="btn-sm-edit" onclick="editSubcategory(${sc.id})" title="Edit">✏️</button>
              <button class="btn-sm-delete" onclick="deleteSubcategory(${sc.id})" title="Delete">🗑️</button>
            </div>
          </td>
        </tr>
      `;
    });
    tbody.innerHTML = html;
  }

  // ============================================
  // RENDER SUB-SUBCATEGORIES TABLE
  // ============================================
  function renderSubSubcategories() {
    const tbody = document.getElementById('subsubcategories-table-body');
    const filterSub = document.getElementById('subsubcat-filter-subcategory').value;
    
    let filtered = subsubcategories;
    if (filterSub) {
      filtered = subsubcategories.filter(ssc => ssc.subcategory_id === parseInt(filterSub));
    }
    
    document.getElementById('subsubcat-count').textContent = `${filtered.length} items`;
    
    if (!filtered || filtered.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--color-gray-400);">No sub-subcategories found</td></tr>';
      return;
    }
    
    let html = '';
    filtered.forEach(ssc => {
      const subcat = subcategories.find(sc => sc.id === ssc.subcategory_id);
      const cat = categories.find(c => c.id === (subcat ? subcat.category_id : null));
      html += `
        <tr>
          <td><strong style="color:var(--color-gray-900);">${escapeHtml(ssc.name)}</strong></td>
          <td><code style="background:var(--color-gray-50);padding:0.125rem 0.5rem;border-radius:4px;font-size:0.75rem;color:var(--color-gray-600);">${escapeHtml(ssc.slug)}</code></td>
          <td><span class="badge-subcategory">${escapeHtml(subcat ? subcat.name : 'Unknown')}</span></td>
          <td><span class="badge-category">${escapeHtml(cat ? cat.name : 'Unknown')}</span></td>
          <td><span class="badge-subcategory">${ssc.website_count || 0}</span></td>
          <td>
            <span class="badge-status ${ssc.is_active ? 'active' : 'inactive'}">
