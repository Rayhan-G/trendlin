      document.getElementById('website-form-logo').value = data.logo_url || '';
      document.getElementById('website-form-country').value = data.country || 'USA';
      document.getElementById('website-form-active').checked = data.is_active === 1;
      document.getElementById('website-form-featured').checked = data.is_featured === 1;
      document.getElementById('website-form-score').value = data.reliability_score || 5;
      document.getElementById('website-score-label').textContent = (data.reliability_score || 5) + '/10';
    } else {
      document.getElementById('website-modal-title').textContent = 'Add Website';
      document.getElementById('website-form-active').checked = true;
      document.getElementById('website-form-featured').checked = false;
      document.getElementById('website-form-country').value = 'USA';
