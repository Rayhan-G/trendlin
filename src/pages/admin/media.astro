---
// ============================================
// MEDIA LIBRARY - Trendlin Admin (Enterprise Edition)
// ============================================

import AdminLayout from '../../layouts/AdminLayout.astro';

let mediaItems = [];
let folders = [];
let totalMedia = 0;
let totalFolders = 0;

try {
  const response = await fetch(`${Astro.url.origin}/api/admin/media`);
  if (response.ok) {
    const data = await response.json();
    if (data.success) {
      mediaItems = data.media || [];
      folders = data.folders || [];
      totalMedia = mediaItems.length;
      totalFolders = folders.length;
    }
  }
} catch (error) {
  console.error('Error fetching media:', error);
}
---

<AdminLayout title="Media Library - Trendlin">
  
  <!-- ============================================ -->
  <!-- HEADER -->
  <!-- ============================================ -->
  <div class="page-header">
    <div class="header-content">
      <div class="header-icon-wrapper">
        <svg class="header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <polyline points="21 15 16 10 5 21" />
        </svg>
      </div>
      <div>
        <h1 class="page-title">Media Library</h1>
        <p class="page-subtitle">
          <span class="media-count">{totalMedia}</span> files •
          <span class="folder-count">{totalFolders}</span> folders
        </p>
      </div>
    </div>
    <div class="header-actions">
      <button id="createFolderBtn" class="btn btn-secondary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
          <line x1="12" y1="11" x2="12" y2="17" />
          <line x1="9" y1="14" x2="15" y2="14" />
        </svg>
        New Folder
      </button>
      <button id="uploadBtn" class="btn btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="17 8 12 3 7 8" />
          <line x1="12" y1="3" x2="12" y2="15" />
        </svg>
        Upload Files
      </button>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- BREADCRUMB -->
  <!-- ============================================ -->
  <div class="breadcrumb-container">
    <div class="breadcrumb-content">
      <button id="rootBtn" class="breadcrumb-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
        </svg>
        <span>Root</span>
      </button>
      <span id="folderPath" class="breadcrumb-path"></span>
      <div class="breadcrumb-actions">
        <button id="refreshBtn" class="breadcrumb-refresh" title="Refresh">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10" />
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- UPLOAD PROGRESS -->
  <!-- ============================================ -->
  <div id="uploadProgress" class="upload-progress" style="display:none;">
    <div class="upload-progress-content">
      <div class="upload-progress-info">
        <span id="uploadFileName" class="upload-progress-name">Uploading...</span>
        <span id="uploadPercent" class="upload-progress-percent">0%</span>
      </div>
      <div class="upload-progress-bar">
        <div id="progressBar" class="upload-progress-fill" style="width:0%"></div>
      </div>
      <div class="upload-progress-meta">
        <span id="uploadSpeed">0 KB/s</span>
        <span id="uploadRemaining">--</span>
      </div>
      <button id="cancelUploadBtn" class="upload-progress-cancel">Cancel</button>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- VIEW TOOLS -->
  <!-- ============================================ -->
  <div class="view-tools">
    <div class="view-tools-left">
      <button id="gridViewBtn" class="view-btn view-btn-active" title="Grid view">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7" rx="1" />
          <rect x="14" y="3" width="7" height="7" rx="1" />
          <rect x="3" y="14" width="7" height="7" rx="1" />
          <rect x="14" y="14" width="7" height="7" rx="1" />
        </svg>
        Grid
      </button>
      <button id="listViewBtn" class="view-btn" title="List view">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="8" y1="6" x2="21" y2="6" />
          <line x1="8" y1="12" x2="21" y2="12" />
          <line x1="8" y1="18" x2="21" y2="18" />
          <line x1="3" y1="6" x2="3.01" y2="6" />
          <line x1="3" y1="12" x2="3.01" y2="12" />
          <line x1="3" y1="18" x2="3.01" y2="18" />
        </svg>
        List
      </button>
    </div>
    <div class="view-tools-right">
      <span id="selectedCount" class="selection-count">0 selected</span>
      <button id="selectAllBtn" class="selection-action">Select All</button>
      <button id="deleteSelectedBtn" class="selection-action selection-action-danger" style="display:none;">Delete Selected</button>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- MEDIA GRID -->
  <!-- ============================================ -->
  <div id="mediaGrid" class="media-grid">
    <!-- Populated by JavaScript -->
  </div>

  <!-- ============================================ -->
  <!-- MEDIA LIST -->
  <!-- ============================================ -->
  <div id="mediaList" class="media-list" style="display:none;">
    <div class="table-wrapper">
      <table class="media-table" id="mediaTable">
        <thead>
          <tr>
            <th class="col-select">
              <input type="checkbox" id="selectAllCheckbox" class="checkbox" />
            </th>
            <th class="col-file">File</th>
            <th class="col-name">Name</th>
            <th class="col-size">Size</th>
            <th class="col-date">Uploaded</th>
            <th class="col-actions">Actions</th>
          </tr>
        </thead>
        <tbody id="mediaListBody">
          <!-- Populated by JavaScript -->
        </tbody>
      </table>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- EMPTY STATE -->
  <!-- ============================================ -->
  <div id="emptyState" class="empty-state" style="display:none;">
    <div class="empty-icon-wrapper">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
        <circle cx="8.5" cy="8.5" r="1.5" />
        <polyline points="21 15 16 10 5 21" />
      </svg>
    </div>
    <h3>This folder is empty</h3>
    <p>Upload images or create subfolders to organize your files</p>
    <div class="empty-actions">
      <button onclick="document.getElementById('uploadBtn').click()" class="btn btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="17 8 12 3 7 8" />
          <line x1="12" y1="3" x2="12" y2="15" />
        </svg>
        Upload Files
      </button>
      <button onclick="document.getElementById('createFolderBtn').click()" class="btn btn-secondary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
          <line x1="12" y1="11" x2="12" y2="17" />
          <line x1="9" y1="14" x2="15" y2="14" />
        </svg>
        Create Folder
      </button>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- LOADING STATE -->
  <!-- ============================================ -->
  <div id="loadingState" class="loading-state">
    <div class="spinner"></div>
    <p>Loading media...</p>
  </div>

  <!-- ============================================ -->
  <!-- PREVIEW MODAL -->
  <!-- ============================================ -->
  <div id="previewModal" class="modal-overlay" style="display:none;">
    <div class="modal modal-lg">
      <div class="modal-header">
        <div class="modal-header-info">
          <span id="previewFileType" class="modal-file-type">Image</span>
          <span id="previewFileName" class="modal-file-name"></span>
        </div>
        <div class="modal-header-actions">
          <button id="previewCopyLink" class="btn-action btn-action-sm" title="Copy link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
            </svg>
            Link
          </button>
          <button id="previewCopyMarkdown" class="btn-action btn-action-sm" title="Copy Markdown">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
            MD
          </button>
          <button id="previewCopyHTML" class="btn-action btn-action-sm" title="Copy HTML">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6" />
              <polyline points="8 6 2 12 8 18" />
            </svg>
            HTML
          </button>
          <button onclick="closePreviewModal()" class="modal-close" title="Close">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>
      </div>
      <div id="previewContent" class="modal-body modal-body-center">
        <!-- Populated by JavaScript -->
      </div>
      <div class="modal-footer">
        <div class="modal-footer-info">
          <span id="previewFileSize"></span>
          <span class="modal-footer-divider">•</span>
          <span id="previewFileDate"></span>
        </div>
        <button id="previewDeleteBtn" class="btn btn-danger">Delete File</button>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- TOAST -->
  <!-- ============================================ -->
  <div id="toast" class="toast"></div>

</AdminLayout>

<!-- ============================================ -->
<!-- JAVASCRIPT -->
<!-- ============================================ -->
<script>
  // ============================================
  // STATE MANAGEMENT
  // ============================================
  let allMedia = [];
  let allFolders = [];
  let currentFolder = '';
  let selectedItems = new Set();
  let viewMode = 'grid';
  let uploadController = null;
  let isUploading = false;

  // ============================================
  // DOM READY
  // ============================================
  document.addEventListener('DOMContentLoaded', function() {
    const urlParams = new URLSearchParams(window.location.search);
    const folderParam = urlParams.get('folder') || '';
    if (folderParam) {
      currentFolder = folderParam;
    }
    
    loadMedia();
    setupEventListeners();
    setupDragAndDrop();
  });

  // ============================================
  // SETUP EVENT LISTENERS
  // ============================================
  function setupEventListeners() {
    document.getElementById('uploadBtn').addEventListener('click', triggerUpload);
    document.getElementById('createFolderBtn').addEventListener('click', createFolder);
    
    document.getElementById('rootBtn').addEventListener('click', function() {
      navigateToFolder('');
    });
    
    document.getElementById('refreshBtn').addEventListener('click', loadMedia);
    
    document.getElementById('gridViewBtn').addEventListener('click', function() {
      viewMode = 'grid';
      document.getElementById('gridViewBtn').className = 'view-btn view-btn-active';
      document.getElementById('listViewBtn').className = 'view-btn';
      document.getElementById('mediaGrid').style.display = 'grid';
      document.getElementById('mediaList').style.display = 'none';
      renderCurrentFolder();
    });
    
    document.getElementById('listViewBtn').addEventListener('click', function() {
      viewMode = 'list';
      document.getElementById('listViewBtn').className = 'view-btn view-btn-active';
      document.getElementById('gridViewBtn').className = 'view-btn';
      document.getElementById('mediaGrid').style.display = 'none';
      document.getElementById('mediaList').style.display = 'block';
      renderCurrentFolder();
    });
    
    document.getElementById('selectAllBtn').addEventListener('click', function() {
      const items = getCurrentItems();
      if (selectedItems.size === items.filter(i => !i.isFolder).length) {
        selectedItems.clear();
      } else {
        items.forEach(item => {
          if (!item.isFolder) {
            selectedItems.add(item.id);
          }
        });
      }
      renderCurrentFolder();
      updateSelectionUI();
    });
    
    document.getElementById('selectAllCheckbox').addEventListener('change', function() {
      const items = getCurrentItems();
      if (this.checked) {
        items.forEach(item => {
          if (!item.isFolder) {
            selectedItems.add(item.id);
          }
        });
      } else {
        selectedItems.clear();
      }
      renderCurrentFolder();
      updateSelectionUI();
    });
    
    document.getElementById('deleteSelectedBtn').addEventListener('click', function() {
      if (selectedItems.size === 0) return;
      if (confirm(`Delete ${selectedItems.size} selected files?`)) {
        deleteSelectedFiles();
      }
    });
    
    document.getElementById('previewModal').addEventListener('click', function(e) {
      if (e.target === this) closePreviewModal();
    });
    
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closePreviewModal();
      }
      if ((e.ctrlKey || e.metaKey) && e.key === 'a') {
        if (!e.target.closest('input')) {
          e.preventDefault();
          document.getElementById('selectAllBtn').click();
        }
      }
    });
  }

  // ============================================
  // DRAG AND DROP
  // ============================================
  function setupDragAndDrop() {
    let dragCounter = 0;
    
    document.addEventListener('dragenter', function(e) {
      e.preventDefault();
      dragCounter++;
    });
    
    document.addEventListener('dragleave', function(e) {
      e.preventDefault();
      dragCounter--;
      if (dragCounter === 0) {
        document.body.classList.remove('drag-over');
      }
    });
    
    document.addEventListener('dragover', function(e) {
      e.preventDefault();
      document.body.classList.add('drag-over');
    });
    
    document.addEventListener('drop', function(e) {
      e.preventDefault();
      document.body.classList.remove('drag-over');
      dragCounter = 0;
      
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        handleFiles(files);
      }
    });
  }

  // ============================================
  // LOAD MEDIA
  // ============================================
  async function loadMedia() {
    try {
      document.getElementById('loadingState').style.display = 'block';
      document.getElementById('mediaGrid').style.display = 'none';
      document.getElementById('mediaList').style.display = 'none';
      document.getElementById('emptyState').style.display = 'none';
      
      const response = await fetch('/api/admin/media');
      const result = await response.json();
      
      if (result.success) {
        allMedia = result.media || [];
        allFolders = result.folders || [];
        
        document.querySelector('.media-count').textContent = allMedia.length;
        document.querySelector('.folder-count').textContent = allFolders.length;
        
        renderCurrentFolder();
      } else {
        showToast('Failed to load media: ' + result.error, 'error');
      }
    } catch (error) {
      console.error('Error loading media:', error);
      showToast('Failed to load media', 'error');
    } finally {
      document.getElementById('loadingState').style.display = 'none';
    }
  }

  // ============================================
  // GET CURRENT ITEMS
  // ============================================
  function getCurrentItems() {
    const subFolders = getSubFolders();
    const files = getFilesInFolder();
    return [
      ...subFolders.map(f => ({ isFolder: true, name: f })),
      ...files
    ];
  }

  function getSubFolders() {
    if (!currentFolder) {
      return allFolders.filter(f => !f.includes('/')).sort();
    }
    return allFolders.filter(f => {
      return f.startsWith(currentFolder + '/') && 
             f.split('/').length === currentFolder.split('/').length + 1;
    }).sort();
  }

  function getFilesInFolder() {
    if (!currentFolder) {
      return allMedia.filter(item => !item.folder || item.folder === '').sort((a, b) => 
        new Date(b.created_at) - new Date(a.created_at)
      );
    }
    return allMedia.filter(item => item.folder === currentFolder).sort((a, b) => 
      new Date(b.created_at) - new Date(a.created_at)
    );
  }

  // ============================================
  // NAVIGATE TO FOLDER
  // ============================================
  window.navigateToFolder = function(folder) {
    currentFolder = folder || '';
    selectedItems.clear();
    renderCurrentFolder();
    updateSelectionUI();
    
    const url = new URL(window.location);
    url.searchParams.set('folder', folder || '');
    window.history.pushState({ folder: folder }, '', url);
  };

  // ============================================
  // RENDER CURRENT FOLDER
  // ============================================
  function renderCurrentFolder() {
    const grid = document.getElementById('mediaGrid');
    const list = document.getElementById('mediaListBody');
    const empty = document.getElementById('emptyState');
    
    const items = getCurrentItems();
    
    const locationDisplay = document.querySelector('.page-subtitle');
    if (locationDisplay) {
      const folderDisplay = currentFolder ? `📁 ${currentFolder}` : '📁 Root';
      const count = items.length;
      locationDisplay.innerHTML = 
        `<span class="media-count">${count}</span> items in <span class="folder-count">${folderDisplay}</span>`;
    }
    
    updateBreadcrumb();
    
    if (items.length === 0) {
      grid.style.display = 'none';
      document.getElementById('mediaList').style.display = 'none';
      empty.style.display = 'block';
      return;
    }
    
    empty.style.display = 'none';
    
    if (viewMode === 'grid') {
      grid.style.display = 'grid';
      document.getElementById('mediaList').style.display = 'none';
      renderGridView(items);
    } else {
      grid.style.display = 'none';
      document.getElementById('mediaList').style.display = 'block';
      renderListView(items);
    }
    
    updateSelectionUI();
  }

  // ============================================
  // RENDER GRID VIEW
  // ============================================
  function renderGridView(items) {
    const grid = document.getElementById('mediaGrid');
    
    grid.innerHTML = items.map((item, index) => {
      if (item.isFolder) {
        const folderName = item.name.split('/').pop();
        const fileCount = allMedia.filter(m => m.folder === item.name).length;
        
        return `
          <div class="media-grid-item media-folder" onclick="navigateToFolder('${item.name}')">
            <div class="media-grid-item-content">
              <div class="media-grid-item-icon media-grid-item-icon-folder">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                </svg>
              </div>
              <span class="media-grid-item-name">${escapeHtml(folderName)}</span>
              <span class="media-grid-item-meta">${fileCount} files</span>
            </div>
          </div>
        `;
      }
      
      const isImage = item.mime_type && item.mime_type.startsWith('image/');
      const isVideo = item.mime_type && item.mime_type.startsWith('video/');
      const isSelected = selectedItems.has(item.id);
      const displayName = item.original_name || item.filename.split('/').pop() || 'Unknown';
      
      return `
        <div class="media-grid-item ${isSelected ? 'media-grid-item-selected' : ''}" onclick="toggleSelect(${item.id})" ondblclick="window.openPreview(${JSON.stringify(item).replace(/"/g, '&quot;')})">
          <div class="media-grid-item-thumb">
            ${isImage ? `
              <img 
                src="${item.url}" 
                alt="${escapeHtml(item.alt_text || displayName)}" 
                class="media-grid-item-img"
                loading="lazy"
                onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22%3E%3Crect fill=%22%23f3f4f6%22 width=%22200%22 height=%22200%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 text-anchor=%22middle%22 dy=%22.3em%22 fill=%22%239ca3af%22 font-size=%2216%22%3ENo Image%3C/text%3E%3C/svg%3E'"
              />
            ` : isVideo ? `
              <video class="media-grid-item-video" muted>
                <source src="${item.url}" type="${item.mime_type}">
              </video>
              <div class="media-grid-item-overlay-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="5 3 19 12 5 21 5 3" />
                </svg>
              </div>
            ` : `
              <div class="media-grid-item-file-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                </svg>
              </div>
            `}
            <div class="media-grid-item-checkbox">
              <input type="checkbox" ${isSelected ? 'checked' : ''} class="checkbox" onclick="event.stopPropagation(); toggleSelect(${item.id})" />
            </div>
            <div class="media-grid-item-overlay">
              <button onclick="event.stopPropagation(); window.openPreview(${JSON.stringify(item).replace(/"/g, '&quot;')})" class="btn-action btn-action-sm">Preview</button>
              <button onclick="event.stopPropagation(); window.copyLink('${item.url}')" class="btn-action btn-action-sm">Copy Link</button>
              <button onclick="event.stopPropagation(); window.deleteMedia(${item.id}, '${item.filename}')" class="btn-action btn-action-sm btn-action-danger">Delete</button>
            </div>
          </div>
          <div class="media-grid-item-info">
            <span class="media-grid-item-name">${escapeHtml(displayName)}</span>
            <span class="media-grid-item-meta">${formatFileSize(item.file_size)}</span>
          </div>
        </div>
      `;
    }).join('');
  }

  // ============================================
  // RENDER LIST VIEW
  // ============================================
  function renderListView(items) {
    const tbody = document.getElementById('mediaListBody');
    
    tbody.innerHTML = items.map((item) => {
      if (item.isFolder) {
        const folderName = item.name.split('/').pop();
        const fileCount = allMedia.filter(m => m.folder === item.name).length;
        
        return `
          <tr class="media-list-row media-list-folder" onclick="navigateToFolder('${item.name}')">
            <td class="col-select"></td>
            <td class="col-file">
              <div class="media-list-file">
                <div class="media-list-icon media-list-icon-folder">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                  </svg>
                </div>
                <span class="media-list-name">${escapeHtml(folderName)}</span>
              </div>
            </td>
            <td class="col-name">Folder</td>
            <td class="col-size">${fileCount} files</td>
            <td class="col-date">—</td>
            <td class="col-actions"></td>
          </tr>
        `;
      }
      
      const isImage = item.mime_type && item.mime_type.startsWith('image/');
      const isVideo = item.mime_type && item.mime_type.startsWith('video/');
      const isSelected = selectedItems.has(item.id);
      const displayName = item.original_name || item.filename.split('/').pop() || 'Unknown';
      
      return `
        <tr class="media-list-row ${isSelected ? 'media-list-row-selected' : ''}" onclick="toggleSelect(${item.id})" ondblclick="window.openPreview(${JSON.stringify(item).replace(/"/g, '&quot;')})">
          <td class="col-select">
            <input type="checkbox" ${isSelected ? 'checked' : ''} class="checkbox" onclick="event.stopPropagation(); toggleSelect(${item.id})" />
          </td>
          <td class="col-file">
            <div class="media-list-file">
              ${isImage ? `
                <img src="${item.url}" alt="${escapeHtml(displayName)}" class="media-list-thumb" />
              ` : isVideo ? `
                <div class="media-list-icon media-list-icon-video">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="5 3 19 12 5 21 5 3" />
                  </svg>
                </div>
              ` : `
                <div class="media-list-icon media-list-icon-file">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                  </svg>
                </div>
              `}
              <span class="media-list-name">${escapeHtml(displayName)}</span>
            </div>
          </td>
          <td class="col-name">${escapeHtml(item.alt_text || '—')}</td>
          <td class="col-size">${formatFileSize(item.file_size)}</td>
          <td class="col-date">${formatDate(item.created_at)}</td>
          <td class="col-actions">
            <div class="media-list-actions">
              <button onclick="event.stopPropagation(); window.openPreview(${JSON.stringify(item).replace(/"/g, '&quot;')})" class="btn-action btn-action-sm" title="Preview">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              </button>
              <button onclick="event.stopPropagation(); window.copyLink('${item.url}')" class="btn-action btn-action-sm" title="Copy Link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                </svg>
              </button>
              <button onclick="event.stopPropagation(); window.deleteMedia(${item.id}, '${item.filename}')" class="btn-action btn-action-sm btn-action-danger" title="Delete">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6" />
                  <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                </svg>
              </button>
            </div>
          </td>
        </tr>
      `;
    }).join('');
  }

  // ============================================
  // UPDATE BREADCRUMB
  // ============================================
  function updateBreadcrumb() {
    const pathElement = document.getElementById('folderPath');
    if (currentFolder) {
      const parts = currentFolder.split('/');
      let html = '';
      let path = '';
      parts.forEach((part, index) => {
        path += (index > 0 ? '/' : '') + part;
        html += `
          <span class="breadcrumb-separator">/</span>
          <button onclick="navigateToFolder('${path}')" class="breadcrumb-item breadcrumb-link">${escapeHtml(part)}</button>
        `;
      });
      pathElement.innerHTML = html;
    } else {
      pathElement.innerHTML = '';
    }
  }

  // ============================================
  // SELECTION
  // ============================================
  window.toggleSelect = function(id) {
    if (selectedItems.has(id)) {
      selectedItems.delete(id);
    } else {
      selectedItems.add(id);
    }
    renderCurrentFolder();
    updateSelectionUI();
  };

  function updateSelectionUI() {
    const count = selectedItems.size;
    document.getElementById('selectedCount').textContent = `${count} selected`;
    const deleteBtn = document.getElementById('deleteSelectedBtn');
    if (count > 0) {
      deleteBtn.style.display = 'inline-flex';
      deleteBtn.textContent = `Delete ${count}`;
    } else {
      deleteBtn.style.display = 'none';
    }
    
    const items = getCurrentItems();
    const selectable = items.filter(i => !i.isFolder);
    const allChecked = selectable.length > 0 && selectable.every(i => selectedItems.has(i.id));
    document.getElementById('selectAllCheckbox').checked = allChecked && selectable.length > 0;
  }

  // ============================================
  // DELETE SELECTED FILES
  // ============================================
  async function deleteSelectedFiles() {
    const ids = Array.from(selectedItems);
    let deleted = 0;
    
    for (const id of ids) {
      try {
        const item = allMedia.find(m => m.id === id);
        if (!item) continue;
        
        const response = await fetch('/api/admin/media', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, filename: item.filename })
        });
        
        if (response.ok) {
          deleted++;
        }
      } catch (error) {
        console.error('Error deleting file:', error);
      }
    }
    
    selectedItems.clear();
    showToast(`Deleted ${deleted} files successfully`, 'success');
    loadMedia();
  }

  // ============================================
  // PREVIEW MODAL
  // ============================================
  window.openPreview = function(item) {
    const modal = document.getElementById('previewModal');
    const content = document.getElementById('previewContent');
    const fileType = document.getElementById('previewFileType');
    const fileName = document.getElementById('previewFileName');
    const fileSize = document.getElementById('previewFileSize');
    const fileDate = document.getElementById('previewFileDate');
    
    const isImage = item.mime_type && item.mime_type.startsWith('image/');
    const isVideo = item.mime_type && item.mime_type.startsWith('video/');
    
    fileType.textContent = item.mime_type || 'File';
    fileName.textContent = item.original_name || item.filename.split('/').pop() || 'Unknown';
    fileSize.textContent = formatFileSize(item.file_size);
    fileDate.textContent = item.created_at ? formatDate(item.created_at) : '—';
    
    if (isImage) {
      content.innerHTML = `<img src="${item.url}" alt="${escapeHtml(item.alt_text || '')}" class="preview-image" />`;
    } else if (isVideo) {
      content.innerHTML = `
        <video controls class="preview-video">
          <source src="${item.url}" type="${item.mime_type}">
          Your browser does not support the video tag.
        </video>
      `;
    } else {
      content.innerHTML = `
        <div class="preview-file">
          <div class="preview-file-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
            </svg>
          </div>
          <p class="preview-file-message">Preview not available for this file type</p>
          <a href="${item.url}" target="_blank" class="btn btn-primary">Download</a>
        </div>
      `;
    }
    
    document.getElementById('previewCopyLink').onclick = function() {
      copyToClipboard(item.url, 'Link copied to clipboard!');
    };
    document.getElementById('previewCopyMarkdown').onclick = function() {
      copyToClipboard(`![${item.alt_text || 'Image'}](${item.url})`, 'Markdown copied!');
    };
    document.getElementById('previewCopyHTML').onclick = function() {
      copyToClipboard(`<img src="${item.url}" alt="${item.alt_text || 'Image'}" />`, 'HTML copied!');
    };
    document.getElementById('previewDeleteBtn').onclick = function() {
      if (confirm('Delete this file?')) {
        closePreviewModal();
        deleteMedia(item.id, item.filename);
      }
    };
    
    modal.style.display = 'flex';
  };

  window.closePreviewModal = function() {
    document.getElementById('previewModal').style.display = 'none';
  };

  // ============================================
  // COPY FUNCTIONS
  // ============================================
  window.copyLink = function(url) {
    copyToClipboard(url, 'Link copied to clipboard!');
  };

  window.copyMarkdown = function(url, alt) {
    copyToClipboard(`![${alt || 'Image'}](${url})`, 'Markdown copied!');
  };

  window.copyHTML = function(url, alt) {
    copyToClipboard(`<img src="${url}" alt="${alt || 'Image'}" />`, 'HTML copied!');
  };

  async function copyToClipboard(text, successMessage) {
    try {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        await navigator.clipboard.writeText(text);
      } else {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
      }
      showToast(successMessage || 'Copied to clipboard!', 'success');
    } catch (error) {
      showToast('Failed to copy', 'error');
    }
  }

  // ============================================
  // DELETE MEDIA
  // ============================================
  window.deleteMedia = async function(id, filename) {
    if (!confirm(`Delete this file?`)) return;
    
    try {
      const response = await fetch('/api/admin/media', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, filename })
      });
      
      const result = await response.json();
      
      if (result.success) {
        showToast('Deleted successfully', 'success');
        loadMedia();
      } else {
        showToast('Failed to delete: ' + result.error, 'error');
      }
    } catch (error) {
      showToast('Failed to delete', 'error');
    }
  };

  // ============================================
  // CREATE FOLDER
  // ============================================
  async function createFolder() {
    const folderName = prompt('Enter folder name:');
    if (!folderName) return;
    
    const sanitized = folderName.trim().replace(/[^a-zA-Z0-9-_]/g, '-').toLowerCase();
    if (!sanitized) {
      showToast('Invalid folder name. Use letters, numbers, hyphens, and underscores.', 'error');
      return;
    }
    
    const folderPath = currentFolder ? `${currentFolder}/${sanitized}` : sanitized;
    
    if (allFolders.includes(folderPath)) {
      showToast('Folder already exists!', 'error');
      return;
    }
    
    try {
      const response = await fetch('/api/admin/media/folders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ folder: folderPath, name: sanitized })
      });
      
      const result = await response.json();
      
      if (result.success) {
        showToast(`Folder "${sanitized}" created!`, 'success');
        loadMedia();
        setTimeout(() => {
          navigateToFolder(folderPath);
        }, 500);
      } else {
        showToast('Failed to create folder: ' + result.error, 'error');
      }
    } catch (error) {
      console.error('Error creating folder:', error);
      showToast('Failed to create folder', 'error');
    }
  }

  // ============================================
  // UPLOAD FILES
  // ============================================
  function triggerUpload() {
    const fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.accept = 'image/*,video/*,.pdf,.doc,.docx,.txt';
    fileInput.multiple = true;
    fileInput.onchange = function(e) {
      if (this.files.length > 0) {
        handleFiles(this.files);
      }
    };
    fileInput.click();
  }

  async function handleFiles(files) {
    if (isUploading) {
      showToast('Upload already in progress', 'error');
      return;
    }
    
    isUploading = true;
    const progressDiv = document.getElementById('uploadProgress');
    const fileNameSpan = document.getElementById('uploadFileName');
    const percentSpan = document.getElementById('uploadPercent');
    const progressBar = document.getElementById('progressBar');
    const speedSpan = document.getElementById('uploadSpeed');
    const remainingSpan = document.getElementById('uploadRemaining');
    const cancelBtn = document.getElementById('cancelUploadBtn');
    
    progressDiv.style.display = 'block';
    let cancelled = false;
    
    cancelBtn.onclick = function() {
      cancelled = true;
      if (uploadController) {
        uploadController.abort();
      }
      showToast('Upload cancelled', 'error');
      isUploading = false;
      progressDiv.style.display = 'none';
    };
    
    const totalFiles = files.length;
    let completed = 0;
    let startTime = Date.now();
    
    for (let i = 0; i < totalFiles; i++) {
      if (cancelled) break;
      
      const file = files[i];
      const folderInfo = currentFolder ? ` → ${currentFolder}` : ' → Root';
      fileNameSpan.textContent = `Uploading ${file.name}${folderInfo} (${i + 1}/${totalFiles})`;
      
      const formData = new FormData();
      formData.append('image', file);
      if (currentFolder) {
        formData.append('folder', currentFolder);
      }
      
      uploadController = new AbortController();
      
      try {
        const response = await fetch('/api/upload', {
          method: 'POST',
          body: formData,
          signal: uploadController.signal
        });
        
        const result = await response.json();
        
        if (result.success) {
          completed++;
          const progress = (completed / totalFiles) * 100;
          progressBar.style.width = `${progress}%`;
          percentSpan.textContent = `${Math.round(progress)}%`;
          
          const elapsed = (Date.now() - startTime) / 1000;
          const speed = file.size / elapsed / 1024;
          speedSpan.textContent = `${speed.toFixed(1)} KB/s`;
          
          const remaining = (totalFiles - completed) * (elapsed / completed);
          if (remaining > 60) {
            remainingSpan.textContent = `${Math.round(remaining / 60)} min remaining`;
          } else {
            remainingSpan.textContent = `${Math.round(remaining)}s remaining`;
          }
        } else {
          showToast(`Failed to upload ${file.name}: ${result.error}`, 'error');
        }
      } catch (error) {
        if (error.name !== 'AbortError') {
          console.error('Upload error:', error);
          showToast(`Failed to upload ${file.name}`, 'error');
        }
      }
    }
    
    isUploading = false;
    progressDiv.style.display = 'none';
    
    if (!cancelled) {
      showToast(`Uploaded ${completed} of ${totalFiles} files`, 'success');
      loadMedia();
    }
  }

  // ============================================
  // UTILITY FUNCTIONS
  // ============================================
  function formatFileSize(bytes) {
    if (!bytes) return '0 B';
    const sizes = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(1024));
    return `${(bytes / Math.pow(1024, i)).toFixed(1)} ${sizes[i]}`;
  }

  function formatDate(dateString) {
    if (!dateString) return '—';
    const date = new Date(dateString);
    return date.toLocaleDateString('en-US', { 
      month: 'short', 
      day: 'numeric', 
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  }

  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // ============================================
  // TOAST NOTIFICATION
  // ============================================
  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = message;
    toast.className = `toast toast-${type}`;
    toast.classList.add('toast-visible');
    
    clearTimeout(toast._timeout);
    toast._timeout = setTimeout(() => {
      toast.classList.remove('toast-visible');
    }, 3000);
  }

  // ============================================
  // BROWSER HISTORY
  // ============================================
  window.addEventListener('popstate', function(event) {
    const folder = event.state?.folder || '';
    currentFolder = folder;
    renderCurrentFolder();
  });

  // ============================================
  // DRAG OVER STYLING
  // ============================================
  const style = document.createElement('style');
  style.textContent = `
    body.drag-over::before {
      content: '';
      position: fixed;
      inset: 0;
      background: rgba(59, 130, 246, 0.05);
      backdrop-filter: blur(4px);
      z-index: 9999;
      border: 4px dashed #3b82f6;
      margin: 20px;
      border-radius: 20px;
      pointer-events: none;
    }
    
    body.drag-over::after {
      content: 'Drop files here';
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 10000;
      font-size: 2rem;
      font-weight: 600;
      color: #3b82f6;
      pointer-events: none;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
  `;
  document.head.appendChild(style);
</script>

