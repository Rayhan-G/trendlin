</style>

<script>
  // ============================================
  // STATE
  // ============================================
  let contentItems = [];
  let contentTypes = [];
  let contentStatuses = [];
  let contentCategories = [];
  let editingId = null;
  let currentMonth = new Date().getMonth();
  let currentYear = new Date().getFullYear();
  let currentView = 'calendar';

  // ============================================
  // TOAST
  // ============================================
  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = message;
    toast.className = `toast ${type}`;
    toast.classList.add('show');
    clearTimeout(toast._timeout);
    toast._timeout = setTimeout(() => toast.classList.remove('show'), 3000);
  }

  // ============================================
  // LOAD DATA
  // ============================================
  function loadData() {
    Promise.all([
      loadContent(),
      loadContentTypes(),
      loadContentStatuses(),
      loadContentCategories(),
      loadStats()
    ]).then(() => {
      renderView();
      populateFilters();
      populateFormSelects();
    }).catch(err => {
      console.error('Error loading data:', err);
      showToast('Error loading data', 'error');
    });
  }

  function loadContent() {
    const params = new URLSearchParams();
    const status = document.getElementById('filter-status').value;
    const type = document.getElementById('filter-type').value;
    const category = document.getElementById('filter-category').value;
    const search = document.getElementById('search-input').value;

    if (status) params.append('status', status);
    if (type) params.append('type', type);
    if (category) params.append('category', category);
    if (search) params.append('search', search);

    return fetch('/api/admin/content?' + params.toString())
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          contentItems = data.data || [];
        } else {
          console.error('API error:', data.error);
          contentItems = [];
        }
        return contentItems;
      })
      .catch(err => {
        console.error('Error loading content:', err);
        contentItems = [];
        return contentItems;
      });
  }

  function loadContentTypes() {
    return fetch('/api/admin/content/types')
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          contentTypes = data.data || [];
        }
        return contentTypes;
      })
      .catch(err => {
        console.error('Error loading content types:', err);
        contentTypes = [];
        return contentTypes;
      });
  }

  function loadContentStatuses() {
    return fetch('/api/admin/content/status')
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          contentStatuses = data.data || [];
        }
        return contentStatuses;
      })
      .catch(err => {
        console.error('Error loading content statuses:', err);
        contentStatuses = [];
        return contentStatuses;
      });
  }

  function loadContentCategories() {
    return fetch('/api/admin/content/categories')
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          contentCategories = data.data || [];
        }
        return contentCategories;
      })
      .catch(err => {
        console.error('Error loading content categories:', err);
        contentCategories = [];
        return contentCategories;
      });
  }

  function loadStats() {
    return fetch('/api/admin/content/stats')
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          document.getElementById('total-count').textContent = data.data.total || 0;
          document.getElementById('published-count').textContent = data.data.published || 0;
          document.getElementById('scheduled-count').textContent = data.data.scheduled || 0;
          document.getElementById('monthly-count').textContent = data.data.thisMonth || 0;

          const draftStatus = contentStatuses.find(s => s.slug === 'draft');
          if (draftStatus) {
            const draftData = data.data.byStatus.find(s => s.id === draftStatus.id);
            document.getElementById('draft-count').textContent = draftData ? draftData.count : 0;
          }
        }
        return data;
      })
      .catch(err => {
        console.error('Error loading stats:', err);
        return { data: {} };
      });
  }

  // ============================================
  // VIEWS
  // ============================================
  function switchView(view) {
    currentView = view;
    document.querySelectorAll('.btn-view').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.view-content').forEach(v => v.classList.remove('active'));

    const buttons = document.querySelectorAll('.btn-view');
    const viewMap = { calendar: 0, list: 1 };
    if (buttons[viewMap[view]]) {
      buttons[viewMap[view]].classList.add('active');
    }

    document.getElementById(`${view}-view`).classList.add('active');
    renderView();
  }

  function renderView() {
    if (currentView === 'list') {
      renderList();
    } else {
      renderCalendar();
    }
  }

  // ============================================
  // MONTH CALENDAR
  // ============================================
  function changeMonth(delta) {
    currentMonth += delta;
    if (currentMonth > 11) {
      currentMonth = 0;
      currentYear++;
    } else if (currentMonth < 0) {
      currentMonth = 11;
      currentYear--;
    }
    renderCalendar();
  }

  function goToday() {
    const today = new Date();
    currentMonth = today.getMonth();
    currentYear = today.getFullYear();
    renderCalendar();
  }

  function renderCalendar() {
    const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
      'July', 'August', 'September', 'October', 'November', 'December'
    ];
    document.getElementById('calendar-title').textContent =
      `${monthNames[currentMonth]} ${currentYear}`;

    const firstDay = new Date(currentYear, currentMonth, 1).getDay();
    const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
    const today = new Date();

    let html = '';

    for (let i = 0; i < firstDay; i++) {
      html += `<div class="calendar-day empty"></div>`;
    }

    for (let d = 1; d <= daysInMonth; d++) {
      const dateStr = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
      const isToday = d === today.getDate() && currentMonth === today.getMonth() && currentYear === today.getFullYear();

      const dayContent = contentItems.filter(c => {
        if (!c.scheduled_publish_at) return false;
        const pubDate = new Date(c.scheduled_publish_at);
        return pubDate.getDate() === d &&
          pubDate.getMonth() === currentMonth &&
          pubDate.getFullYear() === currentYear;
      });

      html += `<div class="calendar-day" onclick="openModalByDate('${dateStr}')">`;
      html += `<div class="day-number ${isToday ? 'today' : ''}">${d}</div>`;

      if (dayContent.length === 0) {
        html += `<div class="calendar-empty-text">No content</div>`;
      } else {
        dayContent.slice(0, 4).forEach(item => {
          const type = contentTypes.find(t => t.id === item.content_type_id);
          const status = contentStatuses.find(s => s.id === item.status_id);
          const color = status ? status.color : '#94a3b8';
          const icon = type ? type.icon : '📄';
          const time = item.scheduled_publish_at ?
            new Date(item.scheduled_publish_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) :
            '';

          html += `
            <div class="day-event" style="background:${color}20;border-left:3px solid ${color}" 
                 onclick="event.stopPropagation();editContent(${item.id})">
              <span class="event-status-dot" style="background:${color}"></span>
              <span class="event-time">${time}</span> ${icon} ${escapeHtml(item.title)}
            </div>
          `;
        });

        if (dayContent.length > 4) {
          html += `<div style="font-size:0.6rem;color:#94a3b8;padding:0.1rem 0;">+${dayContent.length - 4} more</div>`;
        }
      }

      html += `</div>`;
    }

    document.getElementById('calendar-days').innerHTML = html;
  }

  // ============================================
  // LIST VIEW
  // ============================================
  function renderList() {
    const tbody = document.getElementById('list-table-body');
    const empty = document.getElementById('list-empty');
    const tableWrap = document.getElementById('list-table-wrap');

    if (!contentItems || contentItems.length === 0) {
      tableWrap.style.display = 'none';
      empty.style.display = 'block';
      return;
    }

    tableWrap.style.display = 'block';
    empty.style.display = 'none';

    let html = '';
    contentItems.forEach(item => {
      const type = contentTypes.find(t => t.id === item.content_type_id);
      const status = contentStatuses.find(s => s.id === item.status_id);
      const category = contentCategories.find(c => c.id === item.category_id);

      const typeIcon = type ? type.icon : '📄';
      const typeColor = type ? type.color : '#94a3b8';
      const statusColor = status ? status.color : '#94a3b8';
      const statusName = status ? status.name : 'Unknown';

      const scheduledDate = item.scheduled_publish_at ?
        new Date(item.scheduled_publish_at).toLocaleDateString('en-US', { 
          month: 'short', 
          day: 'numeric', 
          year: 'numeric' 
        }) :
        'Not scheduled';

      html += `
        <tr>
          <td>
            <div>
              <div style="font-weight:600;color:#0f172a;font-size:0.875rem;">${escapeHtml(item.title)}</div>
              ${item.excerpt ? `<div style="font-size:0.75rem;color:#94a3b8;margin-top:0.125rem;">${escapeHtml(item.excerpt)}</div>` : ''}
            </div>
          </td>
          <td>
            <span class="badge-type" style="background:${typeColor}20;color:${typeColor}">
              ${typeIcon} ${type ? type.name : 'Unknown'}
            </span>
          </td>
          <td style="font-size:0.813rem;color:#64748b;">${category ? escapeHtml(category.name) : '—'}</td>
          <td>
            <span class="badge-status" style="background:${statusColor}20;color:${statusColor}">
              ${statusName}
            </span>
          </td>
          <td style="font-size:0.813rem;color:#64748b;">${scheduledDate}</td>
          <td>
            <div class="actions-cell">
              <button class="btn-sm btn-sm-edit" onclick="editContent(${item.id})">✏️</button>
              ${item.status_id === contentStatuses.find(s => s.slug === 'scheduled')?.id ? 
                `<button class="btn-sm btn-sm-publish" onclick="publishContent(${item.id})">🚀</button>` : 
                ''}
              <button class="btn-sm btn-sm-delete" onclick="deleteContent(${item.id})">🗑️</button>
            </div>
          </td>
        </tr>
      `;
    });

    tbody.innerHTML = html;
  }

  // ============================================
  // POPULATE SELECTS
  // ============================================
  function populateFilters() {
    const statusSel = document.getElementById('filter-status');
    statusSel.innerHTML = '<option value="">All Statuses</option>';
    contentStatuses.forEach(s => {
      const opt = document.createElement('option');
      opt.value = s.id;
      opt.textContent = s.name;
      statusSel.appendChild(opt);
    });

    const typeSel = document.getElementById('filter-type');
    typeSel.innerHTML = '<option value="">All Types</option>';
    contentTypes.forEach(t => {
      const opt = document.createElement('option');
      opt.value = t.id;
      opt.textContent = t.icon + ' ' + t.name;
      typeSel.appendChild(opt);
    });

    const catSel = document.getElementById('filter-category');
    catSel.innerHTML = '<option value="">All Categories</option>';
    contentCategories.forEach(c => {
      const opt = document.createElement('option');
      opt.value = c.id;
      opt.textContent = c.name;
      catSel.appendChild(opt);
    });
  }

  function populateFormSelects() {
    const typeSel = document.getElementById('form-type');
    typeSel.innerHTML = '<option value="">Select Type</option>';
    contentTypes.forEach(t => {
      const opt = document.createElement('option');
      opt.value = t.id;
      opt.textContent = t.icon + ' ' + t.name;
      typeSel.appendChild(opt);
    });

    const catSel = document.getElementById('form-category');
    catSel.innerHTML = '<option value="">None</option>';
    contentCategories.forEach(c => {
      const opt = document.createElement('option');
      opt.value = c.id;
      opt.textContent = c.name;
      catSel.appendChild(opt);
    });

    const statusSel = document.getElementById('form-status');
    statusSel.innerHTML = '';
    contentStatuses.forEach(s => {
      const opt = document.createElement('option');
      opt.value = s.id;
      opt.textContent = s.name;
      statusSel.appendChild(opt);
    });
  }

  // ============================================
  // MODAL FUNCTIONS
  // ============================================
  function openModal(data = null) {
    document.getElementById('content-form').reset();
    editingId = null;
    document.getElementById('content-edit-id').value = '';
    document.getElementById('form-message').style.display = 'none';

    populateFormSelects();

    if (data) {
      editingId = data.id;
      document.getElementById('modal-title').textContent = 'Edit Content';
      document.getElementById('modal-submit').textContent = 'Update Content';
      document.getElementById('content-edit-id').value = data.id;
      document.getElementById('form-title').value = data.title || '';
      document.getElementById('form-slug').value = data.slug || '';
      document.getElementById('form-type').value = data.content_type_id || '';
      document.getElementById('form-category').value = data.category_id || '';
      document.getElementById('form-excerpt').value = data.excerpt || '';
      document.getElementById('form-content').value = data.content || '';
      document.getElementById('form-tags').value = data.tags || '';
      document.getElementById('form-status').value = data.status_id || '';
      document.getElementById('form-scheduled').value = data.scheduled_publish_at ?
        data.scheduled_publish_at.slice(0, 16) : '';
      document.getElementById('form-featured-image').value = data.featured_image || '';
      document.getElementById('form-cover-image').value = data.cover_image || '';
      document.getElementById('form-featured').checked = data.is_featured === 1;
      document.getElementById('form-published').checked = data.is_published === 1;
      document.getElementById('form-meta-title').value = data.meta_title || '';
      document.getElementById('form-meta-desc').value = data.meta_description || '';
      document.getElementById('form-meta-keywords').value = data.meta_keywords || '';
    } else {
      document.getElementById('modal-title').textContent = 'Create Content';
      document.getElementById('modal-submit').textContent = 'Save Content';
      document.getElementById('form-status').value = contentStatuses.find(s => s.slug === 'draft')?.id || '';
    }

    document.getElementById('content-modal').style.display = 'flex';
  }

  window.editContent = function(id) {
    const content = contentItems.find(c => c.id === id);
    if (content) openModal(content);
  };

  function closeModal(modalId) {
    document.getElementById(modalId).style.display = 'none';
  }

  function openModalByDate(dateStr) {
    const date = new Date(dateStr);
    date.setHours(9, 0, 0, 0);
    const formatted = date.toISOString().slice(0, 16);
    document.getElementById('form-scheduled').value = formatted;
    openModal();
  }

  // ============================================
  // CONTENT CRUD
  // ============================================
  window.deleteContent = function(id) {
    const content = contentItems.find(c => c.id === id);
    if (!confirm(`Delete "${content?.title}"? This cannot be undone.`)) return;

    fetch('/api/admin/content/' + id, { method: 'DELETE' })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          showToast('✅ Content deleted', 'success');
          loadData();
        } else {
          showToast('❌ ' + (data.error || 'Failed to delete'), 'error');
        }
      })
      .catch(err => {
        showToast('❌ Error deleting content', 'error');
        console.error(err);
      });
  };

  function publishContent(id) {
    if (!confirm('Publish this content now?')) return;

    const statusId = contentStatuses.find(s => s.slug === 'published')?.id;
    fetch('/api/admin/content/' + id, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        status_id: statusId,
        is_published: 1,
        published_at: new Date().toISOString()
      })
    })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          showToast('✅ Content published!', 'success');
          loadData();
        } else {
          showToast('❌ ' + (data.error || 'Failed to publish'), 'error');
        }
      })
      .catch(err => {
        showToast('❌ Error publishing content', 'error');
        console.error(err);
      });
  }

  // ============================================
  // FORM SUBMIT
  // ============================================
  document.getElementById('content-form').addEventListener('submit', function(e) {
    e.preventDefault();

    const id = document.getElementById('content-edit-id').value;
    const data = {
      title: document.getElementById('form-title').value.trim(),
      slug: document.getElementById('form-slug').value.trim(),
      content: document.getElementById('form-content').value.trim(),
      excerpt: document.getElementById('form-excerpt').value.trim(),
      content_type_id: parseInt(document.getElementById('form-type').value) || null,
      category_id: parseInt(document.getElementById('form-category').value) || null,
      status_id: parseInt(document.getElementById('form-status').value) || null,
      featured_image: document.getElementById('form-featured-image').value.trim(),
      cover_image: document.getElementById('form-cover-image').value.trim(),
      tags: document.getElementById('form-tags').value.trim(),
      meta_title: document.getElementById('form-meta-title').value.trim(),
      meta_description: document.getElementById('form-meta-desc').value.trim(),
      meta_keywords: document.getElementById('form-meta-keywords').value.trim(),
      scheduled_publish_at: document.getElementById('form-scheduled').value || null,
      is_featured: document.getElementById('form-featured').checked ? 1 : 0,
      is_published: document.getElementById('form-published').checked ? 1 : 0
    };

    if (!data.title || !data.slug || !data.content_type_id) {
      const msg = document.getElementById('form-message');
      msg.textContent = 'Title, slug, and content type are required';
      msg.className = 'form-message error';
      msg.style.display = 'block';
      return;
    }

    const url = id ? '/api/admin/content/' + id : '/api/admin/content';
    const method = id ? 'PUT' : 'POST';

    fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    })
      .then(r => r.json())
      .then(result => {
        if (result.success) {
          showToast(id ? '✅ Content updated!' : '✅ Content created!', 'success');
          closeModal('content-modal');
          loadData();
        } else {
          const msg = document.getElementById('form-message');
          msg.textContent = result.error || 'Failed to save';
          msg.className = 'form-message error';
          msg.style.display = 'block';
        }
      })
      .catch(err => {
        const msg = document.getElementById('form-message');
        msg.textContent = 'Error saving content';
        msg.className = 'form-message error';
        msg.style.display = 'block';
        console.error(err);
      });
  });

  // ============================================
  // HELPERS
  // ============================================
  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  let searchTimeout;

  function debounceSearch() {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(loadData, 300);
  }

  // ============================================
  // EVENT LISTENERS
  // ============================================
  document.getElementById('add-content-btn').addEventListener('click', () => openModal());

  document.getElementById('content-modal').addEventListener('click', function(e) {
    if (e.target === this) {
      this.style.display = 'none';
    }
  });

  document.querySelector('#content-modal .modal-close').addEventListener('click', function() {
    document.getElementById('content-modal').style.display = 'none';
  });

  // ============================================
  // INIT
  // ============================================
  document.addEventListener('DOMContentLoaded', () => {
    loadData();
    switchView('calendar');
  });
</script>