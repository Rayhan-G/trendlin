---
// /src/pages/admin/newsletter/new.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getDB } from '../../../lib/db';
---

<AdminLayout title="New Campaign">
  <div class="campaign-editor">
    <h1>Create New Campaign</h1>
    
    <form id="campaign-form">
      <div class="form-group">
        <label for="subject">Subject Line</label>
        <input type="text" id="subject" required placeholder="Your newsletter subject" />
      </div>

      <div class="form-group">
        <label for="preview">Preview Text</label>
        <input type="text" id="preview" placeholder="Preview text for email clients" />
      </div>

      <div class="form-group">
        <label for="list">Audience</label>
        <select id="list">
          <option value="">All Subscribers</option>
          <option value="1">Technology</option>
          <option value="2">Finance</option>
          <option value="3">Health</option>
        </select>
      </div>

      <div class="form-group">
        <label for="content">Content</label>
        <textarea id="content" rows="10" placeholder="Write your newsletter content here..."></textarea>
      </div>

      <div class="form-group">
        <label for="schedule">Schedule</label>
        <input type="datetime-local" id="schedule" />
      </div>

      <div class="actions">
        <button type="button" id="save-draft" class="btn-secondary">Save Draft</button>
        <button type="button" id="schedule-btn" class="btn-primary">Schedule</button>
        <button type="button" id="send-now" class="btn-success">Send Now</button>
      </div>
    </form>

    <div id="message" class="message"></div>
  </div>
</AdminLayout>

<style>
  .campaign-editor {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #1e293b;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    font-size: 1rem;
  }

  .form-group textarea {
    min-height: 300px;
  }

  .actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  .btn-primary,
  .btn-secondary,
  .btn-success {
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 4px;
    font-weight: 600;
    cursor: pointer;
  }

  .btn-primary {
    background: #3b82f6;
    color: white;
  }

  .btn-secondary {
    background: #e2e8f0;
    color: #1e293b;
  }

  .btn-success {
    background: #22c55e;
    color: white;
  }

  .message {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 4px;
    display: none;
  }

  .message.success {
    display: block;
    background: #dcfce7;
    color: #166534;
  }

  .message.error {
    display: block;
    background: #fee2e2;
    color: #991b1b;
  }
</style>

<script>
  import { createCampaign } from '../../../lib/api';

  const showMessage = (text, type) => {
    const el = document.getElementById('message');
    el.textContent = text;
    el.className = `message ${type}`;
    setTimeout(() => { el.className = 'message'; }, 5000);
  };

  const getFormData = () => ({
    subject: document.getElementById('subject').value,
    previewText: document.getElementById('preview').value,
    contentHtml: document.getElementById('content').value,
    listId: document.getElementById('list').value || null,
  });

  document.getElementById('save-draft')?.addEventListener('click', async () => {
    try {
      const data = getFormData();
      data.status = 'draft';
      const result = await createCampaign(data);
      showMessage('Campaign saved as draft!', 'success');
    } catch (error) {
      showMessage('Failed to save draft: ' + error.message, 'error');
    }
  });

  document.getElementById('schedule-btn')?.addEventListener('click', async () => {
    const scheduleInput = document.getElementById('schedule');
    if (!scheduleInput.value) {
      showMessage('Please select a schedule time', 'error');
      return;
    }

    try {
      const data = getFormData();
      data.status = 'scheduled';
      data.scheduledAt = scheduleInput.value;
      const result = await createCampaign(data);
      showMessage(`Campaign scheduled for ${new Date(scheduleInput.value).toLocaleString()}`, 'success');
    } catch (error) {
      showMessage('Failed to schedule campaign: ' + error.message, 'error');
    }
  });

  document.getElementById('send-now')?.addEventListener('click', async () => {
    if (!confirm('Are you sure you want to send this campaign now?')) return;

    try {
      const data = getFormData();
      data.status = 'sending';
      const result = await createCampaign(data);
      showMessage('Campaign is being sent!', 'success');
    } catch (error) {
      showMessage('Failed to send campaign: ' + error.message, 'error');
    }
  });
</script>