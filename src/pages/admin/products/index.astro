<script>
  document.addEventListener('DOMContentLoaded', function() {
    // ============================================
    // DELETE PRODUCT FUNCTIONALITY
    // ============================================
    const deleteButtons = document.querySelectorAll('.delete-product-btn');
    
    deleteButtons.forEach(function(button) {
      button.addEventListener('click', async function(e) {
        e.preventDefault();
        
        const productId = this.getAttribute('data-id');
        const productRow = this.closest('.product-row');
        const productName = productRow?.querySelector('.product-name')?.textContent || 'this product';
        
        if (!confirm(`Are you sure you want to delete "${productName}"?`)) {
          return;
        }
        
        // Show loading state
        const originalHTML = this.innerHTML;
        this.innerHTML = '⏳';
        this.disabled = true;
        this.classList.add('loading');
        
        try {
          const response = await fetch(`/api/admin/products/${productId}`, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json'
            }
          });
          
          const result = await response.json();
          
          if (!response.ok) {
            throw new Error(result.error || 'Delete failed');
          }
          
          // Fade out and remove row
          if (productRow) {
            productRow.style.transition = 'opacity 0.3s, transform 0.3s';
            productRow.style.opacity = '0';
            productRow.style.transform = 'scale(0.95)';
            
            setTimeout(() => {
              productRow.remove();
              
              // Update product count if needed
              const remainingRows = document.querySelectorAll('.product-row');
              if (remainingRows.length === 0) {
                // Reload to show empty state
                window.location.reload();
              }
              
              // Update table info
              updateTableInfo(remainingRows.length);
            }, 400);
          } else {
            window.location.reload();
          }
          
        } catch (error) {
          console.error('Error:', error);
          alert('❌ Failed to delete product: ' + error.message);
          this.innerHTML = originalHTML;
          this.disabled = false;
          this.classList.remove('loading');
        }
      });
    });
    
    // ============================================
    // UPDATE TABLE INFO
    // ============================================
    function updateTableInfo(count) {
      const infoLabels = document.querySelectorAll('.table-info strong');
      if (infoLabels.length > 0) {
        infoLabels[0].textContent = count;
      }
      
      // Update footer
      const footerText = document.querySelector('.table-footer-text strong');
      if (footerText) {
        footerText.textContent = count;
      }
      
      // Update in stock count
      const inStockRows = document.querySelectorAll('.product-row .status-in-stock');
      const inStockCount = inStockRows.length;
      const inStockLabels = document.querySelectorAll('.table-info .status-indicator-active');
      if (inStockLabels.length > 0) {
        const parent = inStockLabels[0].closest('.table-info');
        if (parent) {
          const text = parent.textContent.trim();
          parent.innerHTML = `
            <span class="table-info-label">
              <span class="status-indicator status-indicator-active"></span>
              ${inStockCount} in stock
            </span>
          `;
        }
      }
    }
    
    // ============================================
    // SEARCH FUNCTIONALITY
    // ============================================
    const searchInput = document.getElementById('searchProducts');
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase().trim();
        const rows = document.querySelectorAll('.product-row');
        
        rows.forEach(row => {
          const name = row.querySelector('.product-name')?.textContent?.toLowerCase() || '';
          const slug = row.querySelector('.product-slug')?.textContent?.toLowerCase() || '';
          const category = row.querySelector('.category-tag')?.textContent?.toLowerCase() || '';
          const brand = row.querySelector('.brand-tag')?.textContent?.toLowerCase() || '';
          
          const shouldShow = searchTerm === '' || 
            name.includes(searchTerm) || 
            slug.includes(searchTerm) || 
            category.includes(searchTerm) || 
            brand.includes(searchTerm);
          
          row.style.display = shouldShow ? '' : 'none';
        });
        
        // Update visible count in footer
        const visibleRows = document.querySelectorAll('.product-row[style*="display: none"]');
        const totalRows = document.querySelectorAll('.product-row');
        const visibleCount = totalRows.length - visibleRows.length;
        
        const footerText = document.querySelector('.table-footer-text strong');
        if (footerText) {
          if (searchTerm) {
            footerText.textContent = `${visibleCount} of ${totalRows.length}`;
          } else {
            footerText.textContent = totalRows.length;
          }
        }
      });
    }
  });
</script>