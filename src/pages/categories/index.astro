// ============================================
// GET DATABASE CONNECTION
// ============================================
let db;
try {
  db = getDB(Astro.locals.runtime.env);
} catch (error) {
  console.error('❌ Database connection error:', error);
  db = null;
}

// ============================================
// FETCH POSTS FROM DATABASE
// ============================================
let allPosts = [];
let postCounts = {};
let totalPosts = 0;
let categoryHeroes = {};
let categories = [];

if (db) {
  try {
    // Fetch posts
    const result = await prepare(
      db,
      `SELECT * FROM posts WHERE is_draft = 0 ORDER BY created_at DESC`
    );
    
    allPosts = result?.results || [];
    
    allPosts.forEach(post => {
      if (post.category) {
        postCounts[post.category] = (postCounts[post.category] || 0) + 1;
        totalPosts++;
      }
    });
    
  } catch (error) {
    console.error('Database error:', error);
  }

  try {
    // Fetch category hero images
    const result = await prepare(
      db,
      `SELECT 
        c.slug,
        ch.hero_image
      FROM category_hero ch
      JOIN categories c ON ch.category_id = c.id
      WHERE ch.is_active = 1`
    );
    
    const heroes = result?.results || [];
    heroes.forEach(hero => {
      if (hero.slug) {
        categoryHeroes[hero.slug] = hero.hero_image;
      }
    });
    
    console.log('✅ Loaded hero images for categories:', Object.keys(categoryHeroes));
    
  } catch (error) {
    console.error('Error fetching category heroes:', error);
  }
}

// ============================================
// MERGE CATEGORIES DATA WITH HERO IMAGES
// ============================================
categories = categoriesData.map(cat => {
  return {
    ...cat,
    hero_image: categoryHeroes[cat.slug] || null // Only use hero image if it exists in database
  };
});

// ============================================
// HELPER FUNCTION TO GET HERO IMAGE
// ============================================
function getHeroImage(category) {
  return category.hero_image || null;
}
---

<BaseLayout title="Categories - Trendlin">
  <div class="max-w-6xl mx-auto px-6 py-16 sm:py-24 selection:bg-black selection:text-white">
    
    <!-- ============================================ -->
    <!-- HEADER -->
    <!-- ============================================ -->
    <div class="mb-20 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 border-b border-gray-100 pb-8">
      <div>
        <h1 class="text-4xl sm:text-6xl font-bold text-gray-900 tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">
          Categories
        </h1>
        <p class="text-gray-500 text-base sm:text-lg mt-3 font-light tracking-wide">
          Discover <span class="font-medium text-gray-800">{totalPosts} articles</span> curated across <span class="font-medium text-gray-800">{categories.length}</span> categories.
        </p>
      </div>
      <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-gray-400" style="font-family: 'Space Grotesk', sans-serif;">
        <span class="inline-block w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        Matrix Engine v2
      </div>
    </div>

    <!-- ============================================ -->
    <!-- MAIN CATEGORIES STACK -->
    <!-- ============================================ -->
    <div class="space-y-16" id="matrixContainer">
      {categories.map((category, index) => {
        const count = postCounts[category.name] || 0;
        const posts = allPosts.filter(p => p.category === category.name);
        const isImageRight = index % 2 === 0;
        const targetGradient = category.gradient;
        const heroImage = getHeroImage(category);
        
        return (
          <div 
            class="category-section" 
            data-category={category.slug}
            data-ring={category.ringClass}
            key={category.slug}
          >
            <div class="view-wrapper relative bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-md transition-all duration-500 hover:shadow-xl hover:border-gray-200/80">
              
              <!-- ========================================== -->
              <!-- STATE 1: SPLIT VIEW (Default - Overview) -->
              <!-- ========================================== -->
              <div class="state-split grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[380px]">
                
                <!-- Image Side (Uses category.image - NOT hero) -->
                <div class={`lg:col-span-5 relative p-6 sm:p-8 flex items-center justify-center bg-gray-50/50 ${isImageRight ? 'lg:order-2 border-l border-gray-100' : 'lg:order-1 border-r border-gray-100'}`}>
                  <div class="relative w-full aspect-[4/3] lg:aspect-square max-w-sm rounded-2xl overflow-hidden shadow-inner group">
                    <img 
                      src={category.image} 
                      alt={category.name}
                      class="w-full h-full object-cover transition-transform duration-700 ease-out scale-102 group-hover:scale-105 filter grayscale-[10%] group-hover:grayscale-0"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-60"></div>
                    <div class="absolute bottom-4 left-4 bg-white/90 backdrop-blur-md rounded-xl py-2 px-3 shadow-lg border border-white/40 flex items-center gap-2">
                      <span class="text-xl">{category.icon}</span>
                      <span class="text-xs font-bold uppercase tracking-wider text-gray-800" style="font-family: 'Space Grotesk', sans-serif;">{category.slug.replace('-', ' ')}</span>
                    </div>
                  </div>
                </div>
                
                <!-- Content Side -->
                <div class={`lg:col-span-7 p-8 sm:p-12 flex flex-col justify-between ${isImageRight ? 'lg:order-1' : 'lg:order-2'} relative overflow-hidden bg-white`}>
                  <div class={`absolute -right-24 -top-24 w-48 h-48 rounded-full bg-gradient-to-br ${targetGradient} opacity-[0.03] blur-3xl pointer-events-none`}></div>
                  
                  <div class="relative z-10 my-auto">
                    <div class="flex items-center gap-4 mb-4">
                      <div class={`w-2 h-8 rounded-full bg-gradient-to-b ${targetGradient}`}></div>
                      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">
                        {category.name}
                      </h2>
                    </div>
                    
                    <div class="flex items-center gap-3 mb-6">
                      <span class="text-xs font-semibold bg-gray-100 text-gray-600 px-3 py-1 rounded-md tracking-wide">
                        {count} {count === 1 ? 'Article' : 'Articles'}
                      </span>
                    </div>

                    <p class="text-gray-500 text-base leading-relaxed max-w-xl font-normal">
                      {category.description}
                    </p>
                  </div>

                  <div class="pt-8 border-t border-gray-50 mt-8 flex items-center justify-between">
                    <button 
                      class="explore-matrix-btn inline-flex items-center gap-3 px-6 py-3 rounded-xl text-sm font-semibold text-white transition-all duration-300 hover:shadow-lg w-fit bg-gray-900 hover:bg-black group/btn"
                      data-category={category.slug}
                    >
                      <span>View Articles</span>
                      <svg class="w-4 h-4 transition-transform duration-300 group-hover/btn:translate-x-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                      </svg>
                    </button>
                  </div>
                </div>

              </div>

              <!-- ========================================== -->
              <!-- STATE 2: EXPANDED SLIDER WITH HERO SECTION -->
              <!-- ========================================== -->
              <div class="state-slider hidden flex-col transition-all duration-500">
                
                <!-- HERO SECTION - Appears ONLY in expanded view -->
                {heroImage ? (
                  <div class="category-hero relative w-full overflow-hidden bg-gray-900">
                    <div class="relative h-48 sm:h-56 md:h-64 lg:h-72">
                      
                      <!-- Hero Image (Wide format) -->
                      <img 
                        src={heroImage} 
                        alt={`${category.name} hero`}
                        class="w-full h-full object-cover"
                        loading="lazy"
                        onerror="this.style.display='none'; this.parentElement.querySelector('.hero-fallback').style.display='flex';"
                      />
                      
                      <!-- Fallback if image fails -->
                      <div class="hero-fallback absolute inset-0 hidden items-center justify-center bg-gradient-to-r from-gray-800 to-gray-900">
                        <div class="text-center text-white">
                          <span class="text-4xl block mb-2">{category.icon}</span>
                          <span class="text-xl font-bold">{category.name}</span>
                        </div>
                      </div>
                      
                      <!-- Gradient Overlay for text readability -->
                      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
                      
                      <!-- Hero Content Overlay -->
                      <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8 text-white">
                        <div class="max-w-3xl">
                          <div class="flex items-center gap-3 mb-2">
                            <span class="text-3xl sm:text-4xl">{category.icon}</span>
                            <h3 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">
                              {category.name}
                            </h3>
                          </div>
                          <p class="text-sm sm:text-base text-white/90 max-w-2xl">
                            {category.description}
                          </p>
                          <div class="flex items-center gap-3 mt-3 flex-wrap">
                            <span class="text-xs font-medium bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full">
                              {count} {count === 1 ? 'Article' : 'Articles'}
                            </span>
                            <span class="text-xs font-medium bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full">
                              🏷️ {category.slug.replace('-', ' ')}
                            </span>
                            <span class="text-xs font-medium bg-emerald-500/30 backdrop-blur-sm px-3 py-1 rounded-full">
                              ✨ Custom Hero
                            </span>
                          </div>
                        </div>
                      </div>
                    </div>
                    
                    <!-- Close Button inside hero -->
                    <button 
                      class="close-matrix-btn absolute top-4 right-4 text-white/70 hover:text-white flex items-center gap-1.5 transition-colors duration-200 px-3 py-1.5 rounded-md bg-black/30 hover:bg-black/50 backdrop-blur-sm border border-white/20"
                      data-category={category.slug}
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                      </svg>
                      <span class="text-xs font-medium">Close</span>
                    </button>
                  </div>
                ) : (
                  <!-- If no hero image, show a simple header -->
                  <div class="bg-gradient-to-r from-gray-800 to-gray-900 px-6 py-4 flex items-center justify-between">
                    <div class="flex items-center gap-3 text-white">
                      <span class="text-2xl">{category.icon}</span>
                      <h3 class="font-bold tracking-tight text-lg sm:text-xl" style="font-family: 'Space Grotesk', sans-serif;">
                        {category.name} Archive
                      </h3>
                      <span class="text-xs text-gray-400 font-normal">/ {count} entries</span>
                    </div>
                    <button 
                      class="close-matrix-btn text-xs text-gray-400 hover:text-white flex items-center gap-1.5 transition-colors duration-200 px-2.5 py-1 rounded-md border border-gray-700 hover:border-gray-500"
                      data-category={category.slug}
                    >
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                      </svg>
                      Esc
                    </button>
                  </div>
                )}

                <!-- Horizontal Scroll - Posts -->
                <div class="flex overflow-x-auto gap-5 p-6 sm:p-8 bg-gray-50/70 dark:bg-gray-900/30 scroll-smooth" 
                     style="scrollbar-width: none; -ms-overflow-style: none; overflow-x: auto;">
                  <style>
                    .flex.overflow-x-auto::-webkit-scrollbar {
                      display: none;
                    }
                  </style>
                  
                  {posts.length > 0 ? (
                    posts.map((post) => (
                      <PostCard post={post} />
                    ))
                  ) : (
                    <div class="w-full text-center py-12 text-gray-400 font-light text-sm">
                      <span class="text-4xl block mb-3">📭</span>
                      No publications found in this category yet.
                    </div>
                  )}
                </div>
                
                <!-- Scroll Hint -->
                <div class="flex justify-center items-center gap-1 py-3 text-[10px] font-medium text-gray-400 dark:text-gray-500 tracking-widest uppercase bg-gray-50/70 dark:bg-gray-900/30 border-t border-gray-100 dark:border-gray-800">
                  <svg class="w-3.5 h-3.5 animate-bounce-x" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                  </svg>
                  <span>Scroll to explore articles</span>
                  <svg class="w-3.5 h-3.5 animate-bounce-x" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                  </svg>
                </div>
              </div>

            </div>
          </div>
        );
      })}
    </div>
  </div>
</BaseLayout>

<!-- ============================================ -->
<!-- GLOBAL STYLES -->
<!-- ============================================ -->
<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap');
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  /* Hide scrollbar but keep functionality */
  .scroll-smooth::-webkit-scrollbar {
    height: 6px;
  }
  .scroll-smooth::-webkit-scrollbar-track {
    background: #f3f4f6;
    border-radius: 9999px;
  }
  .scroll-smooth::-webkit-scrollbar-thumb {
    background: #e5e7eb;
    border-radius: 9999px;
  }
  .scroll-smooth::-webkit-scrollbar-thumb:hover {
    background: #d1d5db;
  }
  
  /* Bounce Animation */
  @keyframes bounce-x {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(6px); }
  }
  
  .animate-bounce-x {
    animation: bounce-x 1.8s ease-in-out infinite;
  }
  
  /* Hero image loading transition */
  .category-hero img {
    transition: opacity 0.5s ease;
  }
  
  .category-hero img[loading] {
    opacity: 0;
  }
  
  .category-hero img[loaded] {
    opacity: 1;
  }
</style>

<!-- ============================================ -->
<!-- JAVASCRIPT - INTERACTIVITY -->
<!-- ============================================ -->
<script>
  // ============================================
  // CLOSE ALL OPEN SLIDERS
  // ============================================
  function closeAllSliders() {
    document.querySelectorAll('.state-slider').forEach(s => {
      const section = s.closest('.category-section');
      const splitState = section?.querySelector('.state-split');
      const wrapper = section?.querySelector('.view-wrapper');
      const customRing = (section)?.dataset?.ring || 'ring-gray-900/10';
      
      s.classList.add('hidden');
      s.classList.remove('flex');
      splitState?.classList.remove('hidden');
      wrapper?.classList.remove('ring-4', customRing);
    });
  }

  // ============================================
  // EXPLORE MATRIX BUTTON - OPEN SLIDER
  // ============================================
  document.querySelectorAll('.explore-matrix-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const section = this.closest('.category-section');
      const splitState = section.querySelector('.state-split');
      const sliderState = section.querySelector('.state-slider');
      const wrapper = section.querySelector('.view-wrapper');
      const customRing = section.dataset.ring || 'ring-gray-900/10';
      
      const isOpen = !sliderState.classList.contains('hidden');
      
      if (isOpen) {
        // Close if already open
        sliderState.classList.add('hidden');
        sliderState.classList.remove('flex');
        splitState.classList.remove('hidden');
        wrapper.classList.remove('ring-4', customRing);
      } else {
        // Close all others first
        closeAllSliders();

        // Open this one
        splitState.classList.add('hidden');
        sliderState.classList.remove('hidden');
        sliderState.classList.add('flex');
        wrapper.classList.add('ring-4', customRing);
        
        // Smooth scroll to section
        setTimeout(() => {
          section.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 80);
      }
    });
  });
  
  // ============================================
  // CLOSE BUTTON
  // ============================================
  document.querySelectorAll('.close-matrix-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const section = this.closest('.category-section');
      const splitState = section.querySelector('.state-split');
      const sliderState = section.querySelector('.state-slider');
      const wrapper = section.querySelector('.view-wrapper');
      const customRing = section.dataset.ring || 'ring-gray-900/10';
      
      sliderState.classList.add('hidden');
      sliderState.classList.remove('flex');
      splitState.classList.remove('hidden');
      wrapper.classList.remove('ring-4', customRing);
    });
  });
  
  // ============================================
  // ESC KEY TO CLOSE ALL
  // ============================================
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeAllSliders();
    }
  });

  // ============================================
  // IMAGE LOADING HANDLER
  // ============================================
  document.addEventListener('DOMContentLoaded', function() {
    // Handle hero image loading
    document.querySelectorAll('.category-hero img').forEach(img => {
      img.addEventListener('load', function() {
        this.setAttribute('loaded', '');
      });
      
      // If image already loaded
      if (img.complete) {
        img.setAttribute('loaded', '');
      }
    });
  });
</script>